---
const links = [
  { href: '/',        label: 'Home' },
  { href: '/dev',     label: 'Dev' },
  { href: '/food',    label: 'Food' },
  { href: '/contact', label: 'Contact' },
];

const current = Astro.url.pathname;
---

<nav>
  <a href="/" class="nav-logo" aria-label="Nate Cowperthwaite — home">
    Nate<span class="nav-logo-dot">.</span>dev
  </a>

  <div class="nav-right">
    <ul class="nav-links">
      {links.map(({ href, label }) => (
        <li>
          <a
            href={href}
            aria-current={current === href || (href !== '/' && current.startsWith(href)) ? 'page' : undefined}
          >
            {label}
          </a>
        </li>
      ))}
    </ul>

    <button
      class="theme-toggle"
      aria-label="Toggle dark mode"
      data-theme-toggle
      title="Toggle light / dark mode"
    >
      <span class="theme-toggle-icon" aria-hidden="true">🌙</span>
    </button>
  </div>
</nav>

<script>
  (function () {
    const btn  = document.querySelector('[data-theme-toggle]');
    const icon = btn?.querySelector('.theme-toggle-icon');
    const html = document.documentElement;

    // Initialise from system preference (no localStorage — sandboxed)
    let dark = window.matchMedia('(prefers-color-scheme: dark)').matches;
    apply(dark);

    btn?.addEventListener('click', () => {
      dark = !dark;
      apply(dark);
    });

    function apply(isDark) {
      html.setAttribute('data-theme', isDark ? 'dark' : 'light');
      if (icon) icon.textContent = isDark ? '☀️' : '🌙';
      if (btn)  btn.setAttribute('aria-label', isDark ? 'Switch to light mode' : 'Switch to dark mode');
    }
  })();
</script>

<style>
  nav {
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .nav-logo {
    font-weight: 900;
    font-size: 1.05rem;
    letter-spacing: -0.03em;
    color: var(--text-primary);
    text-decoration: none;
    transition: color 0.2s;
  }
  .nav-logo:hover { color: var(--accent-blue); }
  .nav-logo-dot { color: var(--accent-blue); }

  .nav-right {
    display: flex;
    align-items: center;
    gap: var(--space-4);
  }

  .nav-links {
    display: flex;
    align-items: center;
    gap: var(--space-1);
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .nav-links a {
    color: var(--text-muted);
    font-size: 0.88rem;
    font-weight: 500;
    padding: 0.3rem 0.65rem;
    border-radius: var(--radius-sm);
    transition: color 0.2s, background 0.2s;
    text-decoration: none;
  }
  .nav-links a:hover,
  .nav-links a[aria-current='page'] {
    color: var(--accent-blue);
    background: var(--accent-blue-pale);
  }
</style>
