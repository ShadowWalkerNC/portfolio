---
import '../styles/global.css';
const { title, description, side } = Astro.props;
const themeColor = side === 'food' ? '#f97316' : '#2563eb';
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content={description ?? 'Nate Cowperthwaite — Chef & Developer'} />
  <meta name="theme-color" content={themeColor} />
  <title>{title ?? 'Nate Cowperthwaite'}</title>

  {side === 'dev' && (
    <link rel="icon" type="image/svg+xml" href="data:image/svg+xml,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 24 24' fill='none' stroke='%232563eb' stroke-width='2' stroke-linecap='round' stroke-linejoin='round'><polyline points='16 18 22 12 16 6'/><polyline points='8 6 2 12 8 18'/></svg>" />
  )}
  {side === 'food' && (
    <link rel="icon" type="image/svg+xml" href="data:image/svg+xml,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 24 24' fill='none' stroke='%23f97316' stroke-width='2' stroke-linecap='round' stroke-linejoin='round'><path d='M6 2v6a6 6 0 0 0 12 0V2'/><line x1='12' y1='14' x2='12' y2='22'/></svg>" />
  )}
  {!side && (
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  )}

  {side === 'dev' && (
    <link
      rel="stylesheet"
      href="https://cdn.jsdelivr.net/gh/devicons/devicon@latest/devicon.min.css"
    />
  )}
</head>
<body data-side={side}>

  <a href="#main-content" class="skip-link">Skip to content</a>

  <nav aria-label="Main navigation">
    <a href="/" class="nav-logo">
      <span class="nav-logo-name">Nate Cowperthwaite</span>
    </a>

    <button class="nav-burger" id="navBurger" aria-label="Toggle menu" aria-expanded="false" aria-controls="navMenu">
      <span></span><span></span><span></span>
    </button>

    <div class="nav-links" id="navMenu">
      {side === 'dev' && (
        <>
          <a href="/dev">Home</a>
          <a href="/dev/projects">Projects</a>
          <a href="/contact">Contact</a>
          <a href="/food" class="nav-switch nav-switch-food">
            <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M6 2v6a6 6 0 0 0 12 0V2"/><line x1="12" y1="14" x2="12" y2="22"/></svg>
            Chef Side
          </a>
        </>
      )}
      {side === 'food' && (
        <>
          <a href="/food">Home</a>
          <a href="/contact">Contact</a>
          <a href="/dev" class="nav-switch nav-switch-dev">
            <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="16 18 22 12 16 6"/><polyline points="8 6 2 12 8 18"/></svg>
            Dev Side
          </a>
        </>
      )}
      {!side && (
        <>
          <a href="/dev">Dev</a>
          <a href="/food">Food</a>
          <a href="/contact">Contact</a>
        </>
      )}
    </div>
  </nav>

  <slot />

  <footer>
    <p>Built with Astro &amp; a lot of
      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="display:inline-block;vertical-align:-2px;opacity:0.7" aria-hidden="true"><path d="M17 8h1a4 4 0 1 1 0 8h-1"/><path d="M3 8h14v9a4 4 0 0 1-4 4H7a4 4 0 0 1-4-4Z"/><line x1="6" y1="2" x2="6" y2="4"/><line x1="10" y1="2" x2="10" y2="4"/><line x1="14" y1="2" x2="14" y2="4"/></svg>
      &mdash; &copy; {new Date().getFullYear()} Nate Cowperthwaite</p>
    <p style="margin-top:0.4rem;">
      <a href="/dev">Dev</a> &middot;
      <a href="/food">Food</a> &middot;
      <a href="/contact">Contact</a>
    </p>
  </footer>

  <!-- ===== SCROLL REVEAL & BACKGROUND PARTICLES ===== -->
  <script>
    import { initBackgroundParticles } from '../utils/particles.js';
    
    (() => {
      // Initialize cursor-responsive floating canvas particles
      initBackgroundParticles();

      const els = document.querySelectorAll('.reveal, .reveal-left, .reveal-right');
      const reveal = (el: Element) => el.classList.add('revealed');
      const observer = new IntersectionObserver(
        (entries) => entries.forEach(e => {
          if (e.isIntersecting) { reveal(e.target); observer.unobserve(e.target); }
        }),
        { threshold: 0, rootMargin: '0px 0px 40px 0px' }
      );
      els.forEach(el => observer.observe(el));
      setTimeout(() => els.forEach(reveal), 600);
    })();
  </script>

  <script>
    const burger = document.getElementById('navBurger');
    const menu   = document.getElementById('navMenu');
    if (burger && menu) {
      burger.addEventListener('click', () => {
        const open = menu.classList.toggle('open');
        burger.classList.toggle('open', open);
        burger.setAttribute('aria-expanded', String(open));
      });
      const path = location.pathname;
      menu.querySelectorAll('a').forEach(a => {
        if (a.getAttribute('href') === path) a.setAttribute('aria-current', 'page');
      });
    }

    const updateGlow = (e: MouseEvent) => {
      const targets = document.querySelectorAll('.spotlight-card, .split-half');
      targets.forEach((el) => {
        const rect = el.getBoundingClientRect();
        const x = e.clientX - rect.left;
        const y = e.clientY - rect.top;
        (el as HTMLElement).style.setProperty('--mouse-x', `${x}px`);
        (el as HTMLElement).style.setProperty('--mouse-y', `${y}px`);
      });
    };

    let frameId: number | null = null;
    document.addEventListener('mousemove', (e) => {
      if (frameId) cancelAnimationFrame(frameId);
      frameId = requestAnimationFrame(() => updateGlow(e));
    });
  </script>

</body>
</html>
