---
import BaseLayout from '../layouts/BaseLayout.astro';
import ProjectCard from '../components/ProjectCard.astro';
import { getCollection } from 'astro:content';

const all = await getCollection('projects');

const categories = [
  { key: 'food-tech',      label: '🍽️ Food & Restaurant Tech' },
  { key: 'facility-ops',  label: '🏠 Senior Living & Facility Ops' },
  { key: 'dev-tools',     label: '🧱 Dev Platforms & Tools' },
  { key: 'experimental',  label: '⚙️ Experimental & Engine Work' },
];
---

<BaseLayout title="Projects — Nate Cowperthwaite" description="All projects by Nate Cowperthwaite — food tech, facility ops, dev tools, and experimental work.">
  <div class="max-w-6xl mx-auto px-6 pt-28 pb-24">

    <p class="font-mono text-xs uppercase tracking-widest mb-3" style="color: var(--blue-primary);">All Work</p>
    <h1 class="text-5xl font-extrabold mb-4 text-gradient-blue-white">Projects</h1>
    <p class="text-lg mb-16 max-w-2xl" style="color: var(--text-subtle);">
      A food-tech ecosystem, a facility ops platform, dev tools, and experimental engines.
      Each product is AI-native and MCP-connected.
    </p>

    {categories.map(cat => {
      const items = all.filter(p => p.data.category === cat.key);
      if (items.length === 0) return null;
      return (
        <section class="mb-20">
          <h2 class="text-2xl font-bold mb-8" style="color: #CBD5E1;">{cat.label}</h2>
          <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-6 stagger-children">
            {items.map(p => <ProjectCard project={p} />)}
          </div>
        </section>
      );
    })}
  </div>
</BaseLayout>
