---
import BaseLayout from '../layouts/BaseLayout.astro';
import ProjectCard from '../components/ProjectCard.astro';
import { getCollection } from 'astro:content';

const allProjects = await getCollection('projects');
const featured = allProjects.filter(p => p.data.featured);

const stack = [
  'TypeScript', 'Python', 'Kotlin', 'JavaScript',
  'React', 'Next.js', 'Tailwind', 'Vite', 'Flask',
  'Supabase', 'Vercel', 'Node.js', 'MCP',
];
---

<BaseLayout title="Nate Cowperthwaite — Cook. Builder. Founder.">

  <!-- HERO -->
  <section class="relative min-h-screen flex flex-col justify-center px-6 pt-24 pb-16 max-w-6xl mx-auto overflow-hidden">
    <div class="hero-glow"></div>
    <div class="hero-glow-left"></div>

    <div class="relative z-10">
      <p class="font-mono text-sm mb-5 tracking-widest uppercase animate-slide-down" style="color: var(--blue-bright);">
        Bangor, Maine
      </p>

      <h1 class="text-5xl sm:text-7xl font-extrabold leading-tight tracking-tight animate-slide-up">
        Cook.<br />
        Builder.<br />
        <span class="text-gradient-blue">Founder.</span>
      </h1>

      <p class="mt-6 text-lg max-w-xl leading-relaxed animate-fade-in" style="color: var(--text-subtle); animation-delay: 200ms;">
        10+ years in professional kitchens. Self-taught developer since 2017.
        Building the software food operations actually need — AI-native from the ground up.
      </p>

      <div class="mt-8 flex flex-wrap gap-4 animate-fade-in" style="animation-delay: 350ms;">
        <a href="/projects" class="btn-blue">See the Work</a>
        <a href="/contact" class="btn-outline">Get in Touch</a>
      </div>
    </div>
  </section>

  <hr class="section-divider" />

  <!-- ABOUT -->
  <section class="px-6 py-24 max-w-6xl mx-auto">
    <p class="font-mono text-xs uppercase tracking-widest mb-3" style="color: var(--blue-primary);">About</p>
    <h2 class="text-3xl sm:text-4xl font-bold mb-10 text-gradient-blue-white">Who I Am</h2>

    <div class="grid md:grid-cols-2 gap-10 leading-relaxed" style="color: var(--text-subtle);">
      <div class="animate-slide-up">
        <p class="mb-5">
          I'm Nate Cowperthwaite — born and raised in Ellsworth, Maine, now building in Bangor.
          I spent over a decade working every station in professional kitchens, from prep cook to line lead,
          until I started noticing how broken the software side of food operations really was.
          So I started building the fix.
        </p>
        <p class="mb-5">
          I'm a self-taught developer constructing a vertically integrated food-tech ecosystem:
          4 products, 9 MCP servers, one AI-native network.
          Everything I'm building will run in my own kitchen when
          <span class="font-semibold" style="color: #E2E8F0;">Half Baked Café & Bakehouse</span> opens in 2027.
        </p>
        <p>
          When the café opens, the tech will already be live and battle-tested.
          I'm not building software for investors — I'm building it for operators,
          because I am one.
        </p>
      </div>
      <div class="animate-slide-up" style="animation-delay: 150ms;">
        <p class="mb-5">
          I'm a <span class="font-semibold" style="color: #E2E8F0;">Concrete Random thinker</span> —
          I pattern-match across domains most people keep separate:
          kitchen ops, software architecture, AI tooling, systems design.
          Give me a hard problem and I'll find the angle nobody tried yet.
        </p>
        <p class="mb-5">
          My aesthetic is <span class="font-semibold" style="color: #E2E8F0;">Grit & Grace</span> —
          the craft is serious, the work is real, but it doesn't have to be ugly.
          Precision with soul. That's what I build.
        </p>
        <p class="font-mono text-sm" style="color: var(--blue-bright);">
          Build for operators, not investors.<br />
          Ship real things that run in real kitchens.
        </p>
      </div>
    </div>
  </section>

  <hr class="section-divider" />

  <!-- STACK -->
  <section class="px-6 py-24 max-w-6xl mx-auto">
    <p class="font-mono text-xs uppercase tracking-widest mb-3" style="color: var(--blue-primary);">Tech</p>
    <h2 class="text-3xl sm:text-4xl font-bold mb-10 text-gradient-blue-white">Stack</h2>
    <div class="flex flex-wrap gap-3 stagger-children">
      {stack.map(s => (
        <span class="animate-fade-in text-sm font-mono px-3 py-1.5 rounded-lg"
          style="background: var(--dark-card); border: 1px solid var(--dark-border); color: #CBD5E1;">
          {s}
        </span>
      ))}
    </div>
  </section>

  <hr class="section-divider" />

  <!-- FEATURED PROJECTS -->
  <section class="px-6 py-24 max-w-6xl mx-auto">
    <div class="flex items-center justify-between mb-10">
      <div>
        <p class="font-mono text-xs uppercase tracking-widest mb-3" style="color: var(--blue-primary);">Work</p>
        <h2 class="text-3xl sm:text-4xl font-bold text-gradient-blue-white">Featured Projects</h2>
      </div>
      <a href="/projects" class="text-sm font-mono transition" style="color: var(--blue-primary);" onmouseover="this.style.color='#fff'" onmouseout="this.style.color='var(--blue-primary)'">View all →</a>
    </div>
    <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-6 stagger-children">
      {featured.map(p => <ProjectCard project={p} />)}
    </div>
  </section>

</BaseLayout>
