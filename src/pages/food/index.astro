---
import BaseLayout from '../../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Nate Cowperthwaite — Chef"
  description="10+ years in professional kitchens across Maine. Scratch cooking, shift leadership, and the craft behind the food."
  side="food"
>
  <main>

    <!-- ===== RESUME HEADER ===== -->
    <section class="resume-header">
      <div class="resume-header-inner animate-fade-in-up">
        <div class="rh-top">
          <div>
            <h1 class="rh-name">Nathaniel Cowperthwaite</h1>
            <p class="rh-title">Professional Cook &amp; Kitchen Lead &mdash; 10+ Years</p>
            <div class="rh-meta">
              <span class="rh-meta-item">
                <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M20 10c0 6-8 12-8 12S4 16 4 10a8 8 0 0 1 16 0Z"/><circle cx="12" cy="10" r="3"/></svg>
                Bangor, ME
              </span>
              <span class="rh-meta-sep">&middot;</span>
              <span class="rh-meta-item">Maine-based</span>
              <span class="rh-meta-sep">&middot;</span>
              <a href="mailto:shadowwalkernc@gmail.com" class="rh-meta-link">shadowwalkernc@gmail.com</a>
            </div>
          </div>
          <div class="rh-stats">
            <div class="rh-stat"><span class="rh-stat-num">10+</span><span class="rh-stat-label">Years</span></div>
            <div class="rh-stat-div"></div>
            <div class="rh-stat"><span class="rh-stat-num ember">12+</span><span class="rh-stat-label">Roles</span></div>
            <div class="rh-stat-div"></div>
            <div class="rh-stat"><span class="rh-stat-num">2</span><span class="rh-stat-label">Sous Chef</span></div>
          </div>
        </div>
        <div class="rh-actions">
          <a href="https://photos.app.goo.gl/JGgx37aAA1vhip3z9" target="_blank" rel="noopener" class="btn btn-ember">View Food Gallery</a>
          <a href="#experience" class="btn btn-ghost">Jump to Experience</a>
        </div>
      </div>
    </section>

    <!-- ===== SKILLS ===== -->
    <section class="section section-ember-tint" id="skills">
      <h2 class="section-heading reveal">Skills &amp; Competencies</h2>

      <div class="skills-table reveal">

        <div class="skills-row">
          <div class="skills-cat">Technique</div>
          <div class="skills-chips">
            <span class="sk">Knife Skills</span>
            <span class="sk">Saut&eacute;ing</span>
            <span class="sk">Flat-top Griddle</span>
            <span class="sk">Deep Frying</span>
            <span class="sk">Combi Ovens</span>
            <span class="sk">Scratch Baking</span>
            <span class="sk">Stocks &amp; Sauces</span>
            <span class="sk">Butchery / Fabrication</span>
          </div>
        </div>

        <div class="skills-row">
          <div class="skills-cat">Service Types</div>
          <div class="skills-chips">
            <span class="sk">Breakfast / Brunch</span>
            <span class="sk">Fine Dining</span>
            <span class="sk">Banquet &amp; Catering</span>
            <span class="sk">Food Truck Ops</span>
            <span class="sk">High-Volume Line</span>
            <span class="sk">Assisted Living Dining</span>
          </div>
        </div>

        <div class="skills-row">
          <div class="skills-cat">Leadership &amp; Ops</div>
          <div class="skills-chips">
            <span class="sk">Shift Supervision</span>
            <span class="sk">Staff Coordination</span>
            <span class="sk">Dietary Management</span>
            <span class="sk">Inventory Control</span>
            <span class="sk">Menu Development</span>
            <span class="sk">Recipe Costing</span>
            <span class="sk">FOH / BOH Liaison</span>
          </div>
        </div>

        <div class="skills-row">
          <div class="skills-cat">Certifications</div>
          <div class="skills-chips">
            <span class="sk sk-cert">
              <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M20 6 9 17l-5-5"/></svg>
              Food Handler Certified
            </span>
            <span class="sk sk-cert">
              <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M20 6 9 17l-5-5"/></svg>
              Valid Driver&rsquo;s License
            </span>
          </div>
        </div>

      </div>
    </section>

    <div class="divider-fusion"></div>

    <!-- ===== EXPERIENCE ===== -->
    <section class="section" id="experience">
      <h2 class="section-heading reveal">Experience</h2>

      <!-- CURRENT -->
      <div class="exp-group reveal">
        <div class="exp-group-label exp-current">Currently Active</div>
        <div class="exp-cards">

          <div class="exp-card card">
            <div class="exp-card-top">
              <div class="exp-left">
                <div class="exp-role">Cook</div>
                <div class="exp-employer">Ross Manor (Sylvia Ross)</div>
                <div class="exp-loc">
                  <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M20 10c0 6-8 12-8 12S4 16 4 10a8 8 0 0 1 16 0Z"/><circle cx="12" cy="10" r="3"/></svg>
                  Bangor, ME
                </div>
              </div>
              <div class="exp-right">
                <span class="badge badge-ember">Active</span>
                <span class="exp-dates">2024&ndash;Present</span>
              </div>
            </div>
            <p class="exp-desc">Scratch-made meals for assisted living residents with specialized and restricted dietary requirements. Manages dietary accommodations and daily meal service under structured shift schedule.</p>
            <div class="exp-tags">
              <span class="etag">Scratch Cooking</span>
              <span class="etag">Dietary Management</span>
              <span class="etag">Shift Structure</span>
            </div>
          </div>

          <div class="exp-card card">
            <div class="exp-card-top">
              <div class="exp-left">
                <div class="exp-role">Co-Founder</div>
                <div class="exp-employer">Northern Fixin&rsquo;s / Half Baked Co.</div>
                <div class="exp-loc">
                  <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M20 10c0 6-8 12-8 12S4 16 4 10a8 8 0 0 1 16 0Z"/><circle cx="12" cy="10" r="3"/></svg>
                  Bangor, ME
                </div>
              </div>
              <div class="exp-right">
                <span class="badge badge-ember">Active</span>
                <span class="exp-dates">2023&ndash;Present</span>
              </div>
            </div>
            <p class="exp-desc">Co-founded Maine-inspired elevated caf&eacute; and scratch bakehouse concept. Half Baked Caf&eacute; &amp; Bakehouse targeting brick-and-mortar launch 2027. Alley Katz food truck concept in parallel development. Responsible for menu development, brand identity, and kitchen operations planning.</p>
            <div class="exp-tags">
              <span class="etag">Co-Founder</span>
              <span class="etag">Menu Development</span>
              <span class="etag">Food Truck Ops</span>
              <span class="etag">Bakehouse</span>
              <span class="etag">Brand Identity</span>
            </div>
          </div>

        </div>
      </div>

      <!-- 2024-2025 -->
      <div class="exp-group reveal">
        <div class="exp-group-label exp-recent">2024&ndash;2025</div>
        <div class="exp-cards">

          <div class="exp-card card">
            <div class="exp-card-top">
              <div class="exp-left">
                <div class="exp-role">Shift Lead</div>
                <div class="exp-employer">Seasons Bar and Grille</div>
                <div class="exp-loc">
                  <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M20 10c0 6-8 12-8 12S4 16 4 10a8 8 0 0 1 16 0Z"/><circle cx="12" cy="10" r="3"/></svg>
                  Bangor, ME
                </div>
              </div>
              <span class="exp-dates">Feb 2025</span>
            </div>
            <p class="exp-desc">Kitchen and FOH shift leadership. Staff coordination, service flow management, and guest experience oversight across both front and back of house.</p>
            <div class="exp-tags">
              <span class="etag">Shift Leadership</span>
              <span class="etag">FOH / BOH</span>
              <span class="etag">Staff Coordination</span>
            </div>
          </div>

          <div class="exp-card card">
            <div class="exp-card-top">
              <div class="exp-left">
                <div class="exp-role">Line Cook</div>
                <div class="exp-employer">Mason&rsquo;s Brewing Company</div>
                <div class="exp-loc">
                  <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M20 10c0 6-8 12-8 12S4 16 4 10a8 8 0 0 1 16 0Z"/><circle cx="12" cy="10" r="3"/></svg>
                  Bangor, ME
                </div>
              </div>
              <span class="exp-dates">Aug 2024</span>
            </div>
            <p class="exp-desc">High-volume scratch cooking in a craft brewery kitchen. Full line execution across all stations in a fast-paced service environment.</p>
            <div class="exp-tags">
              <span class="etag">High Volume</span>
              <span class="etag">Line Cook</span>
              <span class="etag">Scratch Cooking</span>
            </div>
          </div>

        </div>
      </div>

      <!-- DEFINING ROLES -->
      <div class="exp-group reveal">
        <div class="exp-group-label exp-defining">Defining Roles</div>
        <div class="exp-cards">

          <div class="exp-card card exp-card-key">
            <div class="exp-card-top">
              <div class="exp-left">
                <div class="exp-role">Line Cook / Sous Chef</div>
                <div class="exp-employer">Daddy B&rsquo;s Food Truck</div>
              </div>
              <span class="exp-dates">2022</span>
            </div>
            <p class="exp-desc">Mobile kitchen operations &mdash; menu execution, prep, and sous chef duties. Full responsibility for station output and daily prep lists on a working food truck.</p>
            <div class="exp-tags">
              <span class="etag">Sous Chef</span>
              <span class="etag">Food Truck</span>
              <span class="etag">Menu Execution</span>
            </div>
          </div>

          <div class="exp-card card exp-card-key">
            <div class="exp-card-top">
              <div class="exp-left">
                <div class="exp-role">Sous Chef</div>
                <div class="exp-employer">Ports of Italy</div>
              </div>
              <span class="exp-dates">2020</span>
            </div>
            <p class="exp-desc">Italian fine dining. Station leadership, full menu prep, and kitchen coordination. Elevated technique and kitchen management discipline under fine dining standards.</p>
            <div class="exp-tags">
              <span class="etag">Fine Dining</span>
              <span class="etag">Sous Chef</span>
              <span class="etag">Italian Cuisine</span>
              <span class="etag">Station Lead</span>
            </div>
          </div>

          <div class="exp-card card exp-card-key">
            <div class="exp-card-top">
              <div class="exp-left">
                <div class="exp-role">Breakfast Cook</div>
                <div class="exp-employer">Boynton McKay Food Co.</div>
                <div class="exp-loc">
                  <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M20 10c0 6-8 12-8 12S4 16 4 10a8 8 0 0 1 16 0Z"/><circle cx="12" cy="10" r="3"/></svg>
                  Camden, ME
                </div>
              </div>
              <span class="exp-dates">2019</span>
            </div>
            <p class="exp-desc">Iconic Maine caf&eacute; with high tourist-season volume. Full scratch breakfast service &mdash; consistency, speed, and quality under peak-season pressure.</p>
            <div class="exp-tags">
              <span class="etag">Scratch Breakfast</span>
              <span class="etag">High Volume</span>
              <span class="etag">Maine Caf&eacute;</span>
            </div>
          </div>

          <div class="exp-card card exp-card-key">
            <div class="exp-card-top">
              <div class="exp-left">
                <div class="exp-role">Grill Cook / Line Cook</div>
                <div class="exp-employer">Samoset Resort</div>
                <div class="exp-loc">
                  <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M20 10c0 6-8 12-8 12S4 16 4 10a8 8 0 0 1 16 0Z"/><circle cx="12" cy="10" r="3"/></svg>
                  Rockport, ME
                </div>
              </div>
              <span class="exp-dates">2014</span>
            </div>
            <p class="exp-desc">Premier Maine coastal resort. First major culinary role &mdash; banquet, hospitality service at scale, and the foundation of professional kitchen discipline.</p>
            <div class="exp-tags">
              <span class="etag">First Major Role</span>
              <span class="etag">Banquet</span>
              <span class="etag">Coastal Resort</span>
            </div>
          </div>

        </div>
      </div>

    </section>

    <div class="divider"></div>

    <!-- ===== FOOD GALLERY CTA ===== -->
    <section class="section reveal">
      <div class="gallery-strip">
        <div class="gallery-strip-text">
          <div class="gallery-strip-title">Food Photography</div>
          <p class="gallery-strip-sub">Dishes and kitchen work from real service &mdash; no staged shots.</p>
        </div>
        <a href="https://photos.app.goo.gl/JGgx37aAA1vhip3z9" target="_blank" rel="noopener" class="btn btn-ember">Open Gallery &rarr;</a>
      </div>
    </section>

  </main>
</BaseLayout>

<style>
/* ===== Resume Header ===== */
.resume-header {
  border-bottom: 1px solid var(--border-subtle);
  padding: 3.5rem 1.5rem 2.5rem;
}
.resume-header-inner {
  max-width: 920px;
  margin: 0 auto;
  display: flex;
  flex-direction: column;
  gap: 1.5rem;
}
.rh-top {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  gap: 2rem;
  flex-wrap: wrap;
}
.rh-name {
  font-size: clamp(1.6rem, 4vw, 2.4rem);
  font-weight: 900;
  letter-spacing: -0.03em;
  color: var(--text-primary);
  margin: 0 0 0.2rem;
}
.rh-title {
  font-size: 0.95rem;
  font-weight: 600;
  color: var(--accent-ember);
  margin: 0 0 0.6rem;
}
.rh-meta {
  display: flex;
  align-items: center;
  gap: 0.5rem;
  flex-wrap: wrap;
  font-size: 0.82rem;
  color: var(--text-muted);
}
.rh-meta-item {
  display: inline-flex;
  align-items: center;
  gap: 0.25rem;
}
.rh-meta-sep { color: var(--border-subtle); }
.rh-meta-link {
  color: var(--accent-ember);
  text-decoration: none;
  font-weight: 500;
}
.rh-meta-link:hover { text-decoration: underline; }

.rh-stats {
  display: flex;
  gap: 1rem;
  align-items: center;
  background: var(--bg-surface);
  border: 1px solid var(--border-subtle);
  border-radius: var(--radius-lg);
  padding: 1rem 1.25rem;
  flex-shrink: 0;
}
.rh-stat { display: flex; flex-direction: column; align-items: center; gap: 1px; }
.rh-stat-num { font-size: 1.5rem; font-weight: 800; color: var(--text-primary); line-height: 1; }
.rh-stat-num.ember { color: var(--accent-ember); }
.rh-stat-label { font-size: 0.6rem; text-transform: uppercase; letter-spacing: 0.08em; color: var(--text-muted); }
.rh-stat-div { width: 1px; height: 32px; background: var(--border-subtle); }

.rh-actions { display: flex; gap: 0.75rem; flex-wrap: wrap; }

/* ===== Skills Table ===== */
.section-ember-tint {
  background: linear-gradient(180deg, rgba(249,115,22,0.04) 0%, transparent 100%);
  border-top: 1px solid rgba(249,115,22,0.10);
}
.skills-table {
  display: flex;
  flex-direction: column;
  gap: 0;
  border: 1px solid var(--border-subtle);
  border-radius: var(--radius-lg);
  overflow: hidden;
  max-width: 860px;
}
.skills-row {
  display: grid;
  grid-template-columns: 160px 1fr;
  gap: 1rem;
  padding: 0.9rem 1.25rem;
  border-bottom: 1px solid var(--border-subtle);
  align-items: start;
}
.skills-row:last-child { border-bottom: none; }
.skills-row:nth-child(odd) { background: var(--bg-surface); }
.skills-row:nth-child(even) { background: var(--bg-elevated); }
.skills-cat {
  font-size: 0.72rem;
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: 0.1em;
  color: var(--text-muted);
  padding-top: 3px;
}
.skills-chips { display: flex; flex-wrap: wrap; gap: 0.35rem; }
.sk {
  font-size: 0.78rem;
  font-weight: 600;
  padding: 3px 11px;
  border-radius: var(--radius-full);
  background: var(--bg-card);
  color: var(--text-secondary);
  border: 1px solid var(--border-subtle);
  display: inline-flex;
  align-items: center;
  gap: 0.3rem;
  transition: border-color 0.18s, color 0.18s;
}
.sk:hover { border-color: var(--accent-ember); color: var(--accent-ember); }
.sk-cert {
  border-color: #bbf7d0;
  background: #f0fdf4;
  color: #16a34a;
}
.sk-cert:hover { border-color: #16a34a; color: #16a34a; }
.sk-cert svg { stroke: #16a34a; }

/* ===== Experience ===== */
.exp-group { margin-bottom: 2.5rem; }
.exp-group-label {
  font-size: 0.7rem;
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: 0.1em;
  padding: 0.28rem 0.75rem;
  border-radius: var(--radius-full);
  display: inline-flex;
  align-items: center;
  gap: 0.3rem;
  margin-bottom: 1rem;
}
.exp-current  { background: #fef2f2; color: #dc2626; border: 1px solid #fecaca; }
.exp-recent   { background: #fffbeb; color: #d97706; border: 1px solid #fde68a; }
.exp-defining { background: #fefce8; color: #a16207; border: 1px solid #fef08a; }

.exp-cards { display: grid; grid-template-columns: repeat(auto-fill, minmax(300px, 1fr)); gap: 1rem; }
.exp-card {
  padding: 1.4rem;
  display: flex;
  flex-direction: column;
  gap: 0.75rem;
}
.exp-card-key { border-left: 3px solid var(--accent-ember); }
.exp-card-top {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  gap: 0.5rem;
}
.exp-left { display: flex; flex-direction: column; gap: 2px; }
.exp-role     { font-size: 1rem; font-weight: 700; color: var(--text-primary); }
.exp-employer { font-size: 0.88rem; font-weight: 600; color: var(--accent-ember); }
.exp-loc {
  display: inline-flex;
  align-items: center;
  gap: 0.2rem;
  font-size: 0.75rem;
  color: var(--text-muted);
  margin-top: 1px;
}
.exp-loc svg { flex-shrink: 0; }
.exp-right { display: flex; flex-direction: column; align-items: flex-end; gap: 3px; }
.exp-dates { font-size: 0.75rem; color: var(--text-muted); font-weight: 500; white-space: nowrap; }
.exp-desc { font-size: 0.85rem; color: var(--text-secondary); line-height: 1.65; margin: 0; }

.exp-tags { display: flex; flex-wrap: wrap; gap: 0.3rem; }
.etag {
  font-size: 0.67rem;
  font-weight: 600;
  padding: 0.18rem 0.5rem;
  border-radius: var(--radius-full);
  background: var(--bg-elevated);
  color: var(--text-muted);
  border: 1px solid var(--border-subtle);
  text-transform: uppercase;
  letter-spacing: 0.04em;
}

/* ===== Gallery Strip ===== */
.gallery-strip {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 1.5rem;
  flex-wrap: wrap;
  padding: 1.5rem 2rem;
  background: linear-gradient(135deg, rgba(249,115,22,0.06) 0%, var(--bg-elevated) 70%);
  border: 1px solid rgba(249,115,22,0.15);
  border-left: 3px solid var(--accent-ember);
  border-radius: var(--radius-lg);
  max-width: 860px;
}
.gallery-strip-title {
  font-size: 1rem;
  font-weight: 700;
  color: var(--text-primary);
  margin-bottom: 0.2rem;
}
.gallery-strip-sub {
  font-size: 0.85rem;
  color: var(--text-muted);
  margin: 0;
}

/* ===== Responsive ===== */
@media (max-width: 640px) {
  .resume-header { padding: 2.5rem 1rem 1.75rem; }
  .rh-stats { width: 100%; justify-content: center; }
  .skills-row { grid-template-columns: 1fr; gap: 0.5rem; }
  .exp-cards { grid-template-columns: 1fr; }
  .gallery-strip { flex-direction: column; align-items: flex-start; }
}
</style>
