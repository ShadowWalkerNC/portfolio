---
const links = [
  { label: 'Home',     href: '/' },
  { label: 'Projects', href: '/projects' },
  { label: 'Contact',  href: '/contact' },
];
---

<header class="fixed top-0 inset-x-0 z-50 bg-brand-dark/80 backdrop-blur-md border-b border-brand-border">
  <nav class="max-w-6xl mx-auto px-6 h-16 flex items-center justify-between">
    <a href="/" class="font-mono text-brand-purple font-semibold text-lg tracking-tight hover:opacity-80 transition">
      ShadowWalkerNC
    </a>
    <ul class="flex gap-6">
      {links.map(l => (
        <li>
          <a href={l.href} class="text-sm text-gray-300 hover:text-white transition">{l.label}</a>
        </li>
      ))}
    </ul>
  </nav>
</header>
