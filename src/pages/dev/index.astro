---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Hero from '../../components/Hero.astro';
import ProjectCard from '../../components/ProjectCard.astro';
import { getCollection } from 'astro:content';

const projects = await getCollection('projects');
const featured = projects.filter(p => p.data.featured).slice(0, 3);
---

<BaseLayout title="Nate Cowperthwaite — Developer" description="Agentic coding, AI tools, and API-driven software built by a professional chef who started coding in 2025." side="dev">
  <main id="main-content">

    <!-- ===== HERO ===== -->
    <Hero />

    <div class="divider-fusion"></div>

    <!-- ===== JOURNEY TIMELINE ===== -->
    <section class="section">
      <h2 class="section-heading reveal">The Journey</h2>
      <p class="section-sub reveal">A decade in professional kitchens &mdash; and one side project that grew from all of it.</p>
      <div class="timeline">

        <div class="timeline-item reveal-left">
          <div class="timeline-dot dot-blue"></div>
          <div class="timeline-content">
            <div class="timeline-era">2014 &mdash; First Kitchen Role</div>
            <h3 class="timeline-title">Samoset Resort, Rockport ME</h3>
            <p class="timeline-text">Premier Maine coastal resort. First major culinary role — banquet, hospitality, and the discipline of a real kitchen. Where the foundation was laid.</p>
          </div>
        </div>

        <div class="timeline-item reveal-left">
          <div class="timeline-dot dot-ember"></div>
          <div class="timeline-content">
            <div class="timeline-era era-ember">2019&ndash;2022 &mdash; Rising Through the Ranks</div>
            <h3 class="timeline-title">Boynton McKay &rarr; Ports of Italy &rarr; Daddy B&rsquo;s</h3>
            <p class="timeline-text">Scratch breakfast at an iconic Maine café, sous chef at Italian fine dining, then sous chef on a food truck &mdash; the role that directly sparked Northern Fixin's. Each step added technique, leadership, and clarity about what kitchens were missing.</p>
          </div>
        </div>

        <div class="timeline-item reveal-left">
          <div class="timeline-dot dot-ember"></div>
          <div class="timeline-content">
            <div class="timeline-era era-ember">2023&ndash;Present &mdash; Co-Founder</div>
            <h3 class="timeline-title">Northern Fixin&rsquo;s / Half Baked Co.</h3>
            <p class="timeline-text">Co-founded a Maine-inspired elevated café, scratch bakehouse, and food truck concept. Brick-and-mortar café targeting 2027. Still actively cooking and running kitchen operations at Ross Manor.</p>
          </div>
        </div>

        <div class="timeline-item reveal-left timeline-branch">
          <div class="timeline-dot dot-blue dot-branch"></div>
          <div class="timeline-content">
            <div class="timeline-era">2025&ndash;Present &mdash; Side Project</div>
            <h3 class="timeline-title">Developer <span class="timeline-branch-tag">Branch</span></h3>
            <p class="timeline-text">Started coding in 2025 using agentic workflows, AI tools, and APIs. Built CulinaryOS, KitchenKit, CulinaryOps, and more &mdash; every project rooted in real kitchen problems. Still cooking full-time; this is a side project that got serious.</p>
          </div>
        </div>

      </div>
    </section>

    <div class="divider"></div>

    <!-- ===== DEV KIT ===== -->
    <section class="section" id="devkit">
      <h2 class="section-heading reveal">The Dev Kit</h2>
      <p class="section-sub reveal">Tools I use to ship production software.</p>

      <div class="devkit-grid">

        <!-- Languages -->
        <div class="kit-card">
          <div class="kit-card-header">
            <span class="kit-icon kit-icon-blue">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="16 18 22 12 16 6"/><polyline points="8 6 2 12 8 18"/></svg>
            </span>
            <span class="kit-label">Languages</span>
          </div>
          <div class="lang-banners">
            <div class="lang-banner lang-js kit-chip" style="--i:0">
              <span class="lang-logo" aria-hidden="true">
                <svg width="18" height="18" viewBox="0 0 32 32" fill="none" xmlns="http://www.w3.org/2000/svg">
                  <rect width="32" height="32" rx="4" fill="#F7DF1E"/>
                  <path d="M9.5 24.5l2.3-1.4c.44.78.84 1.44 1.8 1.44.92 0 1.5-.36 1.5-1.76V14h2.82v8.88c0 2.9-1.7 4.22-4.18 4.22-2.24 0-3.54-1.16-4.24-2.6zM19 24.2l2.3-1.34c.6 1 1.38 1.74 2.76 1.74 1.16 0 1.9-.58 1.9-1.38 0-.96-.76-1.3-2.04-1.86l-.7-.3c-2.02-.86-3.36-1.94-3.36-4.22 0-2.1 1.6-3.7 4.1-3.7 1.78 0 3.06.62 3.98 2.24l-2.18 1.4c-.48-.86-1-1.2-1.8-1.2-.82 0-1.34.52-1.34 1.2 0 .84.52 1.18 1.72 1.7l.7.3c2.38 1.02 3.72 2.06 3.72 4.4 0 2.52-1.98 3.9-4.64 3.9-2.6 0-4.28-1.24-5.12-2.88z" fill="#000"/>
                </svg>
              </span>
              <span class="lang-name">JavaScript</span>
            </div>
            <div class="lang-banner lang-py kit-chip" style="--i:1">
              <span class="lang-logo" aria-hidden="true">
                <svg width="18" height="18" viewBox="0 0 32 32" xmlns="http://www.w3.org/2000/svg">
                  <defs>
                    <linearGradient id="pyBlue" x1="0" y1="0" x2="1" y2="1"><stop offset="0%" stop-color="#5A9FD4"/><stop offset="100%" stop-color="#306998"/></linearGradient>
                    <linearGradient id="pyYellow" x1="0" y1="0" x2="1" y2="1"><stop offset="0%" stop-color="#FFD43B"/><stop offset="100%" stop-color="#FFE873"/></linearGradient>
                  </defs>
                  <path d="M15.9 2C11.2 2 11.5 4 11.5 4v4.1h4.6v1.2H8.3S5 8.9 5 13.7s2.8 4.6 2.8 4.6h1.7v-2.2s-.1-2.8 2.7-2.8h4.7s2.6.04 2.6-2.5V4.6S19.9 2 15.9 2zm-2.6 1.5c.47 0 .85.38.85.85s-.38.85-.85.85-.85-.38-.85-.85.38-.85.85-.85z" fill="url(#pyBlue)"/>
                  <path d="M16.1 30c4.7 0 4.4-2 4.4-2v-4.1h-4.6v-1.2h7.8S27 23.1 27 18.3s-2.8-4.6-2.8-4.6h-1.7v2.2s.1 2.8-2.7 2.8h-4.7S13.5 18.6 13.5 21v4.4S13.1 30 16.1 30zm2.6-1.5c-.47 0-.85-.38-.85-.85s.38-.85.85-.85.85.38.85.85-.38.85-.85.85z" fill="url(#pyYellow)"/>
                </svg>
              </span>
              <span class="lang-name">Python</span>
            </div>
            <div class="lang-banner lang-ts kit-chip" style="--i:2">
              <span class="lang-logo" aria-hidden="true">
                <svg width="18" height="18" viewBox="0 0 32 32" fill="none" xmlns="http://www.w3.org/2000/svg">
                  <rect width="32" height="32" rx="4" fill="#3178C6"/>
                  <path d="M18 13.5h-4V12h10v1.5h-4V24h-2V13.5zM24 20.6c.5.9 1.2 1.6 2.2 1.6.9 0 1.5-.45 1.5-1.07 0-.74-.6-1-1.66-1.44l-.57-.24C23.8 18.9 23 18.1 23 16.7c0-1.56 1.19-2.7 2.88-2.7 1.25 0 2.15.44 2.8 1.58l-1.54.99c-.34-.6-.7-.84-1.26-.84-.57 0-.94.36-.94.84 0 .59.37.83 1.22 1.2l.57.24C28.6 18.6 29.5 19.36 29.5 20.9c0 1.76-1.38 2.85-3.24 2.85-1.82 0-3-1-3.58-2.18L24 20.6z" fill="#fff"/>
                </svg>
              </span>
              <span class="lang-name">TypeScript</span>
            </div>
            <div class="lang-banner lang-html kit-chip" style="--i:3">
              <span class="lang-logo" aria-hidden="true">
                <svg width="18" height="18" viewBox="0 0 32 32" fill="none" xmlns="http://www.w3.org/2000/svg">
                  <rect width="32" height="32" rx="4" fill="#E44D26"/>
                  <path d="M6 4l2.2 24.6L16 31l7.8-2.4L26 4H6zm14.9 6.9H12l.2 2.4h8.5l-.6 6.7-4.1 1.1-4.1-1.1-.3-3.1h2.3l.15 1.7 2 .54 2-.54.2-2.6H11.3l-.6-6.4h10.4l-.2 1.7z" fill="#fff"/>
                </svg>
              </span>
              <span class="lang-name">HTML / CSS</span>
            </div>
            <div class="lang-banner lang-sql kit-chip" style="--i:4">
              <span class="lang-logo" aria-hidden="true">
                <svg width="18" height="18" viewBox="0 0 32 32" fill="none" xmlns="http://www.w3.org/2000/svg">
                  <rect width="32" height="32" rx="4" fill="#336791"/>
                  <ellipse cx="16" cy="9" rx="8" ry="3.5" fill="#fff" fill-opacity=".9"/>
                  <path d="M8 9v4.5c0 1.93 3.58 3.5 8 3.5s8-1.57 8-3.5V9" stroke="#fff" stroke-opacity=".9" stroke-width="1.5"/>
                  <path d="M8 13.5V18c0 1.93 3.58 3.5 8 3.5s8-1.57 8-3.5v-4.5" stroke="#fff" stroke-opacity=".9" stroke-width="1.5"/>
                  <path d="M8 18v4.5C8 24.43 11.58 26 16 26s8-1.57 8-3.5V18" stroke="#fff" stroke-opacity=".9" stroke-width="1.5"/>
                </svg>
              </span>
              <span class="lang-name">SQL</span>
            </div>
          </div>
        </div>

        <!-- Frameworks -->
        <div class="kit-card">
          <div class="kit-card-header">
            <span class="kit-icon kit-icon-blue">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="2" y="3" width="20" height="14" rx="2"/><line x1="8" y1="21" x2="16" y2="21"/><line x1="12" y1="17" x2="12" y2="21"/></svg>
            </span>
            <span class="kit-label">Frameworks</span>
          </div>
          <div class="lang-banners">
            <div class="lang-banner lang-neutral kit-chip" style="--i:0"><span class="lang-logo" aria-hidden="true"><i class="devicon-astro-plain colored" style="font-size:20px"></i></span><span class="lang-name">Astro</span></div>
            <div class="lang-banner lang-neutral kit-chip" style="--i:1"><span class="lang-logo" aria-hidden="true"><i class="devicon-flask-original colored" style="font-size:20px"></i></span><span class="lang-name">Flask</span></div>
            <div class="lang-banner lang-neutral kit-chip" style="--i:2"><span class="lang-logo" aria-hidden="true"><i class="devicon-nodejs-plain colored" style="font-size:20px"></i></span><span class="lang-name">Node.js</span></div>
            <div class="lang-banner lang-neutral kit-chip" style="--i:3"><span class="lang-logo" aria-hidden="true"><i class="devicon-discordjs-plain colored" style="font-size:20px"></i></span><span class="lang-name">Discord.js</span></div>
            <div class="lang-banner lang-neutral kit-chip" style="--i:4"><span class="lang-logo" aria-hidden="true"><i class="devicon-tailwindcss-plain colored" style="font-size:20px"></i></span><span class="lang-name">Tailwind CSS</span></div>
            <div class="lang-banner lang-neutral kit-chip" style="--i:5"><span class="lang-logo" aria-hidden="true"><i class="devicon-react-original colored" style="font-size:20px"></i></span><span class="lang-name">React</span></div>
            <div class="lang-banner lang-neutral kit-chip" style="--i:6"><span class="lang-logo" aria-hidden="true"><i class="devicon-vitejs-plain colored" style="font-size:20px"></i></span><span class="lang-name">Vite</span></div>
            <div class="lang-banner lang-neutral kit-chip" style="--i:7"><span class="lang-logo" aria-hidden="true"><i class="devicon-hono-plain colored" style="font-size:20px"></i></span><span class="lang-name">Hono</span></div>
          </div>
        </div>

        <!-- Data & Infra -->
        <div class="kit-card">
          <div class="kit-card-header">
            <span class="kit-icon kit-icon-blue">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><ellipse cx="12" cy="5" rx="9" ry="3"/><path d="M3 5v14c0 1.66 4.03 3 9 3s9-1.34 9-3V5"/><path d="M3 12c0 1.66 4.03 3 9 3s9-1.34 9-3"/></svg>
            </span>
            <span class="kit-label">Data &amp; Infra</span>
          </div>
          <div class="lang-banners">
            <div class="lang-banner lang-neutral kit-chip" style="--i:0"><span class="lang-logo" aria-hidden="true"><i class="devicon-postgresql-plain colored" style="font-size:20px"></i></span><span class="lang-name">PostgreSQL</span></div>
            <div class="lang-banner lang-neutral kit-chip" style="--i:1"><span class="lang-logo" aria-hidden="true"><i class="devicon-sqlite-plain colored" style="font-size:20px"></i></span><span class="lang-name">SQLite</span></div>
            <div class="lang-banner lang-neutral kit-chip" style="--i:2"><span class="lang-logo" aria-hidden="true"><i class="devicon-supabase-plain colored" style="font-size:20px"></i></span><span class="lang-name">Supabase</span></div>
            <div class="lang-banner lang-neutral kit-chip" style="--i:3"><span class="lang-logo" aria-hidden="true"><i class="devicon-railway-plain colored" style="font-size:20px"></i></span><span class="lang-name">Railway</span></div>
            <div class="lang-banner lang-neutral kit-chip" style="--i:4"><span class="lang-logo" aria-hidden="true"><i class="devicon-render-plain colored" style="font-size:20px"></i></span><span class="lang-name">Render</span></div>
            <div class="lang-banner lang-neutral kit-chip" style="--i:5"><span class="lang-logo" aria-hidden="true"><i class="devicon-docker-plain colored" style="font-size:20px"></i></span><span class="lang-name">Docker</span></div>
          </div>
        </div>

        <!-- AI & APIs -->
        <div class="kit-card">
          <div class="kit-card-header">
            <span class="kit-icon kit-icon-blue">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 2a4 4 0 0 1 4 4v1h1a3 3 0 0 1 0 6h-1v1a4 4 0 0 1-8 0v-1H7a3 3 0 0 1 0-6h1V6a4 4 0 0 1 4-4Z"/><circle cx="12" cy="10" r="2"/></svg>
            </span>
            <span class="kit-label">AI &amp; APIs</span>
          </div>
          <div class="lang-banners">
            <div class="lang-banner lang-neutral kit-chip" style="--i:0"><span class="lang-logo" aria-hidden="true"><i class="devicon-google-plain colored" style="font-size:20px"></i></span><span class="lang-name">Google Gemini</span></div>
            <div class="lang-banner lang-neutral kit-chip" style="--i:1"><span class="lang-logo" aria-hidden="true"><i class="devicon-discordjs-plain colored" style="font-size:20px"></i></span><span class="lang-name">Discord API</span></div>
            <div class="lang-banner lang-neutral kit-chip" style="--i:2"><span class="lang-logo" aria-hidden="true"><i class="devicon-facebook-plain colored" style="font-size:20px"></i></span><span class="lang-name">Meta Graph API</span></div>
            <div class="lang-banner lang-neutral kit-chip" style="--i:3"><span class="lang-logo" aria-hidden="true"><i class="devicon-twitter-original colored" style="font-size:20px"></i></span><span class="lang-name">Twitter API v2</span></div>
            <div class="lang-banner lang-neutral kit-chip" style="--i:4">
              <span class="lang-logo" aria-hidden="true">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2a4 4 0 0 1 4 4v1h1a3 3 0 0 1 0 6h-1v1a4 4 0 0 1-8 0v-1H7a3 3 0 0 1 0-6h1V6a4 4 0 0 1 4-4Z"/><circle cx="12" cy="10" r="2"/></svg>
              </span>
              <span class="lang-name">MCP</span>
            </div>
          </div>
        </div>

      </div>
    </section>

    <div class="divider"></div>

    <!-- ===== FEATURED PROJECTS ===== -->
    <section class="section">
      <h2 class="section-heading reveal">Featured Work</h2>
      <p class="section-sub reveal">A handful of projects that show the range. <a href="/dev/projects" class="inline-link">See everything &rarr;</a></p>
      <div class="featured-grid">
        {featured.map(p => (
          <ProjectCard
            id={p.id}
            title={p.data.title}
            tagline={p.data.tagline}
            description={p.data.description}
            story={p.data.story}
            forWho={p.data.forWho}
            tags={p.data.tags}
            stack={p.data.stack}
            status={p.data.status}
            links={p.data.links}
            detailedSpecs={p.data.detailedSpecs}
          />
        ))}
      </div>
    </section>

  </main>
</BaseLayout>

<script>
  (() => {
    const chips = document.querySelectorAll<HTMLElement>('.kit-chip');
    if (!chips.length) return;
    const show = (el: HTMLElement) => {
      const i = parseFloat(el.style.getPropertyValue('--i') || '0');
      setTimeout(() => el.classList.add('chip-visible'), i * 60);
    };
    const io = new IntersectionObserver(
      (entries) => entries.forEach(e => { if (e.isIntersecting) { show(e.target as HTMLElement); io.unobserve(e.target); } }),
      { threshold: 0, rootMargin: '0px 0px 40px 0px' }
    );
    chips.forEach(el => io.observe(el));
    setTimeout(() => chips.forEach(el => show(el)), 800);
  })();

  (() => {
    const cards = document.querySelectorAll<Element>('.featured-grid .card-entrance');
    if (!cards.length) return;
    const reveal = (card: Element, idx: number) => {
      if (card.classList.contains('card-visible')) return;
      (card as HTMLElement).style.animationDelay = (idx * 0.07) + 's';
      card.classList.add('card-visible');
    };
    const io = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (!entry.isIntersecting) return;
        const siblings = Array.from(entry.target.parentElement?.children ?? []);
        const idx = siblings.indexOf(entry.target);
        reveal(entry.target, idx);
        io.unobserve(entry.target);
      });
    }, { threshold: 0, rootMargin: '0px 0px 40px 0px' });
    cards.forEach(card => io.observe(card));
    setTimeout(() => cards.forEach((card, idx) => reveal(card, idx)), 800);
  })();
</script>

<style>
.timeline {
  padding-left: 1rem;
  border-left: 2px solid var(--border-subtle);
  display: flex;
  flex-direction: column;
}
.timeline-item { position: relative; padding: 0 0 2.5rem 1.5rem; }
.timeline-branch { margin-top: 0.5rem; }
.timeline-dot {
  position: absolute; left: -9px; top: 5px;
  width: 14px; height: 14px;
  border-radius: 50%;
  border: 2px solid var(--bg-base);
}
.dot-blue  { background: var(--accent-blue);  box-shadow: 0 0 0 3px var(--accent-blue-pale); }
.dot-ember { background: var(--accent-ember); box-shadow: 0 0 0 3px var(--accent-ember-pale); }
.dot-branch { border: 2px solid var(--accent-blue); background: white; }
@keyframes pulse-ring {
  0%   { box-shadow: 0 0 0 0 rgba(59,130,246,0.45); }
  70%  { box-shadow: 0 0 0 8px rgba(59,130,246,0); }
  100% { box-shadow: 0 0 0 0 rgba(59,130,246,0); }
}
.dot-branch.is-visible, .dot-branch.revealed,
.timeline-item.is-visible .dot-branch, .timeline-item.revealed .dot-branch {
  animation: pulse-ring 2s ease-out infinite;
}
.timeline-era {
  font-size: 0.72rem; font-weight: 700; text-transform: uppercase;
  letter-spacing: 0.1em; color: var(--accent-blue); margin-bottom: 0.3rem; opacity: 0.8;
}
.era-ember { color: var(--accent-ember) !important; }
.timeline-title { font-size: 1rem; font-weight: 700; color: var(--text-primary); margin: 0 0 0.4rem; word-break: break-word; }
.timeline-text { font-size: 0.88rem; color: var(--text-muted); line-height: 1.65; margin: 0; max-width: 560px; }
.timeline-branch-tag {
  font-size: 0.65rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.08em;
  background: var(--accent-blue-pale); color: var(--accent-blue);
  padding: 2px 8px; border-radius: var(--radius-full);
  vertical-align: middle; margin-left: 0.4rem;
}
.devkit-grid {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(240px, 1fr));
  gap: 1.25rem;
}
.kit-card {
  background: var(--bg-surface); border: 1px solid var(--border-subtle);
  border-radius: var(--radius-lg); padding: 1.25rem 1.25rem 1.4rem;
  display: flex; flex-direction: column; gap: 1rem;
  transition: border-color 0.2s, box-shadow 0.2s;
}
.kit-card:hover { border-color: var(--accent-blue); box-shadow: 0 0 0 3px var(--accent-blue-pale); }
.kit-card-header { display: flex; align-items: center; gap: 0.6rem; }
.kit-icon { display: inline-flex; align-items: center; justify-content: center; width: 30px; height: 30px; border-radius: var(--radius-md); flex-shrink: 0; }
.kit-icon-blue { background: var(--accent-blue-pale); color: var(--accent-blue); border: 1px solid color-mix(in srgb, var(--accent-blue) 20%, transparent); }
.kit-label { font-size: 0.7rem; font-weight: 800; text-transform: uppercase; letter-spacing: 0.12em; color: var(--text-muted); }
.kit-chip { opacity: 0; transform: translateY(6px) scale(0.97); transition: opacity 0.3s ease, transform 0.3s ease, border-color 0.2s, background 0.2s; }
.kit-chip.chip-visible { opacity: 1; transform: none; }
.lang-banners { display: flex; flex-direction: column; gap: 0.45rem; }
.lang-banner {
  display: flex; align-items: center; gap: 0.6rem;
  padding: 0.55rem 0.85rem; border-radius: var(--radius-md);
  border: 1px solid transparent;
  font-size: 0.85rem; font-weight: 700; letter-spacing: 0.01em;
  cursor: default; transition: background 0.2s, border-color 0.2s;
}
.lang-logo { display: flex; align-items: center; justify-content: center; flex-shrink: 0; width: 22px; height: 22px; line-height: 1; }
.lang-logo svg { display: block; }
.lang-name { line-height: 1; }
.lang-js  { background: rgba(247,223,30,0.10);  border-color: rgba(247,223,30,0.30);  color: #b8a800; }
.lang-py  { background: rgba(48,105,152,0.10);  border-color: rgba(48,105,152,0.30);  color: #1f5c8a; }
