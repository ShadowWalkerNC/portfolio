---
import '../styles/global.css';
const { title, description, side } = Astro.props;
// side: 'dev' | 'food' | undefined (neutral for landing)
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content={description ?? 'Nate Cowperthwaite — Chef & Developer'} />
  <title>{title ?? 'Nate Cowperthwaite'}</title>
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  {/* Only load devicon on the dev side — saves ~30KB on food/contact pages */}
  {side === 'dev' && (
    <link
      rel="stylesheet"
      href="https://cdn.jsdelivr.net/gh/devicons/devicon@latest/devicon.min.css"
      integrity="sha384-6iv3tXABd3c9DYulXujJl8n22ahn/12f45MomxoPv6jBX4LBE4gNJjfkx5mAKIqR"
      crossorigin="anonymous"
    />
  )}
</head>
<body data-side={side}>

  <!-- ===== SKIP LINK (WCAG 2.4.1) ===== -->
  <a href="#main-content" class="skip-link">Skip to content</a>

  <!-- ===== NAV ===== -->
  <nav>
    <a href="/" class="nav-logo">
      <span class="nav-logo-name">Nate Cowperthwaite</span>
    </a>

    <!-- Mobile hamburger -->
    <button class="nav-burger" id="navBurger" aria-label="Toggle menu" aria-expanded="false" aria-controls="navMenu">
      <span></span><span></span><span></span>
    </button>

    <div class="nav-links" id="navMenu">
      {side === 'dev' && (
        <>
          <a href="/dev">Home</a>
          <a href="/dev/projects">Projects</a>
          <a href="/contact">Contact</a>
          <a href="/food" class="nav-switch nav-switch-food"><span aria-hidden="true">🍽️</span> Chef Side</a>
        </>
      )}
      {side === 'food' && (
        <>
          <a href="/food">Home</a>
          <a href="/contact">Contact</a>
          <a href="/dev" class="nav-switch nav-switch-dev"><span aria-hidden="true">💻</span> Dev Side</a>
        </>
      )}
      {!side && (
        <>
          <a href="/dev" class="nav-switch nav-switch-dev"><span aria-hidden="true">💻</span> Developer</a>
          <a href="/food" class="nav-switch nav-switch-food"><span aria-hidden="true">🍽️</span> Chef</a>
        </>
      )}
    </div>
  </nav>

  <!-- ===== CONTENT (<main> landmark — WCAG 1.3.1 + 2.4.1) ===== -->
  <main id="main-content">
    <slot />
  </main>

  <!-- ===== FOOTER ===== -->
  <footer>
    <p>&copy; {new Date().getFullYear()} Nathaniel Cowperthwaite &mdash;
      <a href="/dev">Developer</a> &nbsp;&bull;&nbsp;
      <a href="/food">Chef</a> &nbsp;&bull;&nbsp;
      <a href="/contact">Contact</a> &nbsp;&bull;&nbsp;
      <a href="https://github.com/ShadowWalkerNC" target="_blank" rel="noopener noreferrer">GitHub</a>
    </p>
  </footer>

  <!-- ===== SCROLL REVEAL =====
    Inline IntersectionObserver removed (was a duplicate of animations.js).
    Pages needing scroll-reveal must import initScrollReveal() from
    src/utils/animations.js and call it in their own <script> block.
  ===== -->

  <!-- ===== HAMBURGER SCRIPT ===== -->
  <script>
    const burger  = document.getElementById('navBurger');
    const menu    = document.getElementById('navMenu');
    if (burger && menu) {
      burger.addEventListener('click', () => {
        const open = menu.classList.toggle('nav-open');
        burger.classList.toggle('is-active', open);
        burger.setAttribute('aria-expanded', String(open));
      });
      menu.querySelectorAll('a').forEach((a) => {
        a.addEventListener('click', () => {
          menu.classList.remove('nav-open');
          burger.classList.remove('is-active');
          burger.setAttribute('aria-expanded', 'false');
        });
      });
    }
  </script>

</body>
</html>

<style>
/* ---- Skip link (WCAG 2.4.1) ---- */
.skip-link {
  position: absolute;
  top: -100%;
  left: var(--space-4);
  z-index: 200;
  background: var(--accent-blue);
  color: #fff;
  padding: 0.5rem 1rem;
  border-radius: var(--radius-sm);
  font-size: 0.875rem;
  font-weight: 600;
  text-decoration: none;
  transition: top 0.15s ease;
}
.skip-link:focus {
  top: var(--space-2);
}

/* ---- Nav logo ---- */
.nav-logo {
  display: flex;
  align-items: center;
  gap: 0.5rem;
  text-decoration: none;
  flex-shrink: 0;
}
.nav-logo-name {
  font-size: 0.95rem;
  font-weight: 800;
  color: var(--text-primary);
  letter-spacing: -0.02em;
}

/* ---- Nav links (desktop) ---- */
.nav-links {
  display: flex;
  align-items: center;
  gap: 0.25rem;
}
.nav-switch {
  font-weight: 600;
  font-size: 0.82rem;
}
.nav-switch-dev {
  color: var(--accent-blue);
  background: var(--accent-blue-pale);
  border-radius: var(--radius-full);
  padding: 0.25rem 0.8rem;
}
.nav-switch-food {
  color: var(--accent-ember);
  background: var(--accent-ember-pale);
  border-radius: var(--radius-full);
  padding: 0.25rem 0.8rem;
}
.nav-switch-dev:hover  { background: var(--accent-blue);  color: white; }
.nav-switch-food:hover { background: var(--accent-ember); color: white; }

/* ---- Hamburger button ---- */
.nav-burger {
  display: none;
  flex-direction: column;
  justify-content: center;
  gap: 5px;
  width: 44px;
  height: 44px;
  background: none;
  border: none;
  cursor: pointer;
  padding: 10px;
  border-radius: var(--radius-sm);
  transition: background 0.15s;
}
.nav-burger:hover { background: var(--bg-elevated); }
.nav-burger span {
  display: block;
  height: 2px;
  width: 22px;
  background: var(--text-secondary);
  border-radius: 2px;
  transition: transform 0.25s ease, opacity 0.2s ease;
  transform-origin: center;
}
.nav-burger.is-active span:nth-child(1) { transform: translateY(7px) rotate(45deg); }
.nav-burger.is-active span:nth-child(2) { opacity: 0; transform: scaleX(0); }
.nav-burger.is-active span:nth-child(3) { transform: translateY(-7px) rotate(-45deg); }

/* ---- Mobile nav (token-driven bg — dark-mode safe) ---- */
@media (max-width: 640px) {
  .nav-logo-name { font-size: 0.88rem; }

  .nav-burger { display: flex; }

  .nav-links {
    display: none;
    position: absolute;
    top: 60px;
    left: 0;
    right: 0;
    background: var(--nav-bg);
    backdrop-filter: blur(20px);
    -webkit-backdrop-filter: blur(20px);
    border-bottom: 1px solid var(--nav-border);
    flex-direction: column;
    align-items: stretch;
    gap: 0;
    padding: 0.5rem 1rem 1rem;
    z-index: 99;
    box-shadow: 0 8px 24px rgba(15,23,42,0.10);
  }
  .nav-links.nav-open { display: flex; }
  .nav-links a {
    padding: 0.75rem;
    min-height: 44px;
    font-size: 0.95rem;
    border-radius: var(--radius-sm);
    text-align: left;
    display: flex;
    align-items: center;
  }
  .nav-switch-dev, .nav-switch-food {
    margin-top: 0.25rem;
    justify-content: center;
  }
}
</style>
