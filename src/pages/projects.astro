import BaseLayout from '../layouts/BaseLayout.astro';
import ProjectCard from '../components/ProjectCard.astro';
import ProjectGroup from '../components/ProjectGroup.astro';
import { getCollection } from 'astro:content';

const all = await getCollection('projects');

const ecosystemSlugs = ['culinaryos', 'kitchenkit', 'culinaryops'];
const ecosystem = all.filter(p => ecosystemSlugs.includes(p.id));

const standalone = all.filter(p => !ecosystemSlugs.includes(p.id));

const categories = [...new Set(standalone.map(p => p.data.category))];
---

<BaseLayout title="Projects — ShadowWalkerNC" description="Full project catalog: culinary tech, Discord bots, automation tools, and creative experiments.">
  <main class="projects-page">
    <header class="page-header">
      <h1 class="page-title">Projects</h1>
      <p class="page-subtitle">
        Built by someone who spent years cooking professionally before writing a line of production code.
        Every tool here solves a real problem — most of them mine.
      </p>
    </header>

    <!-- Culinary Ecosystem -->
    <section class="ecosystem-section">
      <div class="section-label">&#127860; Core Ecosystem</div>
      <ProjectGroup
        name="The Culinary Stack"
        description="Three interconnected tools built to run a modern food operation end-to-end. Each works standalone; together they form a complete operational system."
        icon="&#127860;"
      >
        {ecosystem.map(p => (
          <ProjectCard
            id={p.id}
            title={p.data.title}
            tagline={p.data.tagline}
            description={p.data.description}
            story={p.data.story}
            forWho={p.data.forWho}
            tags={p.data.tags}
            stack={p.data.stack}
            status={p.data.status}
            links={p.data.links}
            detailedSpecs={p.data.detailedSpecs}
          />
        ))}
      </ProjectGroup>
    </section>

    <!-- Standalone Projects by Category -->
    {categories.map(cat => (
      <section class="category-section">
        <h2 class="category-heading">{cat}</h2>
        <div class="category-grid">
          {standalone
            .filter(p => p.data.category === cat)
            .map(p => (
              <ProjectCard
                id={p.id}
                title={p.data.title}
                tagline={p.data.tagline}
                description={p.data.description}
                story={p.data.story}
                forWho={p.data.forWho}
                tags={p.data.tags}
                stack={p.data.stack}
                status={p.data.status}
                links={p.data.links}
                detailedSpecs={p.data.detailedSpecs}
              />
            ))
          }
        </div>
      </section>
    ))}
  </main>
</BaseLayout>

<style>
.projects-page {
  max-width: 1100px;
  margin: 0 auto;
  padding: 3rem 1.5rem 5rem;
}
.page-header {
  margin-bottom: 3rem;
  text-align: center;
}
.page-title {
  font-size: clamp(2rem, 5vw, 3rem);
  font-weight: 900;
  color: var(--text-primary);
  letter-spacing: -0.03em;
  margin-bottom: 0.75rem;
}
.page-subtitle {
  font-size: 1rem;
  color: var(--text-muted);
  max-width: 580px;
  margin: 0 auto;
  line-height: 1.7;
}
.section-label {
  font-size: 0.7rem;
  font-weight: 800;
  text-transform: uppercase;
  letter-spacing: 0.15em;
  color: var(--accent-blue);
  margin-bottom: 1rem;
  opacity: 0.8;
}
.ecosystem-section {
  margin-bottom: 4rem;
}
.category-section {
  margin-bottom: 3.5rem;
}
.category-heading {
  font-size: 1.1rem;
  font-weight: 700;
  color: var(--text-secondary);
  text-transform: uppercase;
  letter-spacing: 0.08em;
  border-bottom: 1px solid var(--border-subtle);
  padding-bottom: 0.6rem;
  margin-bottom: 1.5rem;
}
.category-grid {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
  gap: 1.25rem;
}
@media (max-width: 640px) {
  .category-grid { grid-template-columns: 1fr; }
  .projects-page { padding: 2rem 1rem 4rem; }
}
</style>
