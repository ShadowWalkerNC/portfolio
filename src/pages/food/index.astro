---
import BaseLayout from '../../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Nate Cowperthwaite — Chef"
  description="10+ years in professional kitchens across Maine. Scratch cooking, BOH leadership, and the discipline that only comes from real service."
  side="food"
>
  <main id="main-content">

    <!-- ===== HERO ===== -->
    <section class="food-hero hero-gradient-bg">
      <div class="orb-container" aria-hidden="true">
        <div class="orb orb-ember"></div>
        <div class="orb orb-amber"></div>
      </div>
      <div class="food-hero-inner">
        <div class="animate-fade-in-up">
          <span class="badge badge-ember">&#127859; Chef &amp; Kitchen Lead</span>
        </div>
        <h1 class="food-hero-title animate-fade-in-up" style="animation-delay:0.07s">
          A decade of real kitchens.<br />
          <span class="shimmer-text-ember">Earned at the pass.</span>
        </h1>
        <p class="food-hero-sub animate-fade-in-up" style="animation-delay:0.14s">
          From coastal Maine resort banquets to Italian fine dining and food truck service —
          built from scratch cooking, BOH leadership, and the kind of discipline
          that only comes from years of real, high-pressure service.
        </p>
        <div class="food-hero-stats animate-fade-in-up" style="animation-delay:0.20s">
          <div class="fhs"><span class="fhs-num">10+</span><span class="fhs-label">Years</span></div>
          <div class="fhs-div"></div>
          <div class="fhs"><span class="fhs-num ember">12+</span><span class="fhs-label">Roles</span></div>
          <div class="fhs-div"></div>
          <div class="fhs"><span class="fhs-num">2</span><span class="fhs-label">Sous Chef</span></div>
        </div>
        <div class="food-hero-actions animate-fade-in-up" style="animation-delay:0.26s">
          <a href="https://photos.app.goo.gl/JGgx37aAA1vhip3z9" target="_blank" rel="noopener" class="btn btn-ember">&#127752; View Food Gallery</a>
          <a href="#experience" class="btn btn-ghost">Jump to Experience</a>
        </div>
      </div>
    </section>

    <!-- ===== SKILLS ===== -->
    <section class="section section-ember-tint" id="skills">
      <h2 class="section-heading reveal">Skills &amp; Competencies</h2>

      <div class="skills-table reveal">

        <div class="skills-row">
          <div class="skills-cat">&#128298; Technique</div>
          <div class="skills-chips">
            <span class="sk">Knife Skills</span>
            <span class="sk">Saut&eacute;ing</span>
            <span class="sk">Flat-top Griddle</span>
            <span class="sk">Deep Frying</span>
            <span class="sk">Combi Ovens</span>
            <span class="sk">Scratch Baking</span>
            <span class="sk">Stocks &amp; Sauces</span>
            <span class="sk">Butchery / Fabrication</span>
          </div>
        </div>

        <div class="skills-row">
          <div class="skills-cat">&#127869; Service Types</div>
          <div class="skills-chips">
            <span class="sk">Breakfast / Brunch</span>
            <span class="sk">Fine Dining</span>
            <span class="sk">Banquet &amp; Catering</span>
            <span class="sk">Food Truck Ops</span>
            <span class="sk">High-Volume Line</span>
            <span class="sk">Assisted Living Dining</span>
          </div>
        </div>

        <div class="skills-row">
          <div class="skills-cat">&#128736; Leadership &amp; Ops</div>
          <div class="skills-chips">
            <span class="sk">Shift Supervision</span>
            <span class="sk">Staff Coordination</span>
            <span class="sk">Dietary Management</span>
            <span class="sk">Inventory Control</span>
            <span class="sk">Menu Development</span>
            <span class="sk">Recipe Costing</span>
            <span class="sk">FOH / BOH Liaison</span>
          </div>
        </div>

        <div class="skills-row">
          <div class="skills-cat">&#127941; Certifications</div>
          <div class="skills-chips">
            <span class="sk sk-cert">
              <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M20 6 9 17l-5-5"/></svg>
              Food Handler Certified
            </span>
            <span class="sk sk-cert">
              <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M20 6 9 17l-5-5"/></svg>
              Valid Driver&rsquo;s License
            </span>
          </div>
        </div>

      </div>
    </section>

    <div class="divider-fusion"></div>

    <!-- ===== EXPERIENCE ===== -->
    <section class="section" id="experience">
      <h2 class="section-heading reveal">Experience</h2>

      <!-- CURRENT -->
      <div class="exp-group reveal">
        <div class="exp-group-label exp-current">&#128994; Currently Active</div>
        <div class="exp-cards">

          <div class="exp-card card">
            <div class="exp-card-top">
              <div class="exp-left">
                <div class="exp-role">Cook</div>
                <div class="exp-employer">Ross Manor (Sylvia Ross)</div>
                <div class="exp-loc">
                  <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M20 10c0 6-8 12-8 12S4 16 4 10a8 8 0 0 1 16 0Z"/><circle cx="12" cy="10" r="3"/></svg>
                  Bangor, ME
                </div>
              </div>
              <div class="exp-right">
                <span class="badge badge-ember">Active</span>
                <span class="exp-dates">2024&ndash;Present</span>
              </div>
            </div>
            <p class="exp-desc">Preparing scratch-made meals daily for assisted living residents with complex and restricted dietary needs. Handles specialized accommodations, consistent meal quality, and structured shift operations in a care-focused environment.</p>
            <div class="exp-tags">
              <span class="etag">Scratch Cooking</span>
              <span class="etag">Dietary Management</span>
              <span class="etag">Shift Structure</span>
            </div>
          </div>

          <div class="exp-card card">
            <div class="exp-card-top">
              <div class="exp-left">
                <div class="exp-role">Co-Founder</div>
                <div class="exp-employer">Northern Fixin&rsquo;s / Half Baked Co.</div>
                <div class="exp-loc">
                  <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M20 10c0 6-8 12-8 12S4 16 4 10a8 8 0 0 1 16 0Z"/><circle cx="12" cy="10" r="3"/></svg>
                  Bangor, ME
                </div>
              </div>
              <div class="exp-right">
                <span class="badge badge-ember">Active</span>
                <span class="exp-dates">2023&ndash;Present</span>
              </div>
            </div>
            <p class="exp-desc">Co-founded a Maine-inspired elevated caf&eacute; and scratch bakehouse concept currently in active development. Half Baked Caf&eacute; &amp; Bakehouse is targeting a brick-and-mortar launch in 2027, with the Alley Katz food truck concept running in parallel. Responsible for menu development, brand identity, and all kitchen operations planning.</p>
            <div class="exp-tags">
              <span class="etag">Co-Founder</span>
              <span class="etag">Menu Development</span>
              <span class="etag">Food Truck Ops</span>
              <span class="etag">Bakehouse</span>
              <span class="etag">Brand Identity</span>
            </div>
          </div>

        </div>
      </div>

      <!-- 2024-2025 -->
      <div class="exp-group reveal">
        <div class="exp-group-label exp-recent">&#128992; 2024&ndash;2025</div>
        <div class="exp-cards">

          <div class="exp-card card">
            <div class="exp-card-top">
              <div class="exp-left">
                <div class="exp-role">Shift Lead</div>
                <div class="exp-employer">Seasons Bar and Grille</div>
                <div class="exp-loc">
                  <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M20 10c0 6-8 12-8 12S4 16 4 10a8 8 0 0 1 16 0Z"/><circle cx="12" cy="10" r="3"/></svg>
                  Bangor, ME
                </div>
              </div>
              <span class="exp-dates">Feb 2025</span>
            </div>
            <p class="exp-desc">Led kitchen and FOH shifts with direct responsibility for staff coordination, service pacing, and guest experience quality across both front and back of house operations.</p>
            <div class="exp-tags">
              <span class="etag">Shift Leadership</span>
              <span class="etag">FOH / BOH</span>
              <span class="etag">Staff Coordination</span>
            </div>
          </div>

          <div class="exp-card card">
            <div class="exp-card-top">
              <div class="exp-left">
                <div class="exp-role">Line Cook</div>
                <div class="exp-employer">Mason&rsquo;s Brewing Company</div>
                <div class="exp-loc">
                  <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M20 10c0 6-8 12-8 12S4 16 4 10a8 8 0 0 1 16 0Z"/><circle cx="12" cy="10" r="3"/></svg>
                  Bangor, ME
                </div>
              </div>
              <span class="exp-dates">Aug 2024</span>
            </div>
            <p class="exp-desc">High-volume scratch cooking in a working craft brewery kitchen. Full station execution across the line in a fast-paced, ticket-driven service environment where consistency and speed are non-negotiable.</p>
            <div class="exp-tags">
              <span class="etag">High Volume</span>
              <span class="etag">Line Cook</span>
              <span class="etag">Scratch Cooking</span>
            </div>
          </div>

        </div>
      </div>

      <!-- DEFINING ROLES -->
      <div class="exp-group reveal">
        <div class="exp-group-label exp-defining">&#11088; Defining Roles</div>
        <div class="exp-cards">

          <div class="exp-card card exp-card-key">
            <div class="exp-card-top">
              <div class="exp-left">
                <div class="exp-role">Line Cook / Sous Chef</div>
                <div class="exp-employer">Daddy B&rsquo;s Food Truck</div>
              </div>
              <span class="exp-dates">2022</span>
            </div>
            <p class="exp-desc">Full sous chef responsibilities in a mobile kitchen — menu execution, daily prep lists, and station ownership on a working food truck. The role that directly sparked the Northern Fixin's concept.</p>
            <div class="exp-tags">
              <span class="etag">Sous Chef</span>
              <span class="etag">Food Truck</span>
              <span class="etag">Menu Execution</span>
            </div>
          </div>

          <div class="exp-card card exp-card-key">
            <div class="exp-card-top">
              <div class="exp-left">
                <div class="exp-role">Sous Chef</div>
                <div class="exp-employer">Ports of Italy</div>
              </div>
              <span class="exp-dates">2020</span>
            </div>
            <p class="exp-desc">Italian fine dining — station leadership, full menu prep, and kitchen coordination held to the exacting standards of a proper fine dining house. Where technique got sharp and kitchen discipline became second nature.</p>
            <div class="exp-tags">
              <span class="etag">Fine Dining</span>
              <span class="etag">Sous Chef</span>
              <span class="etag">Italian Cuisine</span>
              <span class="etag">Station Lead</span>
            </div>
          </div>

          <div class="exp-card card exp-card-key">
            <div class="exp-card-top">
              <div class="exp-left">
                <div class="exp-role">Breakfast Cook</div>
                <div class="exp-employer">Boynton McKay Food Co.</div>
                <div class="exp-loc">
                  <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M20 10c0 6-8 12-8 12S4 16 4 10a8 8 0 0 1 16 0Z"/><circle cx="12" cy="10" r="3"/></svg>
                  Camden, ME
                </div>
              </div>
              <span class="exp-dates">2019</span>
            </div>
            <p class="exp-desc">An iconic Camden caf&eacute; running full scratch breakfast service through Maine&rsquo;s unforgiving tourist season. Consistency, speed, and quality under peak-volume pressure — the kind of environment that either sharpens you or breaks you.</p>
            <div class="exp-tags">
              <span class="etag">Scratch Breakfast</span>
              <span class="etag">High Volume</span>
              <span class="etag">Maine Caf&eacute;</span>
            </div>
          </div>

          <div class="exp-card card exp-card-key">
            <div class="exp-card-top">
              <div class="exp-left">
                <div class="exp-role">Grill Cook / Line Cook</div>
                <div class="exp-employer">Samoset Resort</div>
                <div class="exp-loc">
                  <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M20 10c0 6-8 12-8 12S4 16 4 10a8 8 0 0 1 16 0Z"/><circle cx="12" cy="10" r="3"/></svg>
                  Rockport, ME
                </div>
              </div>
              <span class="exp-dates">2014</span>
            </div>
            <p class="exp-desc">Premier Maine coastal resort — the first major culinary role that set the foundation. Banquet service at scale, hospitality-grade standards, and the early discipline of a real professional kitchen. Where it all started.</p>
            <div class="exp-tags">
              <span class="etag">First Major Role</span>
              <span class="etag">Banquet</span>
              <span class="etag">Coastal Resort</span>
            </div>
          </div>

        </div>
      </div>

    </section>

    <div class="divider"></div>

    <!-- ===== CULINARY GALLERY ===== -->
    <section class="section" id="gallery">
      <h2 class="section-heading reveal">Culinary Showcase</h2>
      <p class="section-sub reveal">A look at the dishes and scratch-baked crafts built at the pass. Interactive spotlight hover details below.</p>
      
      <div class="culinary-gallery-grid stagger">
        <div class="gallery-card card spotlight-card reveal">
          <div class="gallery-image-wrapper">
            <img src="/images/seafood.png" alt="Pan-Seared Maine Scallops" class="gallery-img" />
          </div>
          <div class="gallery-info">
            <div>
              <span class="badge badge-ember">Fine Dining</span>
            </div>
            <h3 class="gallery-item-title">Maine Seafood Plating</h3>
            <p class="gallery-item-desc">Seared scallops with vibrant purees, microgreens, and contemporary coastal plating.</p>
          </div>
        </div>

        <div class="gallery-card card spotlight-card reveal">
          <div class="gallery-image-wrapper">
            <img src="/images/baking.png" alt="Artisanal Scratch Baking" class="gallery-img" />
          </div>
          <div class="gallery-info">
            <div>
              <span class="badge badge-ember">Scratch Baking</span>
            </div>
            <h3 class="gallery-item-title">Artisanal Bakehouse</h3>
            <p class="gallery-item-desc">High-hydration sourdough loaves and baked items prepared from scratch daily.</p>
          </div>
        </div>

        <div class="gallery-card card spotlight-card reveal">
          <div class="gallery-image-wrapper">
            <img src="/images/plated.png" alt="Modern Plated Gourmet Dessert" class="gallery-img" />
          </div>
          <div class="gallery-info">
            <div>
              <span class="badge badge-ember">Technique</span>
            </div>
            <h3 class="gallery-item-title">Precision Pastry &amp; Plating</h3>
            <p class="gallery-item-desc">Refined chocolate ganache designs, raspberry coulis, and edible gold leaf garnishes.</p>
          </div>
        </div>
      </div>
      
      <div class="gallery-footer-action reveal">
        <a href="https://photos.app.goo.gl/JGgx37aAA1vhip3z9" target="_blank" rel="noopener" class="btn btn-ember">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" style="margin-right:0.25rem;"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="17 8 12 3 7 8"/><line x1="12" y1="3" x2="12" y2="15"/></svg>
          View Full Google Photos Album &rarr;
        </a>
      </div>
    </section>

  </main>
</BaseLayout>

<style>
/* ===== Ember Orbs (food-side hero) ===== */
@keyframes orbFloat {
  0%, 100% { transform: translateY(0) scale(1); }
  50%       { transform: translateY(-18px) scale(1.03); }
}
.orb-ember {
  width: 420px;
  height: 420px;
  background: radial-gradient(circle, rgba(249,115,22,0.22) 0%, transparent 70%);
  top: -80px;
  right: -80px;
  animation: orbFloat 9s ease-in-out infinite;
}
.orb-amber {
  width: 300px;
  height: 300px;
  background: radial-gradient(circle, rgba(245,158,11,0.16) 0%, transparent 70%);
  bottom: -60px;
  left: 5%;
  animation: orbFloat 12s ease-in-out infinite reverse;
}

/* ===== Shimmer text — ember variant ===== */
.shimmer-text-ember {
  background: linear-gradient(
    90deg,
    var(--accent-ember) 0%,
    #f59e0b 30%,
    #fbbf24 50%,
    #f59e0b 70%,
    var(--accent-ember) 100%
  );
  background-size: 200% auto;
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
  animation: shimmer 3.5s linear infinite;
}

/* ===== Hero ===== */
.food-hero {
  position: relative;
  padding: 5rem 1.5rem 4rem;
  overflow: hidden;
  border-bottom: 1px solid rgba(249,115,22,0.18);
}
.food-hero::after {
  content: '';
  position: absolute;
  inset: 0;
  background: linear-gradient(135deg,
    rgba(249,115,22,0.07) 0%,
    transparent 60%);
  pointer-events: none;
}
.food-hero-inner {
  position: relative;
  z-index: 2;
  max-width: 700px;
  margin: 0 auto;
  text-align: center;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 0;
}
.food-hero-inner .badge { margin-bottom: 1.25rem; }
.food-hero-title {
  font-family: var(--font-serif);
  font-size: clamp(2rem, 5.5vw, 3.8rem);
  font-weight: 400;
  letter-spacing: -0.01em;
  line-height: 1.05;
  color: var(--text-primary);
  margin-bottom: 1.25rem;
}
.food-hero-sub {
  font-size: 1rem;
  color: var(--text-muted);
  line-height: 1.75;
  max-width: 540px;
  margin-bottom: 1.5rem;
}

/* ===== Hero stats ===== */
.food-hero-stats {
  display: flex;
  gap: 1rem;
  align-items: center;
  background: var(--bg-surface);
  border: 1px solid rgba(249,115,22,0.20);
  border-radius: var(--radius-lg);
  padding: 0.85rem 1.5rem;
  margin-bottom: 1.5rem;
}
.fhs { display: flex; flex-direction: column; align-items: center; gap: 1px; }
.fhs-num { font-size: 1.5rem; font-weight: 800; color: var(--text-primary); line-height: 1; }
.fhs-num.ember { color: var(--accent-ember); }
.fhs-label { font-size: 0.6rem; text-transform: uppercase; letter-spacing: 0.08em; color: var(--text-muted); }
.fhs-div { width: 1px; height: 32px; background: rgba(249,115,22,0.18); }

.food-hero-actions { display: flex; gap: 0.75rem; flex-wrap: wrap; justify-content: center; }

/* ===== Skills Table ===== */
.section-ember-tint {
  background: linear-gradient(180deg, rgba(249,115,22,0.04) 0%, transparent 100%);
  border-top: 1px solid rgba(249,115,22,0.10);
}
.skills-table {
  display: flex;
  flex-direction: column;
  gap: 0;
  border: 1px solid var(--border-subtle);
  border-radius: var(--radius-lg);
  overflow: hidden;
  max-width: 860px;
}
.skills-row {
  display: grid;
  grid-template-columns: 170px 1fr;
  gap: 1rem;
  padding: 0.9rem 1.25rem;
  border-bottom: 1px solid var(--border-subtle);
  align-items: start;
}
.skills-row:last-child { border-bottom: none; }
.skills-row:nth-child(odd)  { background: var(--bg-surface); }
.skills-row:nth-child(even) { background: var(--bg-elevated); }
.skills-cat {
  font-size: 0.72rem;
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: 0.1em;
  color: var(--text-muted);
  padding-top: 3px;
  display: flex;
  align-items: center;
  gap: 0.3rem;
}
.skills-chips { display: flex; flex-wrap: wrap; gap: 0.35rem; }
.sk {
  font-size: 0.78rem;
  font-weight: 600;
  padding: 3px 11px;
  border-radius: var(--radius-full);
  background: var(--bg-elevated);
  color: var(--text-secondary);
  border: 1px solid var(--border-subtle);
  display: inline-flex;
  align-items: center;
  gap: 0.3rem;
  transition: border-color 0.18s, color 0.18s;
}
.sk:hover { border-color: var(--accent-ember); color: var(--accent-ember); }
.sk-cert {
  border-color: #bbf7d0;
  background: #f0fdf4;
  color: #16a34a;
}
.sk-cert:hover { border-color: #16a34a; color: #16a34a; }
.sk-cert svg { stroke: #16a34a; }

/* ===== Experience ===== */
.exp-group { margin-bottom: 2.5rem; }
.exp-group-label {
  font-size: 0.7rem;
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: 0.1em;
  padding: 0.28rem 0.75rem;
  border-radius: var(--radius-full);
  display: inline-flex;
  align-items: center;
  gap: 0.3rem;
  margin-bottom: 1rem;
}
.exp-current  { background: #fef2f2; color: #dc2626; border: 1px solid #fecaca; }
.exp-recent   { background: #fffbeb; color: #d97706; border: 1px solid #fde68a; }
.exp-defining { background: #fefce8; color: #a16207; border: 1px solid #fef08a; }

.exp-cards { display: grid; grid-template-columns: repeat(auto-fill, minmax(300px, 1fr)); gap: 1rem; }
.exp-card {
  padding: 1.4rem;
  display: flex;
  flex-direction: column;
  gap: 0.75rem;
}
.exp-card-key { border-left: 3px solid var(--accent-ember); }
.exp-card-top {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  gap: 0.5rem;
}
.exp-left { display: flex; flex-direction: column; gap: 2px; }
.exp-role     { font-size: 1rem; font-weight: 700; color: var(--text-primary); }
.exp-employer { font-size: 0.88rem; font-weight: 600; color: var(--accent-ember); }
.exp-loc {
  display: inline-flex;
  align-items: center;
  gap: 0.2rem;
  font-size: 0.75rem;
  color: var(--text-muted);
  margin-top: 1px;
}
.exp-loc svg { flex-shrink: 0; }
.exp-right { display: flex; flex-direction: column; align-items: flex-end; gap: 3px; }
.exp-dates { font-size: 0.75rem; color: var(--text-muted); font-weight: 500; white-space: nowrap; }
.exp-desc { font-size: 0.85rem; color: var(--text-secondary); line-height: 1.65; margin: 0; }

.exp-tags { display: flex; flex-wrap: wrap; gap: 0.3rem; }
.etag {
  font-size: 0.67rem;
  font-weight: 600;
  padding: 0.18rem 0.5rem;
  border-radius: var(--radius-full);
