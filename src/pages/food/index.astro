---
import BaseLayout from '../../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Nate Cowperthwaite — Chef"
  description="10+ years in professional kitchens across Maine. Scratch cooking, BOH leadership, and the discipline that only comes from real service."
  side="food"
>
  <main id="main-content">

    <!-- ===== HERO ===== -->
    <section class="chef-hero">
      <div class="orb-container" aria-hidden="true">
        <div class="orb orb-ember"></div>
        <div class="orb orb-indigo"></div>
      </div>
      <div class="chef-hero-inner">
        <span class="badge badge-ember animate-fade-in-up">
          <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2z"/><path d="M8 12h8M12 8v8"/></svg>
          Culinary Professional &middot; Bangor, ME
        </span>
        <h1 class="chef-hero-title animate-fade-in-up" style="animation-delay:0.07s">
          Nate Cowperthwaite
        </h1>
        <p class="chef-hero-sub animate-fade-in-up" style="animation-delay:0.12s">
          10+ years across Maine kitchens &mdash; resort banquets, Italian fine dining, craft brewery line, and assisted living dietary care. Scratch cooking, BOH leadership, and the discipline earned at the pass.
        </p>
        <div class="chef-stats animate-fade-in-up" style="animation-delay:0.18s">
          <div class="cs"><span class="cs-num">10+</span><span class="cs-label">Years Experience</span></div>
          <div class="cs-div"></div>
          <div class="cs"><span class="cs-num ember">12+</span><span class="cs-label">Roles Held</span></div>
          <div class="cs-div"></div>
          <div class="cs"><span class="cs-num">2</span><span class="cs-label">Sous Chef Positions</span></div>
          <div class="cs-div"></div>
          <div class="cs"><span class="cs-num ember">500+</span><span class="cs-label">Peak Covers</span></div>
        </div>
        <div class="chef-hero-actions animate-fade-in-up" style="animation-delay:0.24s">
          <a href="#experience" class="btn btn-ember">
            <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><line x1="12" y1="5" x2="12" y2="19"/><polyline points="19 12 12 19 5 12"/></svg>
            View Experience
          </a>
          <a href="https://photos.app.goo.gl/JGgx37aAA1vhip3z9" target="_blank" rel="noopener" class="btn btn-ghost">
            <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="3" y="3" width="18" height="18" rx="2"/><circle cx="8.5" cy="8.5" r="1.5"/><polyline points="21 15 16 10 5 21"/></svg>
            Food Gallery
          </a>
        </div>
      </div>
    </section>

<section class="section chef-skills-section" id="skills" data-animate="fade">
  <div class="chef-skills-inner">
    <section class="skill-card">
      <h3 class="skill-card-title">
        <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M14.7 6.3a1 1 0 0 0 0 1.4l1.6 1.6a1 1 0 0 0 1.4 0l3.77-3.77a6 6 0 0 1-7.94 7.94l-6.91 6.91a2.12 2.12 0 0 1-3-3l6.91-6.91a6 6 0 0 1 7.94-7.94l-3.76 3.76z"/></svg>
        Technique
      </h3>
      <div class="skill-chips">
        <span class="skill-chip">Knife Skills</span>
        <span class="skill-chip">Sautéing</span>
        <span class="skill-chip">Flat-top Griddle</span>
        <span class="skill-chip">Deep Frying</span>
        <span class="skill-chip">Combi Ovens</span>
        <span class="skill-chip">Scratch Baking</span>
        <span class="skill-chip">Stocks & Sauces</span>
        <span class="skill-chip">Butchery</span>
      </div>
    </section>
    <section class="skill-card">
      <h3 class="skill-card-title">
        <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M3 11l19-9-9 19-2-8-8-2z"/></svg>
        Service
      </h3>
      <div class="skill-chips">
        <span class="skill-chip">Fine Dining</span>
        <span class="skill-chip">Banquet & Catering</span>
        <span class="skill-chip">Food Truck</span>
        <span class="skill-chip">High-Volume Line</span>
        <span class="skill-chip">Breakfast / Brunch</span>
        <span class="skill-chip">Assisted Living</span>
      </div>
    </section>
    <section class="skill-card">
      <h3 class="skill-card-title">
        <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
        Leadership
      </h3>
      <div class="skill-chips">
        <span class="skill-chip">Shift Supervision</span>
        <span class="skill-chip">Staff Coordination</span>
        <span class="skill-chip">Dietary Management</span>
        <span class="skill-chip">Menu Development</span>
        <span class="skill-chip">Recipe Costing</span>
        <span class="skill-chip">Inventory Control</span>
      </div>
    </section>
    <section class="certifications-card">
      <h3 class="skill-card-title">
        <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M20 6 9 17l-5-5"/></svg>
        Certifications
      </h3>
      <div class="skill-chips">
        <span class="skill-chip">Food Handler Certified</span>
        <span class="skill-chip">Valid Driver’s License</span>
      </div>
    </section>
  </div>
</section>

    <!-- ===== RECIPE SCALER WIDGET ===== -->
    <section class="section section-ember-tint" id="recipe-scaler">
      <h2 class="section-heading reveal">Ratio Scaling Engine Showcase</h2>
      <p class="section-sub reveal">A live demonstration of the proprietary recipe ratio scaler logic built for **KitchenKit**. Ingredient metrics adjust with mathematical precision.</p>

      <div class="scaler-widget card spotlight-card reveal">
        <div class="scaler-controls">
          <div class="scaler-control-group">
            <label for="recipe-select" class="scaler-label">Select Recipe Blueprint:</label>
            <select id="recipe-select" class="form-select scaler-select">
              <option value="sourdough">Artisanal Sourdough (Baker's Percentages)</option>
              <option value="scallops">Maine Scallops &amp; Herb Puree</option>
              <option value="sauce">Classic Demi-Glace Scratch Reduction</option>
            </select>
          </div>

          <div class="scaler-control-group">
            <div class="slider-labels">
              <span class="scaler-label">Target Yield:</span>
              <span class="slider-value" id="yield-display">4 Portions</span>
            </div>
            <input type="range" id="yield-slider" min="1" max="24" value="4" class="scaler-slider" />
          </div>
        </div>

        <div class="scaler-results">
          <h3 class="scaler-results-title" id="recipe-title">Artisanal Sourdough</h3>
          <div class="ingredients-list" id="ingredients-container">
            <!-- Populated dynamically via JS -->
          </div>
        </div>
      </div>
    </section>

    <div class="divider-fusion"></div>

    <!-- ===== FEATURED ROLES ===== -->
    <section class="section" id="featured">
      <h2 class="section-heading reveal">Featured Roles</h2>
      <p class="section-sub reveal">High-impact positions that define the range.</p>
      <div class="featured-grid stagger">

        <div class="featured-card card reveal">
          <div class="featured-top">
            <div>
              <div class="feat-role">Shift Lead</div>
              <div class="feat-employer">Seasons Bar and Grille</div>
            </div>
            <span class="feat-date">2025</span>
          </div>
          <p class="feat-stat">
            <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="23 6 13.5 15.5 8.5 10.5 1 18"/><polyline points="17 6 23 6 23 12"/></svg>
            200+ covers nightly &middot; Team of 8&ndash;10
          </p>
          <p class="feat-desc">Owned full shift operations across kitchen and FOH &mdash; staff coordination, service pacing, and real-time problem resolution in a high-traffic Bangor bar and grill.</p>
          <div class="feat-tags"><span class="ftag">Shift Lead</span><span class="ftag">FOH / BOH</span><span class="ftag">Staff Coordination</span></div>
        </div>

        <div class="featured-card card reveal">
          <div class="featured-top">
            <div>
              <div class="feat-role">Line Cook</div>
              <div class="feat-employer">Mason&rsquo;s Brewing Company</div>
            </div>
            <span class="feat-date">2024</span>
          </div>
          <p class="feat-stat">
            <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="23 6 13.5 15.5 8.5 10.5 1 18"/><polyline points="17 6 23 6 23 12"/></svg>
            500+ covers &middot; $47k peak night
          </p>
          <p class="feat-desc">High-volume scratch cooking in a working craft brewery kitchen. Full station execution under sustained, ticket-driven pressure where speed and consistency are non-negotiable.</p>
          <div class="feat-tags"><span class="ftag">High Volume</span><span class="ftag">Line Cook</span><span class="ftag">Scratch Cooking</span></div>
        </div>

        <div class="featured-card card reveal">
          <div class="featured-top">
            <div>
              <div class="feat-role">Sous Chef</div>
              <div class="feat-employer">Ports of Italy</div>
            </div>
            <span class="feat-date">2020&ndash;2021</span>
          </div>
          <p class="feat-stat">
            <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M3 11l19-9-9 19-2-8-8-2z"/></svg>
            Italian fine dining &middot; Station leadership
          </p>
          <p class="feat-desc">Station leadership and full menu prep in a proper fine dining house. Where technique got sharp and kitchen discipline became second nature.</p>
          <div class="feat-tags"><span class="ftag">Sous Chef</span><span class="ftag">Fine Dining</span><span class="ftag">Italian Cuisine</span></div>
        </div>

      </div>
    </section>

    <div class="divider"></div>

    <!-- ===== EXPERIENCE TIMELINE ===== -->
    <section class="section" id="experience">
      <h2 class="section-heading reveal">Full Experience</h2>
      <div class="timeline reveal">

        <div class="tl-item">
          <div class="tl-left"><span class="tl-date">Dec 2025&ndash;Present</span><span class="tl-loc">Bangor, ME</span></div>
          <div class="tl-col"><div class="tl-dot tl-dot-active"></div><div class="tl-line"></div></div>
          <div class="tl-right">
            <div class="tl-role">Cook <span class="tl-badge-active">Active</span></div>
            <div class="tl-employer">Ross Manor (Sylvia Ross)</div>
            <p class="tl-desc">Scratch-made meals daily for 40 assisted living residents across complex dietary protocols &mdash; pureed, diabetic, allergen-restricted. Trusted independent kitchen presence in a care-first environment.</p>
          </div>
        </div>

        <div class="tl-item">
          <div class="tl-left"><span class="tl-date">2025</span><span class="tl-loc">Bangor, ME</span></div>
          <div class="tl-col"><div class="tl-dot"></div><div class="tl-line"></div></div>
          <div class="tl-right">
            <div class="tl-role">Shift Lead</div>
            <div class="tl-employer">Seasons Bar and Grille</div>
            <p class="tl-desc">200+ covers nightly, team of 8&ndash;10 across kitchen and FOH. Full shift ownership &mdash; pacing, coordination, and guest experience resolution.</p>
          </div>
        </div>

        <div class="tl-item">
          <div class="tl-left"><span class="tl-date">2024</span><span class="tl-loc">Bangor, ME</span></div>
          <div class="tl-col"><div class="tl-dot"></div><div class="tl-line"></div></div>
          <div class="tl-right">
            <div class="tl-role">Line Cook</div>
            <div class="tl-employer">Mason&rsquo;s Brewing Company</div>
            <p class="tl-desc">High-volume craft brewery kitchen. Peak nights hit 500+ covers and $47k in sales &mdash; full station execution under sustained ticket pressure.</p>
          </div>
        </div>

        <div class="tl-item">
          <div class="tl-left"><span class="tl-date">Nov 2023&ndash;Apr 2024</span><span class="tl-loc">Brewer, ME</span></div>
          <div class="tl-col"><div class="tl-dot"></div><div class="tl-line"></div></div>
          <div class="tl-right">
            <div class="tl-role">Deli Associate</div>
            <div class="tl-employer">Harvest Moon Deli</div>
            <p class="tl-desc">Deli prep to order, food safety standards, and customer-facing service.</p>
          </div>
        </div>

        <div class="tl-item">
          <div class="tl-left"><span class="tl-date">Mar&ndash;May 2022</span><span class="tl-loc">Hurst, TX</span></div>
          <div class="tl-col"><div class="tl-dot tl-dot-key"></div><div class="tl-line"></div></div>
          <div class="tl-right">
            <div class="tl-role">Line Cook / Sous Chef</div>
            <div class="tl-employer">Daddy B&rsquo;s Food Truck</div>
            <p class="tl-desc">Sous chef duties in a mobile kitchen &mdash; menu execution, prep lists, and station ownership. The role that directly sparked Northern Fixin&rsquo;s.</p>
          </div>
        </div>

        <div class="tl-item">
          <div class="tl-left"><span class="tl-date">Jan&ndash;Apr 2022</span><span class="tl-loc">Fort Worth, TX</span></div>
          <div class="tl-col"><div class="tl-dot"></div><div class="tl-line"></div></div>
          <div class="tl-right">
            <div class="tl-role">Breakfast Chef</div>
            <div class="tl-employer">Toasted Coffee + Kitchen</div>
            <p class="tl-desc">Full scratch breakfast service from open through mid-day rush. Speed, quality, and consistency under high-pressure morning volume.</p>
          </div>
        </div>

        <div class="tl-item">
          <div class="tl-left"><span class="tl-date">Dec 2021&ndash;Jul 2022</span><span class="tl-loc">Austin, TX</span></div>
          <div class="tl-col"><div class="tl-dot"></div><div class="tl-line"></div></div>
          <div class="tl-right">
            <div class="tl-role">Line Cook / Prep Cook</div>
            <div class="tl-employer">Red Ash Grill</div>
            <p class="tl-desc">Full-service grill kitchen &mdash; line execution and prep across lunch and dinner service.</p>
          </div>
        </div>

        <div class="tl-item">
          <div class="tl-left"><span class="tl-date">Jun 2020&ndash;May 2021</span><span class="tl-loc">Rockport, ME</span></div>
          <div class="tl-col"><div class="tl-dot tl-dot-key"></div><div class="tl-line"></div></div>
          <div class="tl-right">
            <div class="tl-role">Sous Chef</div>
            <div class="tl-employer">Ports of Italy</div>
            <p class="tl-desc">Italian fine dining &mdash; station leadership, full menu prep, and kitchen coordination. Where technique got sharp and kitchen discipline became second nature.</p>
          </div>
        </div>

        <div class="tl-item">
          <div class="tl-left"><span class="tl-date">May&ndash;Aug 2019</span><span class="tl-loc">Camden, ME</span></div>
          <div class="tl-col"><div class="tl-dot tl-dot-key"></div><div class="tl-line"></div></div>
          <div class="tl-right">
            <div class="tl-role">Breakfast Cook</div>
            <div class="tl-employer">Boynton McKay Food Co.</div>
            <p class="tl-desc">Iconic Camden caf&eacute; &mdash; full scratch breakfast through Maine&rsquo;s peak tourist season. The kind of volume that either sharpens you or breaks you.</p>
          </div>
        </div>

        <div class="tl-item">
          <div class="tl-left"><span class="tl-date">Aug 2017&ndash;Sep 2018</span><span class="tl-loc">Rockland, ME</span></div>
          <div class="tl-col"><div class="tl-dot"></div><div class="tl-line"></div></div>
          <div class="tl-right">
            <div class="tl-role">Tech Supervisor</div>
            <div class="tl-employer">Staples</div>
            <p class="tl-desc">Technology floor supervision &mdash; IP networking, customer service, and technical support.</p>
          </div>
        </div>

        <div class="tl-item">
          <div class="tl-left"><span class="tl-date">Jun 2016&ndash;Oct 2017</span><span class="tl-loc">Austin, TX</span></div>
          <div class="tl-col"><div class="tl-dot"></div><div class="tl-line"></div></div>
          <div class="tl-right">
            <div class="tl-role">Barista / Shift Supervisor</div>
            <div class="tl-employer">Barley Bean / Mour Caf&eacute;</div>
            <p class="tl-desc">Coffee and caf&eacute; service with shift-level supervisory responsibility.</p>
          </div>
        </div>

        <div class="tl-item">
          <div class="tl-left"><span class="tl-date">Dec 2015&ndash;Jun 2016</span><span class="tl-loc">Austin, TX</span></div>
          <div class="tl-col"><div class="tl-dot"></div><div class="tl-line"></div></div>
          <div class="tl-right">
            <div class="tl-role">Prep Cook</div>
            <div class="tl-employer">North Restaurant</div>
            <p class="tl-desc">Early culinary role &mdash; knife skills, mise en place, and kitchen discipline fundamentals.</p>
          </div>
        </div>

        <div class="tl-item tl-last">
          <div class="tl-left"><span class="tl-date">Jun 2014&ndash;Aug 2015</span><span class="tl-loc">Rockport, ME</span></div>
          <div class="tl-col"><div class="tl-dot tl-dot-key"></div></div>
          <div class="tl-right">
            <div class="tl-role">Grill Cook / Line Cook</div>
            <div class="tl-employer">Samoset Resort</div>
            <p class="tl-desc">First major culinary role at a premier Maine coastal resort. Banquet service at scale, hospitality-grade standards, and the early discipline of a real professional kitchen. Where it all started.</p>
          </div>
        </div>

      </div>
    </section>

    <div class="divider"></div>

    <!-- ===== CULINARY GALLERY ===== -->
    <section class="section" id="gallery">
      <h2 class="section-heading reveal">Culinary Showcase</h2>
      <p class="section-sub reveal">A look at the dishes and scratch-baked crafts built at the pass.</p>
      <div class="culinary-gallery-grid stagger">
        <div class="gallery-card card reveal">
          <div class="gallery-image-wrapper">
            <img src="/images/seafood.png" alt="Pan-Seared Maine Scallops" class="gallery-img" />
          </div>
          <div class="gallery-info">
            <span class="badge badge-ember">Fine Dining</span>
            <h3 class="gallery-item-title">Maine Seafood Plating</h3>
            <p class="gallery-item-desc">Seared scallops with vibrant purees, microgreens, and contemporary coastal plating.</p>
          </div>
        </div>
        <div class="gallery-card card reveal">
          <div class="gallery-image-wrapper">
            <img src="/images/baking.png" alt="Artisanal Scratch Baking" class="gallery-img" />
          </div>
          <div class="gallery-info">
            <span class="badge badge-ember">Scratch Baking</span>
            <h3 class="gallery-item-title">Artisanal Bakehouse</h3>
            <p class="gallery-item-desc">High-hydration sourdough loaves and baked items prepared from scratch daily.</p>
          </div>
        </div>
        <div class="gallery-card card reveal">
          <div class="gallery-image-wrapper">
            <img src="/images/plated.png" alt="Modern Plated Gourmet Dessert" class="gallery-img" />
          </div>
          <div class="gallery-info">
            <span class="badge badge-ember">Technique</span>
            <h3 class="gallery-item-title">Precision Pastry &amp; Plating</h3>
            <p class="gallery-item-desc">Refined chocolate ganache designs, raspberry coulis, and edible gold leaf garnishes.</p>
          </div>
        </div>
      </div>
      <div class="gallery-footer-action reveal">
        <a href="https://photos.app.goo.gl/JGgx37aAA1vhip3z9" target="_blank" rel="noopener" class="btn btn-ember">
          <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" style="margin-right:0.25rem"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="17 8 12 3 7 8"/><line x1="12" y1="3" x2="12" y2="15"/></svg>
          View Full Gallery
        </a>
      </div>
    </section>

  </main>
</BaseLayout>

<style>
@keyframes orbFloat {
  0%, 100% { transform: translateY(0) scale(1); }
  50%       { transform: translateY(-18px) scale(1.03); }
}
.orb-ember {
  width: 420px; height: 420px;
  background: radial-gradient(circle, rgba(249,115,22,0.22) 0%, transparent 70%);
  top: -80px; right: -80px;
  animation: orbFloat 9s ease-in-out infinite;
}
.orb-amber {
  width: 300px; height: 300px;
  background: radial-gradient(circle, rgba(245,158,11,0.16) 0%, transparent 70%);
  bottom: -60px; left: 5%;
  animation: orbFloat 12s ease-in-out infinite reverse;
}

/* ===== HERO ===== */
.chef-hero {
  position: relative;
  padding: 5rem 1.5rem 4rem;
  overflow: hidden;
  border-bottom: 1px solid rgba(249,115,22,0.15);
  text-align: center;
}
.chef-hero-inner {
  position: relative; z-index: 2;
  max-width: 680px; margin: 0 auto;
  display: flex; flex-direction: column; align-items: center; gap: 0;
}
.chef-hero-inner .badge { margin-bottom: 1.1rem; display: inline-flex; align-items: center; gap: 0.35rem; }
.chef-hero-title {
  font-family: var(--font-serif);
  font-size: clamp(2.4rem, 6vw, 4rem);
  font-weight: 400;
  letter-spacing: -0.01em;
  line-height: 1.05;
  color: var(--text-primary);
  margin-bottom: 1rem;
}
.chef-hero-sub {
  font-size: 0.975rem; color: var(--text-muted);
  line-height: 1.75; max-width: 560px; margin-bottom: 1.75rem;
}
.chef-stats {
  display: flex; gap: 0.75rem; align-items: center;
  background: var(--bg-surface);
  border: 1px solid rgba(249,115,22,0.18);
  border-radius: var(--radius-lg);
  padding: 0.8rem 1.5rem;
  margin-bottom: 1.75rem;
  flex-wrap: wrap; justify-content: center;
}
.cs { display: flex; flex-direction: column; align-items: center; gap: 1px; }
.cs-num { font-size: 1.4rem; font-weight: 800; color: var(--text-primary); line-height: 1; }
.cs-num.ember { color: var(--accent-ember); }
.cs-label { font-size: 0.58rem; text-transform: uppercase; letter-spacing: 0.08em; color: var(--text-muted); white-space: nowrap; }
.cs-div { width: 1px; height: 30px; background: rgba(249,115,22,0.18); }
.chef-hero-actions { display: flex; gap: 0.75rem; flex-wrap: wrap; justify-content: center; }
.chef-hero-actions .btn { display: inline-flex; align-items: center; gap: 0.35rem; }

/* ===== SKILLS ===== */
.chef-skills-section {
  background: linear-gradient(180deg, rgba(249,115,22,0.04) 0%, transparent 100%);
  border-top: 1px solid rgba(249,115,22,0.10);
  padding-top: 2rem; padding-bottom: 2rem;
}
.chef-skills-inner { display: flex; flex-wrap: wrap; gap: 1.25rem 2.5rem; max-width: 900px; }
.skill-group { display: flex; align-items: baseline; gap: 0.6rem; flex-wrap: wrap; }
.skill-group-label {
  display: inline-flex; align-items: center; gap: 0.3rem;
  font-size: 0.68rem; font-weight: 700; text-transform: uppercase;
  letter-spacing: 0.1em; color: var(--text-muted); white-space: nowrap; padding-top: 2px;
}
.skill-chips { display: flex; flex-wrap: wrap; gap: 0.3rem; }
.sc {
  font-size: 0.76rem; font-weight: 600; padding: 2px 10px;
  border-radius: var(--radius-full); background: var(--bg-elevated);
  color: var(--text-secondary); border: 1px solid var(--border-subtle);
