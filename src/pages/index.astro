---
import Layout from '../layouts/Layout.astro';
import ProjectCard from '../components/ProjectCard.astro';
import { getCollection } from 'astro:content';

const projects = await getCollection('projects');
const featured = projects.filter(p => p.data.featured).slice(0, 3);
---

<Layout title="ShadowWalkerNC — Chef × Developer" description="I spent years cooking professionally. Now I write the software kitchens should have had all along.">
  <main>

    <!-- ===== HERO ===== -->
    <section class="hero">
      <div class="hero-content">
        <div class="hero-kicker">&#128104;&#8205;&#127859; Chef &nbsp;&#215;&nbsp; &#128187; Developer</div>
        <h1 class="hero-title">
          Building the software<br />
          <span class="hero-accent">kitchens deserve.</span>
        </h1>
        <p class="hero-subtitle">
          I spent years working professional kitchens — line cook, prep chef, food truck operator.
          When I started coding, I built the tools I always wished existed.
          That intersection is what drives everything I make.
        </p>
        <div class="hero-actions">
          <a href="/projects" class="btn btn-primary">See the Work</a>
          <a href="/contact" class="btn btn-ghost">Get in Touch</a>
        </div>
        <div class="hero-stats">
          <div class="stat"><span class="stat-num">10+</span><span class="stat-label">Projects Shipped</span></div>
          <div class="stat-divider"></div>
          <div class="stat"><span class="stat-num">3</span><span class="stat-label">Culinary Tech Apps</span></div>
          <div class="stat-divider"></div>
          <div class="stat"><span class="stat-num">5+</span><span class="stat-label">Years in Kitchens</span></div>
        </div>
      </div>
      <div class="hero-visual" aria-hidden="true">
        <div class="hero-glow"></div>
        <div class="code-block">
          <div class="code-line"><span class="c-comment">// the origin</span></div>
          <div class="code-line"><span class="c-keyword">const</span> <span class="c-var">dev</span> <span class="c-op">=</span> <span class="c-string">&#39;chef who codes&#39;</span><span class="c-op">;</span></div>
          <div class="code-line"><span class="c-keyword">const</span> <span class="c-var">mission</span> <span class="c-op">=</span> <span class="c-string">&#39;bridge the gap&#39;</span><span class="c-op">;</span></div>
          <div class="code-line c-dim">&nbsp;</div>
          <div class="code-line"><span class="c-keyword">function</span> <span class="c-fn">buildFor</span><span class="c-paren">(</span><span class="c-var">kitchens</span><span class="c-paren">) {</span></div>
          <div class="code-line">&nbsp; <span class="c-keyword">return</span> <span class="c-var">kitchens</span><span class="c-op">.</span><span class="c-fn">map</span><span class="c-paren">(</span><span class="c-var">k</span> <span class="c-op">=&gt;</span></div>
          <div class="code-line">&nbsp;&nbsp;&nbsp; <span class="c-fn">solve</span><span class="c-paren">(</span><span class="c-var">k</span><span class="c-op">.</span><span class="c-var">realProblems</span><span class="c-paren">)</span></div>
          <div class="code-line">&nbsp; <span class="c-paren">);</span></div>
          <div class="code-line"><span class="c-paren">}</span></div>
        </div>
      </div>
    </section>

    <!-- ===== JOURNEY TIMELINE ===== -->
    <section class="timeline-section">
      <h2 class="section-heading">The Journey</h2>
      <p class="section-sub">How a teenage hardware tinkerer became a line cook who writes production software.</p>
      <div class="timeline">
        <div class="timeline-item">
          <div class="timeline-dot dot-blue"></div>
          <div class="timeline-content">
            <div class="timeline-era">Early 2010s — Age 14–16</div>
            <h3 class="timeline-title">Hardware Repair & First Code</h3>
            <p class="timeline-text">Fixing neighbors' laptops, building first websites with HTML/CSS. Learned that understanding how something breaks is the fastest way to understand how it works.</p>
          </div>
        </div>
        <div class="timeline-item">
          <div class="timeline-dot dot-orange"></div>
          <div class="timeline-content">
            <div class="timeline-era">Mid 2010s — Age 17–21</div>
            <h3 class="timeline-title">Into the Kitchen</h3>
            <p class="timeline-text">Traded keyboards for knives. Worked the line, ran prep, operated a food truck. Learned what real operational pressure looks like — and how badly most kitchens needed better software.</p>
          </div>
        </div>
        <div class="timeline-item">
          <div class="timeline-dot dot-blue"></div>
          <div class="timeline-content">
            <div class="timeline-era">2020–2022</div>
            <h3 class="timeline-title">Back to Code — With a Purpose</h3>
            <p class="timeline-text">Started building the tools I always wished existed on the line. First real projects: scripts to automate food truck social posts, a basic KDS, a reservation tracker. Python first, then Node.js.</p>
          </div>
        </div>
        <div class="timeline-item">
          <div class="timeline-dot dot-green"></div>
          <div class="timeline-content">
            <div class="timeline-era">2023–Present</div>
            <h3 class="timeline-title">Full-Stack & Shipping</h3>
            <p class="timeline-text">Built and shipped CulinaryOS, Shoreline, kitchenkit, Post-Pilot, ASCILINE, and more. Focused on production-grade architecture, real deployments, and tools that solve problems for people who actually work in food.</p>
          </div>
        </div>
      </div>
    </section>

    <!-- ===== DEV KIT ===== -->
    <section class="devkit-section">
      <h2 class="section-heading">The Dev Kit</h2>
      <p class="section-sub">Languages, frameworks, and platforms I use to ship production software.</p>
      <div class="devkit-grid">
        <div class="kit-group">
          <div class="kit-group-label">Languages</div>
          <div class="kit-chips">
            <span class="kit-chip">JavaScript</span>
            <span class="kit-chip">Python</span>
            <span class="kit-chip">TypeScript</span>
            <span class="kit-chip">HTML/CSS</span>
            <span class="kit-chip">SQL</span>
          </div>
        </div>
        <div class="kit-group">
          <div class="kit-group-label">Frameworks & Libraries</div>
          <div class="kit-chips">
            <span class="kit-chip">Astro</span>
            <span class="kit-chip">Flask</span>
            <span class="kit-chip">Node.js</span>
            <span class="kit-chip">Discord.js</span>
            <span class="kit-chip">Tailwind CSS</span>
            <span class="kit-chip">React</span>
          </div>
        </div>
        <div class="kit-group">
          <div class="kit-group-label">Data & Infra</div>
          <div class="kit-chips">
            <span class="kit-chip">PostgreSQL</span>
            <span class="kit-chip">SQLite</span>
            <span class="kit-chip">Alembic</span>
            <span class="kit-chip">Railway</span>
            <span class="kit-chip">Render</span>
          </div>
        </div>
        <div class="kit-group">
          <div class="kit-group-label">AI & APIs</div>
          <div class="kit-chips">
            <span class="kit-chip">Google Gemini</span>
            <span class="kit-chip">Discord API</span>
            <span class="kit-chip">Meta Graph API</span>
            <span class="kit-chip">Twitter API v2</span>
          </div>
        </div>
      </div>
    </section>

    <!-- ===== FEATURED PROJECTS ===== -->
    <section class="featured-section">
      <h2 class="section-heading">Featured Work</h2>
      <p class="section-sub">A handful of projects that show the range. <a href="/projects" class="inline-link">See everything &rarr;</a></p>
      <div class="featured-grid">
        {featured.map(p => (
          <ProjectCard
            id={p.id}
            title={p.data.title}
            tagline={p.data.tagline}
            description={p.data.description}
            story={p.data.story}
            forWho={p.data.forWho}
            tags={p.data.tags}
            stack={p.data.stack}
            status={p.data.status}
            links={p.data.links}
            detailedSpecs={p.data.detailedSpecs}
          />
        ))}
      </div>
    </section>

  </main>
</Layout>

<style>
/* ---- Hero ---- */
.hero {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 3rem;
  align-items: center;
  padding: 5rem 1.5rem 4rem;
  max-width: 1100px;
  margin: 0 auto;
}
.hero-kicker {
  font-size: 0.8rem;
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: 0.15em;
  color: var(--accent-blue);
  margin-bottom: 1rem;
  opacity: 0.85;
}
.hero-title {
  font-size: clamp(2.2rem, 5vw, 3.4rem);
  font-weight: 900;
  line-height: 1.1;
  color: var(--text-primary);
  letter-spacing: -0.03em;
  margin: 0 0 1.2rem;
}
.hero-accent { color: var(--accent-blue); }
.hero-subtitle {
  font-size: 1rem;
  color: var(--text-muted);
  line-height: 1.7;
  margin: 0 0 2rem;
  max-width: 480px;
}
.hero-actions { display: flex; gap: 0.75rem; flex-wrap: wrap; margin-bottom: 2.5rem; }
.btn {
  padding: 0.7rem 1.6rem;
  border-radius: 8px;
  font-weight: 700;
  font-size: 0.9rem;
  text-decoration: none;
  transition: all 0.2s ease;
  cursor: pointer;
}
.btn-primary { background: var(--accent-blue); color: #0d1117; }
.btn-primary:hover { filter: brightness(1.15); transform: translateY(-1px); }
.btn-ghost {
  background: transparent;
  color: var(--text-secondary);
  border: 1px solid var(--border-subtle);
}
.btn-ghost:hover { border-color: var(--accent-blue); color: var(--accent-blue); }
.hero-stats { display: flex; align-items: center; gap: 1.5rem; }
.stat { display: flex; flex-direction: column; gap: 2px; }
.stat-num { font-size: 1.5rem; font-weight: 800; color: var(--text-primary); line-height: 1; }
.stat-label { font-size: 0.7rem; color: var(--text-muted); text-transform: uppercase; letter-spacing: 0.06em; }
.stat-divider { width: 1px; height: 2rem; background: var(--border-subtle); }

/* Hero Visual */
.hero-visual { position: relative; }
.hero-glow {
  position: absolute;
  inset: -20%;
  background: radial-gradient(ellipse at center, rgba(99,179,237,0.12) 0%, transparent 70%);
  pointer-events: none;
  z-index: 0;
}
.code-block {
  position: relative;
  z-index: 1;
  background: rgba(13,17,23,0.85);
  border: 1px solid var(--border-glow);
  border-radius: 12px;
  padding: 1.5rem 1.75rem;
  font-family: var(--font-mono);
  font-size: 0.82rem;
  line-height: 1.9;
  backdrop-filter: blur(8px);
  box-shadow: var(--glow-blue);
}
.code-line { white-space: pre; }
.c-comment { color: #4a5568; }
.c-keyword  { color: #c792ea; }
.c-var      { color: #82aaff; }
.c-fn       { color: #82cfff; }
.c-string   { color: #c3e88d; }
.c-op       { color: #89ddff; }
.c-paren    { color: #a9b1d6; }
.c-dim      { opacity: 0.3; }

/* ---- Timeline ---- */
.timeline-section, .devkit-section, .featured-section {
  max-width: 1100px;
  margin: 0 auto;
  padding: 3rem 1.5rem;
}
.section-heading {
  font-size: clamp(1.5rem, 3vw, 2rem);
  font-weight: 800;
  color: var(--text-primary);
  letter-spacing: -0.02em;
  margin-bottom: 0.4rem;
}
.section-sub {
  font-size: 0.92rem;
  color: var(--text-muted);
  margin-bottom: 2.5rem;
}
.inline-link { color: var(--accent-blue); text-decoration: none; }
.inline-link:hover { text-decoration: underline; }
.timeline { display: flex; flex-direction: column; gap: 0; padding-left: 1.5rem; border-left: 2px solid var(--border-glow); }
.timeline-item { position: relative; padding: 0 0 2.5rem 1.75rem; }
.timeline-dot {
  position: absolute;
  left: -9px;
  top: 5px;
  width: 14px;
  height: 14px;
  border-radius: 50%;
  border: 2px solid var(--bg-base);
}
.dot-blue   { background: var(--accent-blue); box-shadow: 0 0 8px var(--accent-blue); }
.dot-orange { background: #fb923c; box-shadow: 0 0 8px #fb923c; }
.dot-green  { background: #4ade80; box-shadow: 0 0 8px #4ade80; }
.timeline-era { font-size: 0.72rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.1em; color: var(--accent-blue); margin-bottom: 0.3rem; opacity: 0.8; }
.timeline-title { font-size: 1.05rem; font-weight: 700; color: var(--text-primary); margin: 0 0 0.4rem; }
.timeline-text { font-size: 0.88rem; color: var(--text-muted); line-height: 1.65; margin: 0; max-width: 560px; }

/* ---- Dev Kit ---- */
.devkit-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(220px, 1fr)); gap: 1.5rem; }
.kit-group { display: flex; flex-direction: column; gap: 0.5rem; }
.kit-group-label { font-size: 0.7rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.1em; color: var(--text-muted); }
.kit-chips { display: flex; flex-wrap: wrap; gap: 0.4rem; }
.kit-chip {
  font-size: 0.78rem; font-weight: 600;
  padding: 4px 12px; border-radius: 20px;
  background: rgba(30,41,59,0.8);
  color: var(--text-secondary);
  border: 1px solid var(--border-subtle);
  transition: border-color 0.2s, color 0.2s;
}
.kit-chip:hover { border-color: var(--accent-blue); color: var(--accent-blue); }

/* ---- Featured ---- */
.featured-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(320px, 1fr)); gap: 1.25rem; }

/* ---- Responsive ---- */
@media (max-width: 768px) {
  .hero { grid-template-columns: 1fr; gap: 2rem; padding: 3rem 1rem 2rem; }
  .hero-visual { display: none; }
  .hero-stats { gap: 1rem; }
  .featured-grid { grid-template-columns: 1fr; }
  .devkit-grid { grid-template-columns: 1fr 1fr; }
}
@media (max-width: 480px) {
  .devkit-grid { grid-template-columns: 1fr; }
  .hero-stats { flex-wrap: wrap; }
}
</style>
