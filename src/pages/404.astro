---
import BaseLayout from '../layouts/BaseLayout.astro';
---
<BaseLayout title="Page Not Found — Nate Cowperthwaite" description="This page doesn't exist, but the rest of the portfolio does.">
  <main id="main-content">
    <div class="not-found">
      <div class="nf-code" aria-hidden="true">404</div>
      <h1 class="nf-heading">Wrong kitchen.</h1>
      <p class="nf-body">
        That page doesn't exist — either the URL is wrong or something
        moved. Either way, you can find everything from the links below.
      </p>
      <nav class="nf-nav" aria-label="Return navigation">
        <a href="/" class="btn btn-primary">Home</a>
        <a href="/dev" class="btn btn-ghost">Developer</a>
        <a href="/food" class="btn btn-ember">Chef</a>
        <a href="/contact" class="btn btn-ghost">Contact</a>
      </nav>
    </div>
  </main>
</BaseLayout>

<style>
.not-found {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  min-height: calc(100vh - 120px);
  text-align: center;
  padding: var(--space-12) var(--space-6);
  gap: var(--space-6);
}

.nf-code {
  font-size: clamp(5rem, 20vw, 10rem);
  font-weight: 900;
  letter-spacing: -0.05em;
  line-height: 1;
  background: linear-gradient(
    135deg,
    var(--accent-blue) 0%,
    var(--accent-indigo) 50%,
    var(--accent-ember) 100%
  );
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
  user-select: none;
}

.nf-heading {
  font-size: clamp(1.5rem, 4vw, 2.5rem);
  font-weight: 800;
  color: var(--text-primary);
  letter-spacing: -0.03em;
}

.nf-body {
  max-width: 42ch;
  font-size: 1rem;
  color: var(--text-muted);
  line-height: 1.7;
}

.nf-nav {
  display: flex;
  flex-wrap: wrap;
  gap: var(--space-3);
  justify-content: center;
  margin-top: var(--space-2);
}
</style>
