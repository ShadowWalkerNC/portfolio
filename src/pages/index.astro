---
import BaseLayout from '../layouts/BaseLayout.astro';
---
<BaseLayout title="Nate Cowperthwaite" description="Professional chef and self-taught developer. Two distinct crafts, one person building them both.">
  <main class="split-page">

    <!-- Brand lockup centered over both halves -->
    <div class="split-brand animate-slide-down">
      <span class="split-brand-name">Nate Cowperthwaite</span>
      <span class="split-brand-tag">Two crafts. One person.</span>
    </div>

    <!-- DEV HALF -->
    <a href="/dev" class="split-half split-dev" aria-label="Enter Developer portfolio">
      <div class="split-inner">
        <div class="split-icon">&#128187;</div>
        <h2 class="split-title split-title-dev">Developer</h2>
        <p class="split-desc">Self-taught. Problem-driven. Built from real kitchen friction.</p>
        <div class="split-chips">
          <span class="split-chip chip-dev">Astro</span>
          <span class="split-chip chip-dev">Python</span>
          <span class="split-chip chip-dev">MCP</span>
          <span class="split-chip chip-dev">AI APIs</span>
        </div>
        <span class="split-cta">Enter &rarr;</span>
      </div>
      <div class="split-bg-dev" aria-hidden="true"></div>
    </a>

    <!-- FOOD HALF -->
    <a href="/food" class="split-half split-food" aria-label="Enter Chef portfolio">
      <div class="split-inner">
        <div class="split-icon">&#127859;</div>
        <h2 class="split-title split-title-food">Chef</h2>
        <p class="split-desc">10+ years in Maine kitchens. Scratch cooking, real leadership, earned craft.</p>
        <div class="split-chips">
          <span class="split-chip chip-food">Scratch Cooking</span>
          <span class="split-chip chip-food">Sous Chef</span>
          <span class="split-chip chip-food">Menu Dev</span>
          <span class="split-chip chip-food">Maine</span>
        </div>
        <span class="split-cta">Enter &rarr;</span>
      </div>
      <div class="split-bg-food" aria-hidden="true"></div>
    </a>

  </main>
</BaseLayout>

<style>
/* ---- Split Layout ---- */
.split-page {
  display: flex;
  height: calc(100vh - 60px);
  position: relative;
  overflow: hidden;
}

/* Centered brand over both halves */
.split-brand {
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  z-index: 20;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 0.3rem;
  pointer-events: none;
  text-align: center;
}
.split-brand-name {
  font-size: clamp(1.1rem, 2.5vw, 1.6rem);
  font-weight: 900;
  color: #ffffff;
  letter-spacing: -0.03em;
  text-shadow: 0 2px 16px rgba(0,0,0,0.45);
  white-space: nowrap;
}
.split-brand-tag {
  font-size: 0.72rem;
  font-weight: 600;
  text-transform: uppercase;
  letter-spacing: 0.14em;
  color: rgba(255,255,255,0.65);
}

/* Halves */
.split-half {
  flex: 1;
  position: relative;
  display: flex;
  align-items: center;
  justify-content: center;
  overflow: hidden;
  cursor: pointer;
  text-decoration: none;
  transition: flex 0.45s cubic-bezier(0.4, 0, 0.2, 1);
}
/* Desktop hover expansion */
@media (hover: hover) {
  .split-half:hover { flex: 1.45; }
  .split-page:has(.split-dev:hover)  .split-food { flex: 0.6; }
  .split-page:has(.split-food:hover) .split-dev  { flex: 0.6; }
}

/* Backgrounds */
.split-dev  { background: linear-gradient(135deg, #1e3a5f 0%, #1e40af 50%, #2563eb 100%); }
.split-food { background: linear-gradient(135deg, #7c2d12 0%, #c2410c 50%, #f97316 100%); }

.split-bg-dev, .split-bg-food {
  position: absolute;
  inset: 0;
  opacity: 0;
  transition: opacity 0.45s ease;
}
@media (hover: hover) {
  .split-dev:hover  .split-bg-dev  { opacity: 1; }
  .split-food:hover .split-bg-food { opacity: 1; }
}
.split-bg-dev  { background: radial-gradient(ellipse at center, rgba(99,179,237,0.15), transparent 70%); }
.split-bg-food { background: radial-gradient(ellipse at center, rgba(253,186,116,0.15), transparent 70%); }

/* Content */
.split-inner {
  position: relative;
  z-index: 10;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 0.75rem;
  padding: 2rem;
  text-align: center;
  transition: transform 0.3s ease;
}
@media (hover: hover) {
  .split-half:hover .split-inner { transform: scale(1.03); }
}

.split-icon {
  font-size: 3rem;
  line-height: 1;
  filter: drop-shadow(0 4px 12px rgba(0,0,0,0.3));
  animation: float 3.5s ease-in-out infinite;
}
.split-food .split-icon { animation-delay: 0.8s; }

.split-title {
  font-size: clamp(2rem, 5vw, 3.2rem);
  font-weight: 900;
  letter-spacing: -0.04em;
  line-height: 1;
  color: #ffffff;
  text-shadow: 0 2px 20px rgba(0,0,0,0.25);
}

.split-desc {
  font-size: 0.9rem;
  color: rgba(255,255,255,0.75);
  max-width: 220px;
  line-height: 1.5;
}

/* Chips: hidden on desktop until hover, always shown on touch devices */
.split-chips {
  display: flex;
  flex-wrap: wrap;
  gap: 0.4rem;
  justify-content: center;
  opacity: 0;
  transform: translateY(8px);
  transition: opacity 0.3s ease 0.05s, transform 0.3s ease 0.05s;
}
@media (hover: hover) {
  .split-half:hover .split-chips { opacity: 1; transform: translateY(0); }
}
@media (hover: none) {
  .split-chips, .split-cta { opacity: 1 !important; transform: none !important; }
}
.split-chip {
  font-size: 0.7rem;
  font-weight: 700;
  padding: 0.2rem 0.6rem;
  border-radius: var(--radius-full);
  letter-spacing: 0.04em;
  text-transform: uppercase;
}
.chip-dev  { background: rgba(255,255,255,0.15); color: #bfdbfe; border: 1px solid rgba(255,255,255,0.2); }
.chip-food { background: rgba(255,255,255,0.15); color: #fed7aa; border: 1px solid rgba(255,255,255,0.2); }

.split-cta {
  font-size: 0.88rem;
  font-weight: 700;
  color: rgba(255,255,255,0.6);
  letter-spacing: 0.06em;
  opacity: 0;
  transform: translateY(6px);
  transition: opacity 0.3s ease 0.1s, transform 0.3s ease 0.1s;
}
@media (hover: hover) {
  .split-half:hover .split-cta { opacity: 1; transform: translateY(0); color: rgba(255,255,255,0.95); }
}

/* Vertical divider line */
.split-page::after {
  content: '';
  position: absolute;
  top: 10%;
  bottom: 10%;
  left: 50%;
  width: 1px;
  background: rgba(255,255,255,0.2);
  pointer-events: none;
  z-index: 15;
  transition: left 0.45s cubic-bezier(0.4, 0, 0.2, 1);
}

/* Mobile: stack vertically */
@media (max-width: 640px) {
  .split-page {
    flex-direction: column;
    height: auto;
    min-height: calc(100vh - 60px);
  }
  .split-half {
    flex: none;
    min-height: 48vh;
    transition: none;
  }
  .split-page::after { display: none; }

  /* Keep brand absolutely positioned over the stacked layout.
     On mobile the page is taller than the viewport, so we anchor
     it to the top of the first panel instead of mid-page. */
  .split-brand {
    top: 24vh;
    left: 50%;
    transform: translateX(-50%);
    width: max-content;
    max-width: 90vw;
  }

  .split-brand-name { color: white; }
  .split-icon { font-size: 2.4rem; }
  .split-title { font-size: clamp(1.6rem, 8vw, 2.4rem); }
  .split-desc { font-size: 0.82rem; }
}

@keyframes float {
  0%, 100% { transform: translateY(0); }
  50%       { transform: translateY(-7px); }
}

@media (prefers-reduced-motion: reduce) {
  .split-icon { animation: none; }
}
</style>
