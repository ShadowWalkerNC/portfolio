---
import BaseLayout from '../layouts/BaseLayout.astro';
import ProjectCard from '../components/ProjectCard.astro';
import EcosystemBanner from '../components/EcosystemBanner.astro';
import { getCollection } from 'astro:content';

const all = await getCollection('projects');

// Culinary Ecosystem group
const ecosystemProjects = all.filter(p => p.data.group === 'culinary-ecosystem');

// Shoreline group
const shorelineProjects = all.filter(p => p.data.group === 'shoreline');

// Standalone food-tech (not in ecosystem)
const standaloneFoodTech = all.filter(p => p.data.category === 'food-tech' && !p.data.group);

// Dev tools
const devTools = all.filter(p => p.data.category === 'dev-tools');

// Experimental
const experimental = all.filter(p => p.data.category === 'experimental');
---

<BaseLayout title="Projects — Nate Cowperthwaite" description="All projects by Nate Cowperthwaite — food tech, facility ops, dev tools, and experimental work.">
  <div class="max-w-6xl mx-auto px-6 pt-28 pb-24">

    <p class="font-mono text-xs uppercase tracking-widest mb-3" style="color: var(--blue-vivid);">All Work</p>
    <h1 class="text-5xl font-extrabold mb-4 text-gradient-blue-white">Projects</h1>
    <p class="text-lg mb-3 max-w-2xl" style="color: var(--text-subtle);">
      Two worlds. One portfolio.
    </p>
    <p class="text-sm mb-4 max-w-2xl" style="color: var(--text-muted);">
      Every project here comes from a problem I've personally lived with — as a cook, as an operator, or as a developer. Some are food-tech. Some are dev infrastructure. A few are experiments that had no business existing. All of them are real.
    </p>
    <p class="text-sm mb-10 max-w-2xl" style="color: var(--text-muted);">
      Click <span class="font-mono text-xs px-1.5 py-0.5 rounded" style="background: rgba(14,165,233,0.15); color: #7DD3FC;">Story · Who It's For · Details</span> on any card to expand it — you'll see the full story behind the project, who it's built for, and how it works technically.
    </p>

    <hr class="section-divider mb-16" />

    <!-- CULINARY ECOSYSTEM -->
    {ecosystemProjects.length > 0 && (
      <section class="mb-24">
        <EcosystemBanner
          icon="🍽️"
          title="The Culinary Ecosystem"
          subtitle="CulinaryOS, KitchenKit, and CulinaryOps are three connected products built for food service — from the recipe level to the business level. Use any one standalone, or run all three together for a fully integrated, AI-native kitchen operating system. All three share a common data layer and connect via MCP servers so any AI assistant can query live kitchen data across the whole stack. This is the core of what I'm building — and it all runs live in Half Baked Café & Bakehouse when we open in 2027."
        />
        <div class="ecosystem-connector">
          <span class="connector-label">🍳 KitchenKit (recipes + prep) → 🌐 CulinaryOS (operations hub) → 📊 CulinaryOps (analytics + cost)</span>
          <span class="connector-line"></span>
        </div>
        <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-6 stagger-children">
          {ecosystemProjects.map(p => <ProjectCard project={p} />)}
        </div>
        <div class="mcp-note">
          <span class="mcp-note-icon">🤖</span>
          <p>All three products expose <strong>MCP servers</strong> — Model Context Protocol, the standard for connecting AI models to live data. This means a chef can ask an AI assistant in plain English: <em>"What's my food cost this week?"</em> or <em>"Scale this recipe to 150 portions"</em> — and get a real answer from live data, not a canned response.</p>
        </div>
      </section>
    )}

    <hr class="section-divider mb-20" />

    <!-- STANDALONE FOOD TECH -->
    {standaloneFoodTech.length > 0 && (
      <section class="mb-24">
        <p class="font-mono text-xs uppercase tracking-widest mb-2" style="color: var(--blue-vivid);">Food & Beverage</p>
        <h2 class="text-2xl font-bold mb-2" style="color: #D4EAF7;">🚀 Standalone Food Tech</h2>
        <p class="text-sm mb-8" style="color: var(--text-muted);">Food & beverage products that stand on their own — not part of the main ecosystem.</p>
        <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-6 stagger-children">
          {standaloneFoodTech.map(p => <ProjectCard project={p} />)}
        </div>
      </section>
    )}

    <hr class="section-divider mb-20" />

    <!-- SHORELINE -->
    {shorelineProjects.length > 0 && (
      <section class="mb-24">
        <EcosystemBanner
          icon="🏠"
          title="Shoreline Platform"
          subtitle="Operations software for senior living facilities — built from direct experience working as a dietary manager where resident dietary data lived in a three-ring binder. v4 is stable and has been used in a real facility. v5 is the full ground-up SaaS rebuild: multi-tenant, cloud-based, and everything v4 should have been."
        />
        <div class="grid sm:grid-cols-2 gap-6 stagger-children">
          {shorelineProjects.map(p => <ProjectCard project={p} />)}
        </div>
      </section>
    )}

    <hr class="section-divider mb-20" />

    <!-- DEV TOOLS -->
    {devTools.length > 0 && (
      <section class="mb-24">
        <p class="font-mono text-xs uppercase tracking-widest mb-2" style="color: var(--blue-vivid);">Dev Platforms</p>
        <h2 class="text-2xl font-bold mb-2" style="color: #D4EAF7;">🧱 Dev Tools & Platforms</h2>
        <p class="text-sm mb-8" style="color: var(--text-muted);">Tools built for developers — infrastructure, CMS, and platforms that power other projects.</p>
        <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-6 stagger-children">
          {devTools.map(p => <ProjectCard project={p} />)}
        </div>
      </section>
    )}

    <hr class="section-divider mb-20" />

    <!-- EXPERIMENTAL -->
    {experimental.length > 0 && (
      <section class="mb-8">
        <p class="font-mono text-xs uppercase tracking-widest mb-2" style="color: var(--blue-vivid);">Lab Work</p>
        <h2 class="text-2xl font-bold mb-2" style="color: #D4EAF7;">⚙️ Experimental & Engine Work</h2>
        <p class="text-sm mb-8" style="color: var(--text-muted);">The sketchbook. Prototypes, experiments, and things built to see if they were possible — not because they needed to exist.</p>
        <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-6 stagger-children">
          {experimental.map(p => <ProjectCard project={p} />)}
        </div>
      </section>
    )}

  </div>
</BaseLayout>

<style>
  .ecosystem-connector {
    display: flex;
    align-items: center;
    gap: 1rem;
    margin-bottom: 1.5rem;
    padding: 0 0.25rem;
  }

  .connector-label {
    font-family: 'Fira Code', monospace;
    font-size: 0.68rem;
    color: var(--blue-primary);
    white-space: nowrap;
    opacity: 0.75;
  }

  .connector-line {
    flex: 1;
    height: 1px;
    background: linear-gradient(90deg, rgba(14,165,233,0.35), transparent);
  }

  .mcp-note {
    display: flex;
    gap: 0.85rem;
    align-items: flex-start;
    margin-top: 1.25rem;
    padding: 1rem 1.25rem;
    background: rgba(14, 165, 233, 0.06);
    border: 1px solid rgba(14, 165, 233, 0.18);
    border-radius: 10px;
  }

  .mcp-note-icon {
    font-size: 1.1rem;
    flex-shrink: 0;
    margin-top: 0.1rem;
  }

  .mcp-note p {
    font-size: 0.78rem;
    line-height: 1.65;
    color: var(--text-body);
  }

  .mcp-note strong {
    color: #7DD3FC;
    font-weight: 600;
  }

  .mcp-note em {
    color: #A5C8E4;
    font-style: italic;
  }
</style>
