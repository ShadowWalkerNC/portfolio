---
import BaseLayout from '../layouts/BaseLayout.astro';
---
<BaseLayout title="Nate Cowperthwaite" description="Professional chef and self-taught developer. Two distinct crafts, one person building them both.">
  <main class="split-page">

    <!-- Brand lockup centered over both halves (desktop only) -->
    <div class="split-brand animate-slide-down" aria-hidden="true">
      <span class="split-brand-name">Nate Cowperthwaite</span>
      <span class="split-brand-tag">Two crafts. One person.</span>
    </div>

    <!-- DEV HALF -->
    <a href="/dev" class="split-half split-dev split-enter-left" aria-label="Enter Developer portfolio">
      <div class="split-inner">
        <!-- Mobile-only name shown inline in flow -->
        <div class="split-mobile-name">
          <span class="split-brand-name">Nate Cowperthwaite</span>
          <span class="split-brand-tag">Two crafts. One person.</span>
        </div>
        <div class="split-icon">&#128187;</div>
        <h2 class="split-title split-title-dev">Developer</h2>
        <p class="split-desc">Self-taught. Problem-driven. Built from real kitchen friction.</p>
        <div class="split-chips">
          <span class="split-chip chip-dev">Astro</span>
          <span class="split-chip chip-dev">Python</span>
          <span class="split-chip chip-dev">MCP</span>
          <span class="split-chip chip-dev">AI APIs</span>
        </div>
        <span class="split-cta">Enter &rarr;</span>
      </div>
      <div class="split-bg-dev" aria-hidden="true"></div>
    </a>

    <!-- FOOD HALF -->
    <a href="/food" class="split-half split-food split-enter-right" aria-label="Enter Chef portfolio">
      <div class="split-inner">
        <div class="split-icon">&#127859;</div>
        <h2 class="split-title split-title-food">Chef</h2>
        <p class="split-desc">10+ years in Maine kitchens. Scratch cooking, real leadership, earned craft.</p>
        <div class="split-chips">
          <span class="split-chip chip-food">Scratch Cooking</span>
          <span class="split-chip chip-food">Sous Chef</span>
          <span class="split-chip chip-food">Menu Dev</span>
          <span class="split-chip chip-food">Maine</span>
        </div>
        <span class="split-cta">Enter &rarr;</span>
      </div>
      <div class="split-bg-food" aria-hidden="true"></div>
    </a>

  </main>
</BaseLayout>

<style>
/* ---- Split Layout ---- */
.split-page {
  display: flex;
  height: calc(100vh - 60px);
  position: relative;
  overflow: hidden;
}

/* Centered brand over both halves — desktop only */
.split-brand {
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  z-index: 20;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 0.3rem;
  pointer-events: none;
  text-align: center;
  animation-delay: 0.35s;
  animation-fill-mode: both;
  opacity: 0;
}
.split-brand-name {
  font-size: clamp(1.1rem, 2.5vw, 1.6rem);
  font-weight: 900;
  color: #ffffff;
  letter-spacing: -0.03em;
  text-shadow: 0 2px 16px rgba(0,0,0,0.45);
  white-space: nowrap;
}
.split-brand-tag {
  font-size: 0.72rem;
  font-weight: 600;
  text-transform: uppercase;
  letter-spacing: 0.14em;
  color: rgba(255,255,255,0.65);
}

/* Mobile inline name — hidden on desktop */
.split-mobile-name {
  display: none;
}

/* Panel entrance animations */
@keyframes splitEnterLeft {
  from { opacity: 0; transform: translateX(-40px); }
  to   { opacity: 1; transform: translateX(0); }
}
@keyframes splitEnterRight {
  from { opacity: 0; transform: translateX(40px); }
  to   { opacity: 1; transform: translateX(0); }
}

.split-enter-left {
  opacity: 0;
  animation: splitEnterLeft 0.55s cubic-bezier(0.16, 1, 0.3, 1) 0.05s forwards;
}
.split-enter-right {
  opacity: 0;
  animation: splitEnterRight 0.55s cubic-bezier(0.16, 1, 0.3, 1) 0.15s forwards;
}

/* Halves */
.split-half {
  flex: 1;
  position: relative;
  display: flex;
  align-items: center;
  justify-content: center;
  overflow: hidden;
  cursor: pointer;
  text-decoration: none;
  transition: flex 0.45s cubic-bezier(0.4, 0, 0.2, 1);
}
@media (hover: hover) {
  .split-half:hover { flex: 1.45; }
  .split-page:has(.split-dev:hover)  .split-food { flex: 0.6; }
  .split-page:has(.split-food:hover) .split-dev  { flex: 0.6; }
}

/* Backgrounds */
.split-dev  { background: linear-gradient(135deg, #1e3a5f 0%, #1e40af 50%, #2563eb 100%); }
.split-food { background: linear-gradient(135deg, #7c2d12 0%, #c2410c 50%, #f97316 100%); }

.split-bg-dev, .split-bg-food {
  position: absolute;
  inset: 0;
  opacity: 0;
  transition: opacity 0.45s ease;
}
@media (hover: hover) {
  .split-dev:hover  .split-bg-dev  { opacity: 1; }
  .split-food:hover .split-bg-food { opacity: 1; }
}
.split-bg-dev  { background: radial-gradient(ellipse at center, rgba(99,179,237,0.15), transparent 70%); }
.split-bg-food { background: radial-gradient(ellipse at center, rgba(253,186,116,0.15), transparent 70%); }

/* Content */
.split-inner {
  position: relative;
  z-index: 10;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 0.75rem;
  padding: 2rem;
  text-align: center;
  transition: transform 0.3s ease;
}
@media (hover: hover) {
  .split-half:hover .split-inner { transform: scale(1.03); }
}

/* Stagger fadeInUp for all inner children */
@keyframes fadeInUp {
  from { opacity: 0; transform: translateY(16px); }
  to   { opacity: 1; transform: translateY(0); }
}

.split-inner > * {
  opacity: 0;
  animation: fadeInUp 0.45s cubic-bezier(0.16, 1, 0.3, 1) forwards;
}

/* Dev panel — child delays */
.split-dev .split-inner > *:nth-child(1) { animation-delay: 0.30s; }
.split-dev .split-inner > *:nth-child(2) { animation-delay: 0.38s; }
.split-dev .split-inner > *:nth-child(3) { animation-delay: 0.44s; }
.split-dev .split-inner > *:nth-child(4) { animation-delay: 0.50s; }
.split-dev .split-inner > *:nth-child(5) { animation-delay: 0.55s; }

/* Food panel — child delays (offset slightly later) */
.split-food .split-inner > *:nth-child(1) { animation-delay: 0.38s; }
.split-food .split-inner > *:nth-child(2) { animation-delay: 0.46s; }
.split-food .split-inner > *:nth-child(3) { animation-delay: 0.52s; }
.split-food .split-inner > *:nth-child(4) { animation-delay: 0.58s; }
.split-food .split-inner > *:nth-child(5) { animation-delay: 0.63s; }

/* Icon: float continuously after fading in */
.split-icon {
  font-size: 3rem;
  line-height: 1;
  filter: drop-shadow(0 4px 12px rgba(0,0,0,0.3));
}

@keyframes float {
  0%, 100% { transform: translateY(0); }
  50%       { transform: translateY(-7px); }
}

.split-title {
  font-size: clamp(2rem, 5vw, 3.2rem);
  font-weight: 900;
  letter-spacing: -0.04em;
  line-height: 1;
  color: #ffffff;
  text-shadow: 0 2px 20px rgba(0,0,0,0.25);
}

.split-desc {
  font-size: 0.9rem;
  color: rgba(255,255,255,0.75);
  max-width: 220px;
  line-height: 1.5;
}

/*
  Chips: fade in via stagger (lands at opacity:1), then on desktop
  we dim them back down until hover. We use a post-animation class
  swap via a tiny JS trick — but simpler: just keep them visible
  and let hover brighten them.
*/
.split-chips {
  display: flex;
  flex-wrap: wrap;
  gap: 0.4rem;
  justify-content: center;
  /* chips visible by default after stagger; dim slightly on desktop at rest */
  opacity: 1;
  transform: none;
  transition: opacity 0.3s ease, transform 0.3s ease;
}
@media (hover: hover) {
  /* Dim at rest, brighten on hover */
  .split-chips { opacity: 0.35; }
  .split-half:hover .split-chips { opacity: 1; transform: translateY(0); }
}

.split-chip {
  font-size: 0.7rem;
  font-weight: 700;
  padding: 0.2rem 0.6rem;
  border-radius: var(--radius-full);
  letter-spacing: 0.04em;
  text-transform: uppercase;
}
.chip-dev  { background: rgba(255,255,255,0.15); color: #bfdbfe; border: 1px solid rgba(255,255,255,0.2); }
.chip-food { background: rgba(255,255,255,0.15); color: #fed7aa; border: 1px solid rgba(255,255,255,0.2); }

/* CTA: always visible after stagger, brightens on hover */
.split-cta {
  font-size: 0.88rem;
  font-weight: 700;
  letter-spacing: 0.06em;
  color: rgba(255,255,255,0.65);
  transition: color 0.25s ease, transform 0.25s ease;
  /* No opacity:0, no animation:none — stagger handles the entrance */
}
@media (hover: hover) {
  .split-half:hover .split-cta {
    color: #ffffff;
    transform: translateX(4px);
  }
}

/* Vertical divider line */
.split-page::after {
  content: '';
  position: absolute;
  top: 10%;
  bottom: 10%;
  left: 50%;
  width: 1px;
  background: rgba(255,255,255,0.2);
  pointer-events: none;
  z-index: 15;
  transition: left 0.45s cubic-bezier(0.4, 0, 0.2, 1);
}

/* Mobile: stack vertically */
@media (max-width: 640px) {
  .split-page {
    flex-direction: column;
    height: auto;
    min-height: calc(100vh - 60px);
    overflow: visible;
  }
  .split-half {
    flex: none;
    min-height: 48vh;
    transition: none;
  }
  .split-enter-left,
  .split-enter-right {
    animation-name: splitEnterMobile;
  }
  @keyframes splitEnterMobile {
    from { opacity: 0; transform: translateY(24px); }
    to   { opacity: 1; transform: translateY(0); }
  }
  .split-page::after { display: none; }
  .split-brand { display: none; }

  .split-mobile-name {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.2rem;
    padding-bottom: 0.5rem;
    border-bottom: 1px solid rgba(255,255,255,0.15);
    margin-bottom: 0.25rem;
    width: 100%;
  }
  .split-mobile-name .split-brand-name {
    font-size: 1.1rem;
    white-space: nowrap;
  }

  .split-icon { font-size: 2.4rem; }
  .split-title { font-size: clamp(1.6rem, 8vw, 2.4rem); }
  .split-desc { font-size: 0.82rem; }
  /* On touch: chips fully visible, CTA fully bright */
  .split-chips { opacity: 1; }
  .split-cta { color: rgba(255,255,255,0.9); }
}

@media (prefers-reduced-motion: reduce) {
  .split-enter-left,
  .split-enter-right,
  .split-brand,
  .split-inner > * {
    animation: none !important;
    opacity: 1 !important;
    transform: none !important;
  }
  .split-icon { animation: none !important; }
}
</style>
