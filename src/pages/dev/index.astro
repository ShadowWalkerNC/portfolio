---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ProjectCard from '../../components/ProjectCard.astro';
import { getCollection } from 'astro:content';

const projects = await getCollection('projects');
const featured = projects.filter(p => p.data.featured).slice(0, 3);
---

<BaseLayout title="Nate Cowperthwaite — Developer" description="Agentic coding, AI tools, and API-driven software built by a professional chef who started coding in 2025." side="dev">
  <main>

    <!-- ===== HERO ===== -->
    <section class="hero">
      <div class="hero-content animate-fade-in-up">
        <div class="hero-kicker">
          <span class="badge badge-blue">&#128187; Developer Portfolio</span>
        </div>
        <h1 class="hero-title">
          Software built by someone<br />
          <span class="hero-accent-blue">who lived</span>
          <span class="hero-accent-ember"> the problem.</span>
        </h1>
        <p class="hero-subtitle">
          Professional chef. Side-project developer since 2025.
          I started coding because no one was building the tools kitchens actually need &mdash;
          so I built them myself using agentic workflows, AI tools, and modern APIs.
        </p>
        <div class="hero-actions">
          <a href="/dev/projects" class="btn btn-primary">See the Work</a>
          <a href="/dev/contact" class="btn btn-ghost">Get in Touch</a>
        </div>
        <div class="hero-stats">
          <div class="stat"><span class="stat-num">10+</span><span class="stat-label">Projects Shipped</span></div>
          <div class="stat-divider"></div>
          <div class="stat"><span class="stat-num stat-ember">3</span><span class="stat-label">Culinary Tech Apps</span></div>
          <div class="stat-divider"></div>
          <div class="stat"><span class="stat-num">2025</span><span class="stat-label">Started Coding</span></div>
        </div>
      </div>
      <div class="hero-visual" aria-hidden="true">
        <div class="code-block animate-scale-in">
          <div class="code-line"><span class="c-comment">// chef who codes</span></div>
          <div class="code-line">&nbsp;</div>
          <div class="code-line"><span class="c-keyword">const</span> <span class="c-var">nate</span> <span class="c-op">=</span> <span class="c-paren">{</span></div>
          <div class="code-line">&nbsp; <span class="c-prop">craft</span><span class="c-op">:</span>   <span class="c-ember">'culinary'</span><span class="c-op">,</span></div>
          <div class="code-line">&nbsp; <span class="c-prop">coding</span><span class="c-op">:</span>  <span class="c-string">'2025-present'</span><span class="c-op">,</span></div>
          <div class="code-line">&nbsp; <span class="c-prop">style</span><span class="c-op">:</span>   <span class="c-string">'agentic'</span><span class="c-op">,</span></div>
          <div class="code-line">&nbsp; <span class="c-prop">tools</span><span class="c-op">:</span>   <span class="c-string">'AI + APIs'</span></div>
          <div class="code-line"><span class="c-paren">};</span></div>
          <div class="code-line">&nbsp;</div>
          <div class="code-line"><span class="c-keyword">function</span> <span class="c-fn">solve</span><span class="c-paren">(</span><span class="c-var">problem</span><span class="c-paren">) {</span></div>
          <div class="code-line">&nbsp; <span class="c-comment">// lived it first.</span></div>
          <div class="code-line">&nbsp; <span class="c-keyword">return</span> <span class="c-fn">ship</span><span class="c-paren">(</span><span class="c-var">solution</span><span class="c-paren">);</span></div>
          <div class="code-line"><span class="c-paren">}</span></div>
        </div>
      </div>
    </section>

    <div class="divider-fusion"></div>

    <!-- ===== JOURNEY TIMELINE ===== -->
    <section class="section">
      <h2 class="section-heading reveal">The Journey</h2>
      <p class="section-sub reveal">A decade in professional kitchens &mdash; and one side project that grew from all of it.</p>
      <div class="timeline">

        <div class="timeline-item reveal-left">
          <div class="timeline-dot dot-blue"></div>
          <div class="timeline-content">
            <div class="timeline-era">2014 &mdash; First Kitchen Role</div>
            <h3 class="timeline-title">Samoset Resort, Rockport ME</h3>
            <p class="timeline-text">Premier Maine coastal resort. First major culinary role — banquet, hospitality, and the discipline of a real kitchen. Where the foundation was laid.</p>
          </div>
        </div>

        <div class="timeline-item reveal-left">
          <div class="timeline-dot dot-ember"></div>
          <div class="timeline-content">
            <div class="timeline-era era-ember">2019–2022 &mdash; Rising Through the Ranks</div>
            <h3 class="timeline-title">Boynton McKay → Ports of Italy → Daddy B’s</h3>
            <p class="timeline-text">Scratch breakfast at an iconic Maine café, sous chef at Italian fine dining, then sous chef on a food truck &mdash; the role that directly sparked Northern Fixin’s. Each step added technique, leadership, and clarity about what kitchens were missing.</p>
          </div>
        </div>

        <div class="timeline-item reveal-left">
          <div class="timeline-dot dot-ember"></div>
          <div class="timeline-content">
            <div class="timeline-era era-ember">2023–Present &mdash; Co-Founder</div>
            <h3 class="timeline-title">Northern Fixin’s / Half Baked Co.</h3>
            <p class="timeline-text">Co-founded a Maine-inspired elevated café, scratch bakehouse, and food truck concept. Brick-and-mortar café targeting 2027. Still actively cooking and running kitchen operations at Ross Manor.</p>
          </div>
        </div>

        <div class="timeline-item reveal-left timeline-branch">
          <div class="timeline-dot dot-blue dot-branch"></div>
          <div class="timeline-content">
            <div class="timeline-era">2025–Present &mdash; Side Project</div>
            <h3 class="timeline-title">Developer <span class="timeline-branch-tag">Branch</span></h3>
            <p class="timeline-text">Started coding in 2025 using agentic workflows, AI tools, and APIs. Built CulinaryOS, KitchenKit, CulinaryOps, and more &mdash; every project rooted in real kitchen problems. Still cooking full-time; this is a side project that got serious.</p>
          </div>
        </div>

      </div>
    </section>

    <div class="divider"></div>

    <!-- ===== DEV KIT ===== -->
    <section class="section" id="devkit">
      <h2 class="section-heading reveal">The Dev Kit</h2>
      <p class="section-sub reveal">Tools I use to ship production software.</p>

      <div class="devkit-grid">

        <!-- Languages -->
        <div class="kit-card reveal">
          <div class="kit-card-header">
            <span class="kit-icon kit-icon-blue">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="16 18 22 12 16 6"/><polyline points="8 6 2 12 8 18"/></svg>
            </span>
            <span class="kit-label">Languages</span>
          </div>
          <div class="kit-chips">
            <span class="kit-chip" style="--i:0">JavaScript</span>
            <span class="kit-chip" style="--i:1">Python</span>
            <span class="kit-chip" style="--i:2">TypeScript</span>
            <span class="kit-chip" style="--i:3">HTML / CSS</span>
            <span class="kit-chip" style="--i:4">SQL</span>
          </div>
        </div>

        <!-- Frameworks -->
        <div class="kit-card reveal">
          <div class="kit-card-header">
            <span class="kit-icon kit-icon-blue">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="2" y="3" width="20" height="14" rx="2"/><line x1="8" y1="21" x2="16" y2="21"/><line x1="12" y1="17" x2="12" y2="21"/></svg>
            </span>
            <span class="kit-label">Frameworks</span>
          </div>
          <div class="kit-chips">
            <span class="kit-chip" style="--i:0">Astro</span>
            <span class="kit-chip" style="--i:1">Flask</span>
            <span class="kit-chip" style="--i:2">Node.js</span>
            <span class="kit-chip" style="--i:3">Discord.js</span>
            <span class="kit-chip" style="--i:4">Tailwind CSS</span>
            <span class="kit-chip" style="--i:5">React</span>
          </div>
        </div>

        <!-- Data & Infra -->
        <div class="kit-card reveal">
          <div class="kit-card-header">
            <span class="kit-icon kit-icon-blue">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><ellipse cx="12" cy="5" rx="9" ry="3"/><path d="M3 5v14c0 1.66 4.03 3 9 3s9-1.34 9-3V5"/><path d="M3 12c0 1.66 4.03 3 9 3s9-1.34 9-3"/></svg>
            </span>
            <span class="kit-label">Data &amp; Infra</span>
          </div>
          <div class="kit-chips">
            <span class="kit-chip" style="--i:0">PostgreSQL</span>
            <span class="kit-chip" style="--i:1">SQLite</span>
            <span class="kit-chip" style="--i:2">Supabase</span>
            <span class="kit-chip" style="--i:3">Railway</span>
            <span class="kit-chip" style="--i:4">Render</span>
          </div>
        </div>

        <!-- AI & APIs -->
        <div class="kit-card reveal">
          <div class="kit-card-header">
            <span class="kit-icon kit-icon-blue">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 2a4 4 0 0 1 4 4v1h1a3 3 0 0 1 0 6h-1v1a4 4 0 0 1-8 0v-1H7a3 3 0 0 1 0-6h1V6a4 4 0 0 1 4-4Z"/><circle cx="12" cy="10" r="2"/></svg>
            </span>
            <span class="kit-label">AI &amp; APIs</span>
          </div>
          <div class="kit-chips">
            <span class="kit-chip" style="--i:0">MCP</span>
            <span class="kit-chip" style="--i:1">Google Gemini</span>
            <span class="kit-chip" style="--i:2">Discord API</span>
            <span class="kit-chip" style="--i:3">Meta Graph API</span>
            <span class="kit-chip" style="--i:4">Twitter API v2</span>
          </div>
        </div>

      </div>
    </section>

    <div class="divider"></div>

    <!-- ===== FEATURED PROJECTS ===== -->
    <section class="section">
      <h2 class="section-heading reveal">Featured Work</h2>
      <p class="section-sub reveal">A handful of projects that show the range. <a href="/dev/projects" class="inline-link">See everything &rarr;</a></p>
      <div class="featured-grid">
        {featured.map(p => (
          <ProjectCard
            id={p.id}
            title={p.data.title}
            tagline={p.data.tagline}
            description={p.data.description}
            story={p.data.story}
            forWho={p.data.forWho}
            tags={p.data.tags}
            stack={p.data.stack}
            status={p.data.status}
            links={p.data.links}
            detailedSpecs={p.data.detailedSpecs}
          />
        ))}
      </div>
    </section>

  </main>
</BaseLayout>

<!-- ===== SCROLL REVEAL + STAGGER OBSERVER ===== -->
<script>
  (function () {
    // Targets: reveal, reveal-left, reveal-right
    const revealEls = document.querySelectorAll('.reveal, .reveal-left, .reveal-right');
    if (!revealEls.length) return;

    const io = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (!entry.isIntersecting) return;
          const el = entry.target;
          el.classList.add('is-visible');

          // Stagger chips inside kit-card that just became visible
          if (el.classList.contains('kit-card')) {
            el.querySelectorAll('.kit-chip').forEach((chip, idx) => {
              (chip as HTMLElement).style.transitionDelay = `${0.12 + idx * 0.06}s`;
              chip.classList.add('chip-visible');
            });
          }

          io.unobserve(el);
        });
      },
      { threshold: 0.12 }
    );

    revealEls.forEach((el) => io.observe(el));
  })();
</script>

<style>
/* ============================================================
   SCROLL REVEAL — base hidden states + visible transitions
   ============================================================ */
.reveal {
  opacity: 0;
  transform: translateY(22px);
  transition: opacity 0.55s ease, transform 0.55s ease;
}
.reveal-left {
  opacity: 0;
  transform: translateX(-24px);
  transition: opacity 0.55s ease, transform 0.55s ease;
}
.reveal-right {
  opacity: 0;
  transform: translateX(24px);
  transition: opacity 0.55s ease, transform 0.55s ease;
}
.reveal.is-visible,
.reveal-left.is-visible,
.reveal-right.is-visible {
  opacity: 1;
  transform: none;
}

/* Hero entry animations (run on load, no observer needed) */
@keyframes fadeInUp {
  from { opacity: 0; transform: translateY(28px); }
  to   { opacity: 1; transform: translateY(0); }
}
@keyframes scaleIn {
  from { opacity: 0; transform: scale(0.93); }
  to   { opacity: 1; transform: scale(1); }
}
@keyframes float {
  0%, 100% { transform: translateY(0);    }
  50%       { transform: translateY(-7px); }
}
.animate-fade-in-up  { animation: fadeInUp 0.65s ease both; }
.animate-scale-in    { animation: scaleIn  0.65s ease 0.2s both; }

/* ---- Hero ---- */
.hero {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 3rem;
  align-items: center;
  padding: 5rem 1.5rem 4rem;
  max-width: 1100px;
  margin: 0 auto;
}
.hero-kicker  { margin-bottom: 1rem; }
.hero-title {
  font-size: clamp(2rem, 4.5vw, 3.2rem);
  font-weight: 900;
  line-height: 1.1;
  color: var(--text-primary);
  letter-spacing: -0.03em;
  margin-bottom: 1.2rem;
}
.hero-accent-blue  { color: var(--accent-blue); }
.hero-accent-ember { color: var(--accent-ember); }
.hero-subtitle {
  font-size: 1rem;
  color: var(--text-muted);
  line-height: 1.7;
  margin-bottom: 2rem;
  max-width: 480px;
}
.hero-actions { display: flex; gap: 0.75rem; flex-wrap: wrap; margin-bottom: 2.5rem; }
.hero-stats   { display: flex; align-items: center; gap: 1.5rem; }
.stat { display: flex; flex-direction: column; gap: 2px; }
.stat-num {
  font-size: 1.5rem;
  font-weight: 800;
  color: var(--text-primary);
  line-height: 1;
}
.stat-num.stat-ember { color: var(--accent-ember); }
.stat-label {
  font-size: 0.68rem;
  color: var(--text-muted);
  text-transform: uppercase;
  letter-spacing: 0.06em;
}
.stat-divider { width: 1px; height: 2rem; background: var(--border-subtle); }

/* Code block */
.code-block {
  background: #0f172a;
  border: 1px solid #1e293b;
  border-radius: var(--radius-lg);
  padding: 1.5rem 1.75rem;
  font-family: var(--font-mono);
  font-size: 0.82rem;
  line-height: 1.9;
  box-shadow: var(--shadow-lg);
}
.code-line { white-space: pre; }
.c-comment { color: #4a5568; }
.c-keyword { color: #c792ea; }
.c-var     { color: #82aaff; }
.c-prop    { color: #82aaff; }
.c-fn      { color: #82cfff; }
.c-string  { color: #c3e88d; }
.c-ember   { color: var(--accent-ember); }
.c-op      { color: #89ddff; }
.c-paren   { color: #a9b1d6; }

/* ---- Timeline ---- */
.timeline {
  padding-left: 1.5rem;
  border-left: 2px solid var(--border-subtle);
  display: flex;
  flex-direction: column;
}
.timeline-item {
  position: relative;
  padding: 0 0 2.5rem 1.75rem;
}
.timeline-branch { margin-top: 0.5rem; }
.timeline-dot {
  position: absolute;
  left: -9px;
  top: 5px;
  width: 14px;
  height: 14px;
  border-radius: 50%;
  border: 2px solid var(--bg-base);
}
.dot-blue  { background: var(--accent-blue);  box-shadow: 0 0 0 3px var(--accent-blue-pale); }
.dot-ember { background: var(--accent-ember); box-shadow: 0 0 0 3px var(--accent-ember-pale); }
.dot-branch { border: 2px solid var(--accent-blue); background: white; }
/* Pulse on the active/branch dot */
@keyframes pulse-ring {
  0%   { box-shadow: 0 0 0 0 rgba(59,130,246,0.45); }
  70%  { box-shadow: 0 0 0 8px rgba(59,130,246,0); }
  100% { box-shadow: 0 0 0 0 rgba(59,130,246,0); }
}
.dot-branch.is-visible,
.timeline-item.is-visible .dot-branch {
  animation: pulse-ring 2s ease-out infinite;
}
.timeline-era {
  font-size: 0.72rem;
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: 0.1em;
  color: var(--accent-blue);
  margin-bottom: 0.3rem;
  opacity: 0.8;
}
.era-ember { color: var(--accent-ember) !important; }
.timeline-title {
  font-size: 1.05rem;
  font-weight: 700;
  color: var(--text-primary);
  margin: 0 0 0.4rem;
}
.timeline-text {
  font-size: 0.88rem;
  color: var(--text-muted);
  line-height: 1.65;
  margin: 0;
  max-width: 560px;
}
.timeline-branch-tag {
  font-size: 0.65rem;
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: 0.08em;
  background: var(--accent-blue-pale);
  color: var(--accent-blue);
  padding: 2px 8px;
  border-radius: var(--radius-full);
  vertical-align: middle;
  margin-left: 0.4rem;
}

/* ---- Dev Kit ---- */
.devkit-grid {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(240px, 1fr));
  gap: 1.25rem;
}
.kit-card {
  background: var(--bg-surface);
  border: 1px solid var(--border-subtle);
  border-radius: var(--radius-lg);
  padding: 1.25rem 1.25rem 1.4rem;
  display: flex;
  flex-direction: column;
  gap: 1rem;
  transition: border-color 0.2s, box-shadow 0.2s;
}
.kit-card:hover {
  border-color: var(--accent-blue);
  box-shadow: 0 0 0 3px var(--accent-blue-pale);
}
.kit-card-header {
  display: flex;
  align-items: center;
  gap: 0.6rem;
}
.kit-icon {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  width: 30px;
  height: 30px;
  border-radius: var(--radius-md);
  flex-shrink: 0;
}
.kit-icon-blue {
  background: var(--accent-blue-pale);
  color: var(--accent-blue);
  border: 1px solid color-mix(in srgb, var(--accent-blue) 20%, transparent);
}
.kit-label {
  font-size: 0.72rem;
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: 0.1em;
  color: var(--text-muted);
}
.kit-chips { display: flex; flex-wrap: wrap; gap: 0.35rem; }

/* Chips start hidden; JS adds chip-visible when the card enters viewport */
.kit-chip {
  font-size: 0.78rem;
  font-weight: 600;
  padding: 4px 12px;
  border-radius: var(--radius-full);
  background: var(--bg-card);
  color: var(--text-secondary);
  border: 1px solid var(--border-subtle);
  opacity: 0;
  transform: translateY(6px) scale(0.95);
  transition:
    opacity 0.3s ease,
    transform 0.3s ease,
    border-color 0.2s,
    color 0.2s,
    background 0.2s;
}
.kit-chip.chip-visible {
  opacity: 1;
  transform: none;
}
.kit-chip:hover {
  border-color: var(--accent-blue);
  color: var(--accent-blue);
  background: var(--accent-blue-pale);
  cursor: default;
}

/* Featured */
.featured-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(320px, 1fr)); gap: 1.25rem; }

/* ---- Responsive ---- */
@media (max-width: 768px) {
  .hero { grid-template-columns: 1fr; gap: 2rem; padding: 3rem 1rem 2rem; }
  .hero-visual { display: none; }
  .featured-grid { grid-template-columns: 1fr; }
  .devkit-grid { grid-template-columns: 1fr 1fr; }
}
@media (max-width: 480px) {
  .devkit-grid { grid-template-columns: 1fr; }
  .hero-stats  { flex-wrap: wrap; gap: 1rem; }
}

/* Respect prefers-reduced-motion */
@media (prefers-reduced-motion: reduce) {
  .reveal, .reveal-left, .reveal-right,
  .animate-fade-in-up, .animate-scale-in,
  .kit-chip { transition: none !important; animation: none !important; }
  .reveal, .reveal-left, .reveal-right { opacity: 1; transform: none; }
  .kit-chip { opacity: 1; transform: none; }
}
</style>
