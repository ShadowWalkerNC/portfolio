---
import '../styles/global.css';
const { title, description, side } = Astro.props;
// side: 'dev' | 'food' | undefined (neutral for landing)
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content={description ?? 'Nate Cowperthwaite — Chef & Developer'} />
  <title>{title ?? 'Nate Cowperthwaite'}</title>
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
</head>
<body data-side={side}>

  <!-- ===== NAV ===== -->
  <nav>
    <a href="/" class="nav-logo">
      <span class="nav-logo-name">Nate Cowperthwaite</span>
    </a>
    <div class="nav-links">
      {side === 'dev' && (
        <>
          <a href="/dev">Home</a>
          <a href="/dev/projects">Projects</a>
          <a href="/dev/contact">Contact</a>
          <a href="/food" class="nav-switch nav-switch-food">&#127859; Chef Side</a>
        </>
      )}
      {side === 'food' && (
        <>
          <a href="/food">Home</a>
          <a href="/dev" class="nav-switch nav-switch-dev">&#128187; Dev Side</a>
        </>
      )}
      {!side && (
        <>
          <a href="/dev" class="nav-switch nav-switch-dev">&#128187; Developer</a>
          <a href="/food" class="nav-switch nav-switch-food">&#127859; Chef</a>
        </>
      )}
    </div>
  </nav>

  <!-- ===== CONTENT ===== -->
  <slot />

  <!-- ===== FOOTER ===== -->
  <footer>
    <p>&copy; {new Date().getFullYear()} Nathaniel Cowperthwaite &mdash;
      <a href="/dev">Developer</a> &nbsp;&bull;&nbsp;
      <a href="/food">Chef</a> &nbsp;&bull;&nbsp;
      <a href="https://github.com/ShadowWalkerNC" target="_blank" rel="noopener">GitHub</a>
    </p>
  </footer>

  <!-- ===== SCROLL REVEAL SCRIPT ===== -->
  <script>
    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach(entry => {
          if (entry.isIntersecting) {
            entry.target.classList.add('revealed');
            observer.unobserve(entry.target);
          }
        });
      },
      { threshold: 0.12 }
    );
    document.querySelectorAll('.reveal, .reveal-left, .reveal-right')
      .forEach(el => observer.observe(el));
  </script>

</body>
</html>

<style>
.nav-logo {
  display: flex;
  align-items: center;
  gap: 0.5rem;
  text-decoration: none;
}
.nav-logo-name {
  font-size: 0.95rem;
  font-weight: 800;
  color: var(--text-primary);
  letter-spacing: -0.02em;
}
.nav-links {
  display: flex;
  align-items: center;
  gap: 0.25rem;
}
.nav-switch {
  font-weight: 600 !important;
  font-size: 0.82rem !important;
}
.nav-switch-dev {
  color: var(--accent-blue) !important;
  background: var(--accent-blue-pale) !important;
  border-radius: var(--radius-full) !important;
  padding: 0.25rem 0.8rem !important;
}
.nav-switch-food {
  color: var(--accent-ember) !important;
  background: var(--accent-ember-pale) !important;
  border-radius: var(--radius-full) !important;
  padding: 0.25rem 0.8rem !important;
}
.nav-switch-dev:hover {
  background: var(--accent-blue) !important;
  color: white !important;
}
.nav-switch-food:hover {
  background: var(--accent-ember) !important;
  color: white !important;
}
@media (max-width: 480px) {
  .nav-logo-name { display: none; }
  .nav-links { gap: 0.15rem; }
}
</style>
