---
const { label, icon } = Astro.props;
// icon: optional devicon slug, e.g. "javascript", "python", "typescript"
---
<span class="tech-badge">
  {icon && <i class={`devicon-${icon}-plain colored`}></i>}
  <span>{label}</span>
</span>

<style>
  .tech-badge {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    font-size: 0.72rem;
    font-weight: 600;
    font-family: var(--font-mono, 'Fira Code', monospace);
    color: #a5b4fc;
    background: rgba(99, 102, 241, 0.15);
    border: 1px solid rgba(99, 102, 241, 0.3);
    border-radius: 20px;
    padding: 3px 10px;
    transition: border-color 0.2s ease, color 0.2s ease, background 0.2s ease;
  }
  .tech-badge:hover {
    border-color: rgba(59, 130, 246, 0.5);
    background: rgba(59, 130, 246, 0.2);
    color: #bfdbfe;
  }
  .tech-badge i {
    font-size: 0.95rem;
    line-height: 1;
    flex-shrink: 0;
  }
</style>
