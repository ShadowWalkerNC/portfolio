---
const { title, subtitle, icon } = Astro.props;
---
<div class="ecosystem-banner">
  <div class="ecosystem-banner-glow"></div>
  <div class="ecosystem-banner-inner">
    <span class="ecosystem-icon">{icon}</span>
    <div>
      <p class="ecosystem-eyebrow">Ecosystem</p>
      <h2 class="ecosystem-title">{title}</h2>
      {subtitle && <p class="ecosystem-sub">{subtitle}</p>}
    </div>
  </div>
</div>

<style>
  .ecosystem-banner {
    position: relative;
    overflow: hidden;
    border-radius: var(--radius-lg);
    border: 1px solid var(--border-glow);
    background: linear-gradient(
      135deg,
      var(--bg-elevated) 0%,
      var(--accent-blue-pale) 100%
    );
    padding: 2rem;
    margin-bottom: 2rem;
    box-shadow: var(--shadow-md);
  }

  .ecosystem-banner-glow {
    position: absolute;
    inset: 0;
    background: radial-gradient(ellipse at top left, rgba(37,99,235,0.07) 0%, transparent 70%);
    pointer-events: none;
  }

  .ecosystem-banner-inner {
    position: relative;
    z-index: 1;
    display: flex;
    align-items: center;
    gap: 1.25rem;
  }

  .ecosystem-icon {
    font-size: 2.5rem;
    flex-shrink: 0;
  }

  .ecosystem-eyebrow {
    font-family: var(--font-mono);
    font-size: 0.65rem;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--accent-blue);
    margin-bottom: 0.25rem;
  }

  .ecosystem-title {
    font-size: 1.4rem;
    font-weight: 700;
    color: var(--text-primary);
    line-height: 1.2;
  }

  .ecosystem-sub {
    font-size: 0.85rem;
    color: var(--text-muted);
    margin-top: 0.35rem;
    line-height: 1.5;
  }
</style>
