  display: inline-flex; align-items: center; gap: 0.25rem;
}
.sc:hover { border-color: var(--accent-ember); color: var(--accent-ember); }
.sc-cert { border-color: #bbf7d0; background: #f0fdf4; color: #16a34a; }
.sc-cert svg { stroke: #16a34a; }

/* ===== FEATURED ===== */
.featured-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(280px, 1fr)); gap: 1.25rem; }
.featured-card {
  padding: 1.5rem; border-left: 3px solid var(--accent-ember);
  display: flex; flex-direction: column; gap: 0.6rem;
}
.featured-top { display: flex; justify-content: space-between; align-items: flex-start; gap: 0.5rem; }
.feat-role { font-size: 1rem; font-weight: 700; color: var(--text-primary); }
.feat-employer { font-size: 0.85rem; font-weight: 600; color: var(--accent-ember); margin-top: 1px; }
.feat-date { font-size: 0.72rem; color: var(--text-muted); font-weight: 500; white-space: nowrap; }
.feat-stat {
  font-size: 0.8rem; font-weight: 700; color: var(--accent-ember); margin: 0;
  display: inline-flex; align-items: center; gap: 0.3rem;
}
.feat-desc { font-size: 0.84rem; color: var(--text-secondary); line-height: 1.6; margin: 0; }
.feat-tags { display: flex; flex-wrap: wrap; gap: 0.3rem; margin-top: 0.25rem; }
.ftag {
  font-size: 0.65rem; font-weight: 600; padding: 0.15rem 0.5rem;
  border-radius: var(--radius-full); background: var(--bg-elevated);
  color: var(--text-muted); border: 1px solid var(--border-subtle);
  text-transform: uppercase; letter-spacing: 0.04em;
}

/* ===== TIMELINE ===== */
.timeline { display: flex; flex-direction: column; max-width: 820px; }
.tl-item {
  display: grid;
  grid-template-columns: 140px 24px 1fr;
  gap: 0 1.25rem;
  padding-bottom: 1.75rem;
}
.tl-last { padding-bottom: 0; }
.tl-left {
  display: flex; flex-direction: column; align-items: flex-end;
  padding-top: 3px; gap: 2px;
}
.tl-date { font-size: 0.72rem; font-weight: 700; color: var(--text-muted); text-align: right; line-height: 1.3; }
.tl-loc { font-size: 0.65rem; color: var(--text-muted); opacity: 0.7; text-align: right; }
.tl-col { display: flex; flex-direction: column; align-items: center; }
.tl-dot {
  width: 10px; height: 10px; flex-shrink: 0;
  border-radius: 50%;
  background: var(--border-subtle);
  border: 2px solid var(--bg-surface);
  margin-top: 4px; z-index: 2;
}
.tl-dot-active { background: var(--accent-ember); box-shadow: 0 0 0 3px rgba(249,115,22,0.2); }
.tl-dot-key { background: var(--accent-ember); opacity: 0.65; }
.tl-line { width: 1px; flex: 1; background: var(--border-subtle); margin-top: 4px; min-height: 8px; }
.tl-right { padding-top: 1px; padding-bottom: 0.25rem; }
.tl-role {
  font-size: 0.95rem; font-weight: 700; color: var(--text-primary);
  display: flex; align-items: center; gap: 0.5rem; line-height: 1.3;
}
.tl-badge-active {
  font-size: 0.6rem; font-weight: 700; text-transform: uppercase;
  letter-spacing: 0.06em; padding: 1px 6px;
  border-radius: var(--radius-full);
  background: rgba(249,115,22,0.12);
  color: var(--accent-ember);
  border: 1px solid rgba(249,115,22,0.3);
}
.tl-employer { font-size: 0.82rem; font-weight: 600; color: var(--accent-ember); margin-bottom: 0.3rem; }
.tl-desc { font-size: 0.82rem; color: var(--text-secondary); line-height: 1.6; margin: 0; }

/* ===== GALLERY ===== */
.culinary-gallery-grid {
  display: grid; grid-template-columns: repeat(auto-fill, minmax(260px, 1fr));
  gap: 1.5rem; margin-bottom: 2rem;
}
.gallery-card { padding: 0 !important; overflow: hidden; display: flex; flex-direction: column; }
.gallery-image-wrapper { width: 100%; aspect-ratio: 4/3; overflow: hidden; background: var(--bg-elevated); }
.gallery-img { width: 100%; height: 100%; object-fit: cover; transition: transform 0.5s cubic-bezier(0.16,1,0.3,1); }
.gallery-card:hover .gallery-img { transform: scale(1.04); }
.gallery-info { padding: 1.1rem; display: flex; flex-direction: column; gap: 0.4rem; }
.gallery-item-title { font-size: 1rem; font-weight: 700; color: var(--text-primary); margin: 0; }
.gallery-item-desc { font-size: 0.82rem; color: var(--text-muted); line-height: 1.5; margin: 0; }
.gallery-footer-action { display: flex; justify-content: center; margin-top: 1.5rem; }

/* ===== Responsive ===== */
@media (max-width: 640px) {
  .food-hero  { padding: 3.5rem 1rem 2.5rem; }
  .food-hero-stats { padding: 0.75rem 1rem; }
  .skills-row { grid-template-columns: 1fr; gap: 0.5rem; }
  .exp-cards  { grid-template-columns: 1fr; }
  .culinary-gallery-grid { grid-template-columns: 1fr; }
}

/* ===== Recipe Scaler Widget ===== */
.scaler-widget {
  display: grid;
  grid-template-columns: 1fr 1.2fr;
  gap: 2rem;
  padding: 2rem;
  margin-top: 1.5rem;
  background: var(--bg-surface);
  border: 1px solid var(--border-subtle);
  border-radius: var(--radius-lg);
}
@media (max-width: 768px) {
  .scaler-widget { grid-template-columns: 1fr; gap: 1.5rem; }
}
.scaler-controls {
  display: flex;
  flex-direction: column;
  gap: 1.5rem;
  justify-content: center;
}
.scaler-control-group {
  display: flex;
  flex-direction: column;
  gap: 0.5rem;
}
.scaler-label {
  font-family: var(--font-sans);
  font-size: 0.85rem;
  font-weight: 700;
  color: var(--text-primary);
  text-transform: uppercase;
  letter-spacing: 0.05em;
}
.scaler-select {
  width: 100%;
  padding: 0.65rem 0.85rem;
  background: var(--bg-elevated);
  border: 1px solid var(--border-subtle);
  border-radius: var(--radius-md);
  color: var(--text-primary);
  font-weight: 600;
  outline: none;
  cursor: pointer;
}
.slider-labels {
  display: flex;
  justify-content: space-between;
  align-items: center;
}
.slider-value {
  font-size: 0.95rem;
  font-weight: 800;
  color: var(--accent-ember);
}
.scaler-slider {
  -webkit-appearance: none;
  appearance: none;
  width: 100%;
  height: 6px;
  border-radius: var(--radius-full);
  background: var(--border-subtle);
  outline: none;
}
.scaler-slider::-webkit-slider-thumb {
  -webkit-appearance: none;
  appearance: none;
  width: 18px;
  height: 18px;
  border-radius: 50%;
  background: var(--accent-ember);
  cursor: pointer;
  box-shadow: var(--shadow-sm);
  transition: transform 0.1s ease;
}
.scaler-slider::-webkit-slider-thumb:hover {
  transform: scale(1.15);
}

.scaler-results {
  background: var(--bg-elevated);
  padding: 1.5rem;
  border-radius: var(--radius-md);
  border: 1px dashed var(--border-subtle);
}
.scaler-results-title {
  font-family: var(--font-serif);
  font-size: 1.15rem;
  font-weight: 400;
  color: var(--accent-ember-dim);
  border-bottom: 1px solid var(--border-subtle);
  padding-bottom: 0.5rem;
  margin-bottom: 1rem;
}
.ingredients-list {
  display: flex;
  flex-direction: column;
  gap: 0.75rem;
}
.ingredient-row {
  display: grid;
  grid-template-columns: 1.2fr 1fr auto;
  gap: 1rem;
  align-items: center;
  font-size: 0.85rem;
  color: var(--text-secondary);
}
.ing-name {
  font-weight: 600;
  color: var(--text-primary);
}
.ing-ratio-name {
  font-size: 0.72rem;
  color: var(--text-muted);
  text-transform: uppercase;
  letter-spacing: 0.02em;
}
.ing-amount {
  font-weight: 700;
  color: var(--accent-ember-dim);
  text-align: right;
}
</style>

<script>
  const recipes = {
    sourdough: {
      title: "Artisanal Sourdough (Baker's Percentages)",
      baseYield: 4,
      ingredients: [
        { name: "King Arthur Bread Flour", baseAmt: 1000, unit: "g", ratioName: "Flour (100%)" },
        { name: "Filtered Water", baseAmt: 720, unit: "g", ratioName: "Hydration (72%)" },
        { name: "Active Sourdough Starter", baseAmt: 200, unit: "g", ratioName: "Starter (20%)" },
        { name: "Fine Sea Salt", baseAmt: 20, unit: "g", ratioName: "Salt (2%)" }
      ]
    },
    scallops: {
      title: "Maine Scallops & Herb Puree",
      baseYield: 2,
      ingredients: [
        { name: "Fresh Maine Scallops", baseAmt: 8, unit: "pcs", ratioName: "Protein Base" },
        { name: "Unsalted Butter", baseAmt: 60, unit: "g", ratioName: "Basting Fat" },
        { name: "Chervil & Tarragon Blend", baseAmt: 40, unit: "g", ratioName: "Herb Base" },
        { name: "Extra Virgin Olive Oil", baseAmt: 30, unit: "ml", ratioName: "Emulsifier" },
        { name: "Lemon Juice", baseAmt: 15, unit: "ml", ratioName: "Acid Balance" }
      ]
    },
    sauce: {
      title: "Classic Demi-Glace Scratch Reduction",
      baseYield: 10,
      ingredients: [
        { name: "Roast Beef Bones (Brown Stock)", baseAmt: 2000, unit: "g", ratioName: "Bone Weight" },
        { name: "Mirepoix (Onions/Celery/Carrots)", baseAmt: 400, unit: "g", ratioName: "Aromatics (20%)" },
        { name: "Tomato Paste", baseAmt: 60, unit: "g", ratioName: "Acid/Color (3%)" },
        { name: "Red Wine", baseAmt: 300, unit: "ml", ratioName: "Deglazing (15%)" },
        { name: "Fresh Thyme & Bay Leaf", baseAmt: 10, unit: "g", ratioName: "Herbs" }
      ]
    }
  };

  const select = document.getElementById('recipe-select') as HTMLSelectElement;
  const slider = document.getElementById('yield-slider') as HTMLInputElement;
  const yieldDisplay = document.getElementById('yield-display');
  const recipeTitle = document.getElementById('recipe-title');
  const container = document.getElementById('ingredients-container');

  const updateScaler = () => {
    if (!select || !slider || !yieldDisplay || !recipeTitle || !container) return;
    const recipeKey = select.value as keyof typeof recipes;
    const yieldVal = parseInt(slider.value, 10);
    const recipe = recipes[recipeKey];

    yieldDisplay.textContent = `${yieldVal} ${yieldVal === 1 ? 'Portion' : 'Portions'}`;
    recipeTitle.textContent = recipe.title;

    const scaleFactor = yieldVal / recipe.baseYield;

    container.innerHTML = recipe.ingredients.map(ing => {
      const scaledAmt = (ing.baseAmt * scaleFactor).toFixed(1).replace(/\.0$/, '');
      return `
        <div class="ingredient-row">
          <span class="ing-name">${ing.name}</span>
          <span class="ing-ratio-name">${ing.ratioName}</span>
          <span class="ing-amount font-mono">${scaledAmt} ${ing.unit}</span>
        </div>
      `;
    }).join('');
  };

  if (select && slider) {
    select.addEventListener('change', updateScaler);
    slider.addEventListener('input', updateScaler);
    updateScaler();
  }
</script>
