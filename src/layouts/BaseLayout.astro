---
import '../styles/global.css';
const { title, description, side } = Astro.props;
// side: 'dev' | 'food' | undefined (neutral for landing)

const themeColor = side === 'food' ? '#f97316' : '#2563eb';
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content={description ?? 'Nate Cowperthwaite — Chef & Developer'} />
  <meta name="theme-color" content={themeColor} />
  <title>{title ?? 'Nate Cowperthwaite'}</title>
  {side === 'dev' && <link rel="icon" href="data:image/svg+xml,<svg xmlns=%22http://www.w3.org/2000/svg%22 viewBox=%220 0 100 100%22><text y=%22.9em%22 font-size=%2280%22>💻</text></svg>" />}
  {side === 'food' && <link rel="icon" href="data:image/svg+xml,<svg xmlns=%22http://www.w3.org/2000/svg%22 viewBox=%220 0 100 100%22><text y=%22.9em%22 font-size=%2280%22>👨‍🍳</text></svg>" />}
  {!side && <link rel="icon" type="image/svg+xml" href="/favicon.svg" />}
  {side === 'dev' && (
    <link
      rel="stylesheet"
      href="https://cdn.jsdelivr.net/gh/devicons/devicon@latest/devicon.min.css"
    />
  )}
</head>
<body data-side={side}>

  <!-- Skip link -->
  <a href="#main-content" class="skip-link">Skip to content</a>

  <!-- ===== NAV ===== -->
  <nav aria-label="Main navigation">
    <a href="/" class="nav-logo">
      <span class="nav-logo-name">Nate Cowperthwaite</span>
    </a>

    <!-- Mobile hamburger -->
    <button class="nav-burger" id="navBurger" aria-label="Toggle menu" aria-expanded="false" aria-controls="navMenu">
      <span></span><span></span><span></span>
    </button>

    <div class="nav-links" id="navMenu">
      {side === 'dev' && (
        <>
          <a href="/dev">Home</a>
          <a href="/dev/projects">Projects</a>
          <a href="/contact">Contact</a>
          <a href="/food" class="nav-switch nav-switch-food">&#127859; Chef Side</a>
        </>
      )}
      {side === 'food' && (
        <>
          <a href="/food">Home</a>
          <a href="/contact">Contact</a>
          <a href="/dev" class="nav-switch nav-switch-dev">&#128187; Dev Side</a>
        </>
      )}
      {!side && (
        <>
          <a href="/dev">Dev</a>
          <a href="/food">Food</a>
          <a href="/contact">Contact</a>
        </>
      )}
    </div>
  </nav>

  <!-- ===== MAIN ===== -->
  <slot />

  <!-- ===== FOOTER ===== -->
  <footer>
    <p>Built with Astro &amp; a lot of &#9749; &mdash; &copy; {new Date().getFullYear()} Nate Cowperthwaite</p>
    <p style="margin-top:0.4rem;">
      <a href="/dev">Dev</a> &middot;
      <a href="/food">Food</a> &middot;
      <a href="/contact">Contact</a>
    </p>
  </footer>

  <!-- ===== SCROLL REVEAL ===== -->
  <script>
    (() => {
      const els = document.querySelectorAll('.reveal, .reveal-left, .reveal-right');

      const reveal = (el: Element) => el.classList.add('revealed');

      const observer = new IntersectionObserver(
        (entries) => entries.forEach(e => {
          if (e.isIntersecting) {
            reveal(e.target);
            observer.unobserve(e.target);
          }
        }),
        {
          threshold: 0,
          rootMargin: '0px 0px 40px 0px'
        }
      );

      els.forEach(el => observer.observe(el));

      // Safety net: force-reveal anything the observer missed after 600ms
      setTimeout(() => els.forEach(reveal), 600);
    })();
  </script>

  <!-- ===== MOBILE NAV & INTERACTION ===== -->
  <script>
    const burger = document.getElementById('navBurger');
    const menu   = document.getElementById('navMenu');
    if (burger && menu) {
      burger.addEventListener('click', () => {
        const open = menu.classList.toggle('open');
        burger.classList.toggle('open', open);
        burger.setAttribute('aria-expanded', String(open));
      });
      // Mark active link
      const path = location.pathname;
      menu.querySelectorAll('a').forEach(a => {
        if (a.getAttribute('href') === path) a.setAttribute('aria-current', 'page');
      });
    }

    // High-performance dynamic mouse spotlight glow tracking
    const updateGlow = (e: MouseEvent) => {
      const targets = document.querySelectorAll('.spotlight-card, .split-half');
      targets.forEach((el) => {
        const rect = el.getBoundingClientRect();
        const x = e.clientX - rect.left;
        const y = e.clientY - rect.top;
        (el as HTMLElement).style.setProperty('--mouse-x', `${x}px`);
        (el as HTMLElement).style.setProperty('--mouse-y', `${y}px`);
      });
    };
    
    // Throttled listener for scroll/move performance
    let frameId: number | null = null;
    document.addEventListener('mousemove', (e) => {
      if (frameId) cancelAnimationFrame(frameId);
      frameId = requestAnimationFrame(() => updateGlow(e));
    });
  </script>

</body>
</html>
