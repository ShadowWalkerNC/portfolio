---
import BaseLayout from '../../layouts/BaseLayout.astro';
---
<BaseLayout title="Nate Cowperthwaite — Chef" description="10+ years in professional kitchens across Maine. Scratch cooking, shift leadership, and the craft behind the food." side="food">
  <main>

    <!-- ===== HERO ===== -->
    <section class="food-hero">
      <div class="food-hero-content animate-fade-in-up">
        <div class="food-hero-kicker">
          <span class="badge badge-ember">&#127859; Culinary Portfolio</span>
        </div>
        <h1 class="food-hero-title">
          Cooking is a craft.<br />
          <span class="food-hero-accent">I&rsquo;ve spent a decade</span><br />
          perfecting mine.
        </h1>
        <p class="food-hero-sub">
          Scratch kitchens, assisted living dining, food trucks, fine dining &mdash;
          from Rockport to Bangor, Maine. Every role shaped how I cook, lead, and build.
        </p>
        <div class="food-hero-actions">
          <a href="https://photos.app.goo.gl/JGgx37aAA1vhip3z9" target="_blank" rel="noopener" class="btn btn-ember">&#128247; View Photo Gallery</a>
          <a href="#resume" class="btn btn-ghost">See Work History</a>
        </div>
      </div>
      <div class="food-hero-stats reveal-right">
        <div class="food-stat"><span class="food-stat-num">10+</span><span class="food-stat-label">Years in Kitchens</span></div>
        <div class="food-stat-div"></div>
        <div class="food-stat"><span class="food-stat-num food-stat-ember">12+</span><span class="food-stat-label">Culinary Roles</span></div>
        <div class="food-stat-div"></div>
        <div class="food-stat"><span class="food-stat-num">1</span><span class="food-stat-label">Co-Founded Brand</span></div>
      </div>
    </section>

    <div class="divider-fusion"></div>

    <!-- ===== PHOTO GALLERY CTA ===== -->
    <section class="section reveal">
      <h2 class="section-heading">The Food</h2>
      <p class="section-sub">A look at what comes out of my kitchen.</p>
      <div class="gallery-cta-block">
        <div class="gallery-cta-inner">
          <div class="gallery-cta-icon">&#127859;</div>
          <div class="gallery-cta-text">
            <h3>Food Photography Gallery</h3>
            <p>Dishes, prep work, and kitchen moments &mdash; captured from real service.</p>
          </div>
          <a href="https://photos.app.goo.gl/JGgx37aAA1vhip3z9" target="_blank" rel="noopener" class="btn btn-ember">&#128247; Open Full Gallery &rarr;</a>
        </div>
      </div>
    </section>

    <div class="divider"></div>

    <!-- ===== WORK HISTORY / RÉSUMÉ ===== -->
    <section class="section" id="resume">
      <h2 class="section-heading reveal">Work History</h2>
      <p class="section-sub reveal">Key roles across 10+ years of professional kitchen work in Maine.</p>

      <!-- CURRENT -->
      <div class="resume-group reveal">
        <div class="resume-group-label resume-group-current">&#128308; Currently Active</div>
        <div class="resume-cards">
          <div class="resume-card card">
            <div class="resume-card-header">
              <div>
                <div class="resume-role">Cook</div>
                <div class="resume-employer">Ross Manor (Sylvia Ross)</div>
                <div class="resume-location">&#128205; Bangor, ME</div>
              </div>
              <div class="resume-badge"><span class="badge badge-ember">Active</span><span class="resume-dates">2024–Present</span></div>
            </div>
            <p class="resume-desc">Assisted living kitchen. Scratch-made meals for residents with specialized and restricted dietary needs. Trusted day-to-day kitchen contributor managing dietary accommodations under shift structure.</p>
            <div class="resume-tags">
              <span class="res-tag">Scratch Cooking</span>
              <span class="res-tag">Dietary Management</span>
              <span class="res-tag">Shift Structure</span>
            </div>
          </div>
          <div class="resume-card card">
            <div class="resume-card-header">
              <div>
                <div class="resume-role">Co-Founder</div>
                <div class="resume-employer">Northern Fixin&rsquo;s / Half Baked Co.</div>
                <div class="resume-location">&#128205; Bangor, ME</div>
              </div>
              <div class="resume-badge"><span class="badge badge-ember">Active</span><span class="resume-dates">2023–Present</span></div>
            </div>
            <p class="resume-desc">Co-founded Maine-inspired elevated café, scratch bakehouse, and food truck concept. Half Baked Café & Bakehouse targeting brick-and-mortar launch in 2027. Alley Katz food truck concept in development.</p>
            <div class="resume-tags">
              <span class="res-tag">Co-Founder</span>
              <span class="res-tag">Menu Development</span>
              <span class="res-tag">Food Truck Ops</span>
              <span class="res-tag">Bakehouse</span>
            </div>
          </div>
        </div>
      </div>

      <!-- 2024-2025 -->
      <div class="resume-group reveal">
        <div class="resume-group-label resume-group-recent">&#128993; 2024–2025</div>
        <div class="resume-cards">
          <div class="resume-card card">
            <div class="resume-card-header">
              <div>
                <div class="resume-role">Shift Lead</div>
                <div class="resume-employer">Seasons Bar and Grille</div>
                <div class="resume-location">&#128205; Bangor, ME</div>
              </div>
              <span class="resume-dates">Feb 2025</span>
            </div>
            <p class="resume-desc">Kitchen and FOH shift leadership. Staff coordination, service flow management, and guest experience oversight.</p>
            <div class="resume-tags">
              <span class="res-tag">Shift Leadership</span>
              <span class="res-tag">FOH/BOH</span>
              <span class="res-tag">Staff Coordination</span>
            </div>
          </div>
          <div class="resume-card card">
            <div class="resume-card-header">
              <div>
                <div class="resume-role">Line Cook</div>
                <div class="resume-employer">Mason&rsquo;s Brewing Company</div>
                <div class="resume-location">&#128205; Bangor, ME</div>
              </div>
              <span class="resume-dates">Aug 2024</span>
            </div>
            <p class="resume-desc">Craft brewery kitchen. High-volume line execution and scratch cooking in a fast-paced service environment.</p>
            <div class="resume-tags">
              <span class="res-tag">High Volume</span>
              <span class="res-tag">Line Cook</span>
              <span class="res-tag">Scratch Cooking</span>
            </div>
          </div>
        </div>
      </div>

      <!-- DEFINING ROLES -->
      <div class="resume-group reveal">
        <div class="resume-group-label resume-group-defining">&#11088; Defining Roles</div>
        <div class="resume-cards">
          <div class="resume-card card resume-card-featured">
            <div class="resume-card-header">
              <div>
                <div class="resume-role">Line Cook / Sous Chef</div>
                <div class="resume-employer">Daddy B&rsquo;s Food Truck</div>
              </div>
              <span class="resume-dates">2022</span>
            </div>
            <p class="resume-desc">Mobile kitchen operations. Menu execution, prep, and sous chef duties. Direct creative influence on the Northern Fixin's concept — this role sparked the food truck dream.</p>
            <div class="resume-tags">
              <span class="res-tag">Sous Chef</span>
              <span class="res-tag">Food Truck</span>
              <span class="res-tag">Menu Dev</span>
            </div>
          </div>
          <div class="resume-card card resume-card-featured">
            <div class="resume-card-header">
              <div>
                <div class="resume-role">Sous Chef</div>
                <div class="resume-employer">Ports of Italy</div>
              </div>
              <span class="resume-dates">2020</span>
            </div>
            <p class="resume-desc">Italian fine dining. Station leadership, menu prep, and kitchen coordination. A pivotal role that elevated technique and kitchen management skills.</p>
            <div class="resume-tags">
              <span class="res-tag">Fine Dining</span>
              <span class="res-tag">Sous Chef</span>
              <span class="res-tag">Italian Cuisine</span>
              <span class="res-tag">Station Lead</span>
            </div>
          </div>
          <div class="resume-card card resume-card-featured">
            <div class="resume-card-header">
              <div>
                <div class="resume-role">Breakfast Cook</div>
                <div class="resume-employer">Boynton McKay Food Co.</div>
                <div class="resume-location">&#128205; Camden, ME</div>
              </div>
              <span class="resume-dates">2019</span>
            </div>
            <p class="resume-desc">Iconic Maine café with high tourist-season volume. Full scratch breakfast service. Consistency, speed, and quality under pressure.</p>
            <div class="resume-tags">
              <span class="res-tag">Scratch Breakfast</span>
              <span class="res-tag">High Volume</span>
              <span class="res-tag">Maine Café</span>
            </div>
          </div>
          <div class="resume-card card resume-card-featured">
            <div class="resume-card-header">
              <div>
                <div class="resume-role">Grill Cook / Line Cook</div>
                <div class="resume-employer">Samoset Resort</div>
                <div class="resume-location">&#128205; Rockport, ME</div>
              </div>
              <span class="resume-dates">2014</span>
            </div>
            <p class="resume-desc">Premier Maine coastal resort. First major culinary role. Banquet and hospitality experience at scale — where the foundation was built.</p>
            <div class="resume-tags">
              <span class="res-tag">First Major Role</span>
              <span class="res-tag">Banquet</span>
              <span class="res-tag">Coastal Resort</span>
              <span class="res-tag">Hospitality</span>
            </div>
          </div>
        </div>
      </div>
    </section>

    <div class="divider"></div>

    <!-- ===== SKILLS ===== -->
    <section class="section reveal">
      <h2 class="section-heading">Culinary Skills</h2>
      <p class="section-sub">A decade of real kitchen work across every station.</p>
      <div class="skills-grid">
        <div class="skill-group">
          <div class="skill-group-label">Technique</div>
          <div class="skill-chips stagger">
            <span class="skill-chip">Knife Skills</span>
            <span class="skill-chip">Sautéing</span>
            <span class="skill-chip">Flat-top Griddle</span>
            <span class="skill-chip">Deep Frying</span>
            <span class="skill-chip">Combi Ovens</span>
            <span class="skill-chip">Scratch Baking</span>
          </div>
        </div>
        <div class="skill-group">
          <div class="skill-group-label">Service</div>
          <div class="skill-chips stagger">
            <span class="skill-chip">Breakfast Service</span>
            <span class="skill-chip">Fine Dining</span>
            <span class="skill-chip">Banquet/Catering</span>
            <span class="skill-chip">Food Truck Ops</span>
            <span class="skill-chip">High Volume Line</span>
          </div>
        </div>
        <div class="skill-group">
          <div class="skill-group-label">Leadership & Ops</div>
          <div class="skill-chips stagger">
            <span class="skill-chip">Shift Supervision</span>
            <span class="skill-chip">Staff Coordination</span>
            <span class="skill-chip">Dietary Management</span>
            <span class="skill-chip">Inventory Control</span>
            <span class="skill-chip">Menu Development</span>
            <span class="skill-chip">Recipe Costing</span>
          </div>
        </div>
        <div class="skill-group">
          <div class="skill-group-label">Certifications</div>
          <div class="skill-chips stagger">
            <span class="skill-chip skill-chip-cert">&#9989; Food Handler Certified</span>
            <span class="skill-chip skill-chip-cert">&#9989; Driver&rsquo;s License</span>
          </div>
        </div>
      </div>
    </section>

  </main>
</BaseLayout>

<style>
/* ---- Food Hero ---- */
.food-hero {
  max-width: 1100px;
  margin: 0 auto;
  padding: 5rem 1.5rem 3rem;
  display: grid;
  grid-template-columns: 1fr auto;
  gap: 3rem;
  align-items: start;
}
.food-hero-content { max-width: 600px; }
.food-hero-kicker  { margin-bottom: 1rem; }
.food-hero-title {
  font-size: clamp(2rem, 5vw, 3.2rem);
  font-weight: 900;
  line-height: 1.1;
  color: var(--text-primary);
  letter-spacing: -0.03em;
  margin-bottom: 1.2rem;
}
.food-hero-accent { color: var(--accent-ember); }
.food-hero-sub {
  font-size: 1rem;
  color: var(--text-muted);
  line-height: 1.7;
  margin-bottom: 2rem;
  max-width: 480px;
}
.food-hero-actions { display: flex; gap: 0.75rem; flex-wrap: wrap; }

.food-hero-stats {
  display: flex;
  flex-direction: column;
  gap: 1.2rem;
  padding: 1.5rem;
  background: var(--bg-surface);
  border: 1px solid var(--border-subtle);
  border-radius: var(--radius-lg);
  box-shadow: var(--shadow-md);
  min-width: 140px;
  align-items: center;
  margin-top: 1rem;
}
.food-stat { display: flex; flex-direction: column; align-items: center; gap: 2px; }
.food-stat-num {
  font-size: 2rem;
  font-weight: 800;
  color: var(--text-primary);
  line-height: 1;
}
.food-stat-ember { color: var(--accent-ember); }
.food-stat-label {
  font-size: 0.65rem;
  text-transform: uppercase;
  letter-spacing: 0.08em;
  color: var(--text-muted);
  text-align: center;
}
.food-stat-div { width: 40px; height: 1px; background: var(--border-subtle); }

/* ---- Gallery CTA ---- */
.gallery-cta-block {
  background: linear-gradient(135deg, #fff7ed, #ffedd5);
  border: 1px solid var(--border-ember);
  border-radius: var(--radius-lg);
  padding: 2.5rem;
  box-shadow: var(--shadow-md);
}
.gallery-cta-inner {
  display: flex;
  align-items: center;
  gap: 1.5rem;
  flex-wrap: wrap;
}
.gallery-cta-icon { font-size: 3rem; flex-shrink: 0; animation: float 3s ease-in-out infinite; }
.gallery-cta-text { flex: 1; min-width: 200px; }
.gallery-cta-text h3 {
  font-size: 1.2rem;
  font-weight: 800;
  color: var(--text-primary);
  margin-bottom: 0.3rem;
}
.gallery-cta-text p { font-size: 0.9rem; color: var(--text-muted); margin: 0; }

/* ---- Resume ---- */
.resume-group { margin-bottom: 2.5rem; }
.resume-group-label {
  font-size: 0.72rem;
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: 0.1em;
  margin-bottom: 1rem;
  padding: 0.3rem 0.8rem;
  border-radius: var(--radius-full);
  display: inline-flex;
  align-items: center;
  gap: 0.3rem;
}
.resume-group-current  { background: #fef2f2; color: #dc2626; border: 1px solid #fecaca; }
.resume-group-recent   { background: #fffbeb; color: #d97706; border: 1px solid #fde68a; }
.resume-group-defining { background: #fefce8; color: #a16207; border: 1px solid #fef08a; }

.resume-cards { display: grid; grid-template-columns: repeat(auto-fill, minmax(300px, 1fr)); gap: 1rem; }

.resume-card {
  padding: 1.4rem;
  display: flex;
  flex-direction: column;
  gap: 0.75rem;
}
.resume-card-featured { border-left: 3px solid var(--accent-ember); }

.resume-card-header {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  gap: 0.5rem;
}
.resume-role     { font-size: 1rem; font-weight: 700; color: var(--text-primary); }
.resume-employer { font-size: 0.9rem; font-weight: 600; color: var(--accent-ember); margin-top: 1px; }
.resume-location { font-size: 0.78rem; color: var(--text-muted); margin-top: 2px; }
.resume-badge    { display: flex; flex-direction: column; align-items: flex-end; gap: 3px; }
.resume-dates    { font-size: 0.75rem; color: var(--text-muted); font-weight: 500; white-space: nowrap; }
.resume-desc     { font-size: 0.85rem; color: var(--text-secondary); line-height: 1.6; margin: 0; }

.resume-tags { display: flex; flex-wrap: wrap; gap: 0.35rem; }
.res-tag {
  font-size: 0.68rem;
  font-weight: 600;
  padding: 0.2rem 0.55rem;
  border-radius: var(--radius-full);
  background: var(--bg-elevated);
  color: var(--text-muted);
  border: 1px solid var(--border-subtle);
  text-transform: uppercase;
  letter-spacing: 0.04em;
}

/* ---- Skills ---- */
.skills-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(220px, 1fr)); gap: 1.5rem; }
.skill-group { display: flex; flex-direction: column; gap: 0.5rem; }
.skill-group-label {
  font-size: 0.7rem;
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: 0.1em;
  color: var(--text-muted);
}
.skill-chips { display: flex; flex-wrap: wrap; gap: 0.4rem; }
.skill-chip {
  font-size: 0.78rem;
  font-weight: 600;
  padding: 5px 13px;
  border-radius: var(--radius-full);
  background: var(--bg-surface);
  color: var(--text-secondary);
  border: 1px solid var(--border-subtle);
  box-shadow: var(--shadow-sm);
  transition: border-color 0.2s, color 0.2s, background 0.2s;
}
.skill-chip:hover {
  border-color: var(--accent-ember);
  color: var(--accent-ember);
  background: var(--accent-ember-pale);
}
.skill-chip-cert {
  border-color: #bbf7d0;
  background: #f0fdf4;
  color: #16a34a;
}

/* ---- Responsive ---- */
@media (max-width: 768px) {
  .food-hero { grid-template-columns: 1fr; gap: 2rem; padding: 3rem 1rem 2rem; }
  .food-hero-stats { flex-direction: row; min-width: unset; }
  .resume-cards { grid-template-columns: 1fr; }
  .skills-grid { grid-template-columns: 1fr 1fr; }
}
@media (max-width: 480px) {
  .skills-grid { grid-template-columns: 1fr; }
  .gallery-cta-inner { flex-direction: column; text-align: center; }
}
</style>
