---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ProjectCard from '../../components/ProjectCard.astro';
import { getCollection } from 'astro:content';

const allProjects = await getCollection('projects');
---

<BaseLayout title="Projects — Nate Cowperthwaite" description="All developer projects by Nate Cowperthwaite." side="dev">
  <main class="section">
    <h1 class="section-heading reveal">All Projects</h1>
    <p class="section-sub reveal">Everything shipped so far. <a href="/dev" class="inline-link">&larr; Back to Dev Home</a></p>
    <div class="projects-grid">
      {allProjects.map(p => (
        <ProjectCard
          id={p.id}
          title={p.data.title}
          tagline={p.data.tagline}
          description={p.data.description}
          story={p.data.story}
          forWho={p.data.forWho}
          tags={p.data.tags}
          stack={p.data.stack}
          status={p.data.status}
          links={p.data.links}
          detailedSpecs={p.data.detailedSpecs}
        />
      ))}
    </div>
  </main>
</BaseLayout>

<script>
  // Card entrance observer — runs once after all cards are in the DOM
  const cards = document.querySelectorAll('.card-entrance');

  const reveal = (card: Element, idx: number) => {
    if (card.classList.contains('card-visible')) return;
    (card as HTMLElement).style.animationDelay = (idx * 0.07) + 's';
    card.classList.add('card-visible');
  };

  const io = new IntersectionObserver((entries) => {
    entries.forEach(entry => {
      if (!entry.isIntersecting) return;
      const siblings = Array.from(entry.target.parentElement?.children ?? []);
      const idx = siblings.indexOf(entry.target);
      reveal(entry.target, idx);
      io.unobserve(entry.target);
    });
  }, {
    threshold: 0,
    rootMargin: '0px 0px 40px 0px'
  });

  cards.forEach(card => io.observe(card));

  // Safety net: force-reveal anything the observer missed after 800ms
  setTimeout(() => {
    cards.forEach((card, idx) => reveal(card, idx));
  }, 800);
</script>

<style>
.projects-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(320px, 1fr)); gap: 1.25rem; }
@media (max-width: 640px) { .projects-grid { grid-template-columns: 1fr; } }
</style>
