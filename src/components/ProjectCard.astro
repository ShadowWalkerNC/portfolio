---
interface DetailedSpecs {
  architecture?: string;
  dataFlow?: string;
  keyPatterns?: string[];
  apiSurface?: string;
  deployTarget?: string;
  notableFiles?: string[];
}

interface Props {
  title: string;
  tagline: string;
  description: string;
  story?: string;
  forWho?: string;
  tags: string[];
  stack: string[];
  status: 'active' | 'stable' | 'archived' | 'wip';
  links?: { github?: string; live?: string; docs?: string };
  detailedSpecs?: DetailedSpecs;
  id: string;
}

const { title, tagline, description, story, forWho, tags, stack, status, links, detailedSpecs, id } = Astro.props;

const statusMap = {
  active:   { label: 'Active',      color: 'badge-active' },
  stable:   { label: 'Stable',      color: 'badge-stable' },
  archived: { label: 'Archived',    color: 'badge-archived' },
  wip:      { label: 'In Progress', color: 'badge-wip' },
};
const s = statusMap[status];
---

<article class="project-card spotlight-card" id={`card-${id}`}>
  <!-- Header Row -->
  <div class="card-header">
    <div class="card-title-group">
      <h3 class="card-title">{title}</h3>
      <span class={`status-badge ${s.color}`}>{s.label}</span>
    </div>
    {forWho && (
      <p class="for-who-badge">&#128100; {forWho}</p>
    )}
  </div>

  <!-- Tagline -->
  <p class="card-tagline">{tagline}</p>

  <!-- Description -->
  <p class="card-description">{description}</p>

  <!-- Tech Stack -->
  <div class="card-stack">
    {stack.map(tech => (
      <span class="tech-chip">{tech}</span>
    ))}
  </div>

  <!-- Tags -->
  <div class="card-tags">
    {tags.map(tag => (
      <span class="tag-chip">#{tag}</span>
    ))}
  </div>

  <!-- Links -->
  {links && (
    <div class="card-links">
      {links.github && <a href={links.github} target="_blank" rel="noopener" class="card-link link-github">GitHub &rarr;</a>}
      {links.live   && <a href={links.live}   target="_blank" rel="noopener" class="card-link link-live">Live Site &rarr;</a>}
      {links.docs   && <a href={links.docs}   target="_blank" rel="noopener" class="card-link link-docs">Docs &rarr;</a>}
    </div>
  )}

  <!-- Accordion: Tech Deep-Dive -->
  {(story || detailedSpecs) && (
    <div class="accordion-wrapper">
      <button
        class="accordion-trigger"
        aria-expanded="false"
        aria-controls={`details-${id}`}
        onclick={`toggleAccordion('${id}')`}
      >
        <span class="accordion-label">Technical Deep-Dive</span>
        <svg class="chevron-icon" xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
          <polyline points="6 9 12 15 18 9"></polyline>
        </svg>
      </button>

      <div id={`details-${id}`} class="accordion-body" hidden>
        {story && (
          <div class="spec-block">
            <h4 class="spec-heading">&#128218; Origin Story</h4>
            <p class="spec-text">{story}</p>
          </div>
        )}
        {detailedSpecs?.architecture && (
          <div class="spec-block">
            <h4 class="spec-heading">&#127959; Architecture</h4>
            <p class="spec-text">{detailedSpecs.architecture}</p>
          </div>
        )}
        {detailedSpecs?.dataFlow && (
          <div class="spec-block">
            <h4 class="spec-heading">&#10145; Data Flow</h4>
            <p class="spec-text">{detailedSpecs.dataFlow}</p>
          </div>
        )}
        {detailedSpecs?.keyPatterns && detailedSpecs.keyPatterns.length > 0 && (
          <div class="spec-block">
            <h4 class="spec-heading">&#128207; Key Patterns</h4>
            <ul class="spec-list">
              {detailedSpecs.keyPatterns.map(p => <li>{p}</li>)}
            </ul>
          </div>
        )}
        {detailedSpecs?.apiSurface && (
          <div class="spec-block">
            <h4 class="spec-heading">&#128225; API Surface</h4>
            <p class="spec-text">{detailedSpecs.apiSurface}</p>
          </div>
        )}
        {detailedSpecs?.deployTarget && (
          <div class="spec-block">
            <h4 class="spec-heading">&#128640; Deploy Target</h4>
            <p class="spec-text">{detailedSpecs.deployTarget}</p>
          </div>
        )}
        {detailedSpecs?.notableFiles && detailedSpecs.notableFiles.length > 0 && (
          <div class="spec-block">
            <h4 class="spec-heading">&#128196; Notable Files</h4>
            <ul class="spec-list mono">
              {detailedSpecs.notableFiles.map(f => <li>{f}</li>)}
            </ul>
          </div>
        )}
      </div>
    </div>
  )}
</article>

<script is:inline>
function toggleAccordion(id) {
  const body    = document.getElementById('details-' + id);
  const btn     = body.previousElementSibling;
  const chevron = btn.querySelector('.chevron-icon');
  const open    = !body.hidden;
  body.hidden   = open;
  btn.setAttribute('aria-expanded', String(!open));
  chevron.style.transform = open ? 'rotate(0deg)' : 'rotate(180deg)';
}

// Spotlight hover — runs once per page
if (typeof window.__spotlightInit === 'undefined') {
  window.__spotlightInit = true;
  document.addEventListener('mousemove', (e) => {
    document.querySelectorAll('.spotlight-card').forEach((card) => {
      const rect = card.getBoundingClientRect();
      const x = ((e.clientX - rect.left) / rect.width) * 100;
      const y = ((e.clientY - rect.top)  / rect.height) * 100;
      card.style.setProperty('--sx', x + '%');
      card.style.setProperty('--sy', y + '%');
    });
  });
}
</script>

<style>
.project-card {
  background: var(--card-bg);
  border: 1px solid var(--border-subtle);
  border-radius: 12px;
  padding: 1.5rem;
  transition: border-color 0.2s ease, box-shadow 0.2s ease;
  display: flex;
  flex-direction: column;
  gap: 0.75rem;
  position: relative;
  overflow: hidden;
}

/* Spotlight beam layer */
.spotlight-card::before {
  content: '';
  position: absolute;
  inset: 0;
  border-radius: inherit;
  background: radial-gradient(
    500px circle at var(--sx, 50%) var(--sy, 50%),
    rgba(37, 99, 235, 0.07),
    transparent 60%
  );
  pointer-events: none;
  opacity: 0;
  transition: opacity 0.3s ease;
  z-index: 0;
}
.spotlight-card:hover::before {
  opacity: 1;
}

/* Push card content above the spotlight layer */
.project-card > * {
  position: relative;
  z-index: 1;
}

.project-card:hover {
  border-color: var(--accent-blue);
  box-shadow: 0 0 0 1px var(--accent-blue), var(--glow-blue);
}
.card-header { display: flex; flex-direction: column; gap: 0.35rem; }
.card-title-group { display: flex; align-items: center; gap: 0.75rem; flex-wrap: wrap; }
.card-title { font-size: 1.2rem; font-weight: 700; color: var(--text-primary); margin: 0; }
.status-badge {
  font-size: 0.65rem; font-weight: 600; text-transform: uppercase;
  padding: 2px 8px; border-radius: 20px; letter-spacing: 0.05em;
}
.badge-active   { background: rgba(34,197,94,0.15);  color: #4ade80; border: 1px solid rgba(34,197,94,0.3); }
.badge-stable   { background: rgba(59,130,246,0.15); color: #60a5fa; border: 1px solid rgba(59,130,246,0.3); }
.badge-wip      { background: rgba(250,204,21,0.15); color: #fcd34d; border: 1px solid rgba(250,204,21,0.3); }
.badge-archived { background: rgba(156,163,175,0.15);color: #9ca3af; border: 1px solid rgba(156,163,175,0.3); }
.for-who-badge {
  font-size: 0.78rem; color: var(--text-muted);
  background: rgba(99,179,237,0.08); border: 1px solid rgba(99,179,237,0.2);
  border-radius: 6px; padding: 4px 10px; margin: 0; width: fit-content;
}
.card-tagline { font-size: 0.95rem; color: var(--accent-blue); font-style: italic; margin: 0; }
.card-description { font-size: 0.88rem; color: var(--text-secondary); line-height: 1.6; margin: 0; }
.card-stack, .card-tags { display: flex; flex-wrap: wrap; gap: 0.4rem; }
.tech-chip {
  font-size: 0.72rem; font-weight: 600; padding: 3px 10px; border-radius: 20px;
  background: rgba(99,102,241,0.15); color: #a5b4fc;
  border: 1px solid rgba(99,102,241,0.3);
}
.tag-chip { font-size: 0.7rem; color: var(--text-muted); opacity: 0.7; }
.card-links { display: flex; flex-wrap: wrap; gap: 0.6rem; }
.card-link {
  font-size: 0.8rem; font-weight: 600; padding: 5px 14px; border-radius: 6px;
  text-decoration: none; transition: all 0.2s ease;
}
.link-github { background: rgba(255,255,255,0.05); color: var(--text-secondary); border: 1px solid var(--border-subtle); }
.link-github:hover { border-color: var(--accent-blue); color: var(--accent-blue); }
.link-live { background: var(--accent-blue); color: #0d1117; }
.link-live:hover { filter: brightness(1.15); }
.link-docs { background: rgba(99,179,237,0.1); color: var(--accent-blue); border: 1px solid rgba(99,179,237,0.2); }

/* Accordion */
.accordion-wrapper { border-top: 1px solid var(--border-subtle); padding-top: 0.75rem; margin-top: 0.25rem; }
.accordion-trigger {
  display: flex; align-items: center; justify-content: space-between;
  width: 100%; background: none; border: none; cursor: pointer;
  color: var(--text-muted); font-size: 0.8rem; font-weight: 600;
  text-transform: uppercase; letter-spacing: 0.07em; padding: 0;
  transition: color 0.2s;
}
.accordion-trigger:hover { color: var(--accent-blue); }
.chevron-icon { transition: transform 0.25s ease; flex-shrink: 0; }
.accordion-body { margin-top: 1rem; display: flex; flex-direction: column; gap: 1rem; }
.accordion-body[hidden] { display: none; }
.spec-block { display: flex; flex-direction: column; gap: 0.3rem; }
.spec-heading { font-size: 0.78rem; font-weight: 700; color: var(--text-secondary); text-transform: uppercase; letter-spacing: 0.05em; margin: 0; }
.spec-text { font-size: 0.83rem; color: var(--text-muted); line-height: 1.65; margin: 0; }
.spec-list { font-size: 0.83rem; color: var(--text-muted); line-height: 1.8; margin: 0; padding-left: 1.2rem; }
.spec-list.mono li { font-family: var(--font-mono); font-size: 0.78rem; color: #7dd3fc; }
</style>
