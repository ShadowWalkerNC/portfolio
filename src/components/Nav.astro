---
const links = [
  { href: '/',         label: 'Home' },
  { href: '/projects', label: 'Projects' },
  { href: '/contact',  label: 'Contact' },
];

const current = Astro.url.pathname;
---

<header class="glass-strong fixed top-0 left-0 right-0 z-50">
  <nav class="max-w-6xl mx-auto px-6 h-16 flex items-center justify-between">
    <a href="/" class="font-bold text-lg tracking-tight transition" style="color: #E2E8F0;"
      onmouseover="this.style.color='var(--blue-bright)'"
      onmouseout="this.style.color='#E2E8F0'">
      Nate<span style="color: var(--blue-primary);">.</span>dev
    </a>
    <ul class="flex items-center gap-6">
      {links.map(({ href, label }) => (
        <li>
          <a
            href={href}
            class="font-medium text-sm transition"
            style={current === href
              ? 'color: var(--blue-bright);'
              : 'color: var(--text-subtle);'}
            onmouseover="this.style.color='var(--blue-bright)'"
            onmouseout={`this.style.color='${current === href ? 'var(--blue-bright)' : 'var(--text-subtle)'}'`}
          >
            {label}
          </a>
        </li>
      ))}
    </ul>
  </nav>
</header>
