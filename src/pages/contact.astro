---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Contact — ShadowWalkerNC">
  <div class="max-w-2xl mx-auto px-6 pt-28 pb-20">
    <h1 class="text-5xl font-bold mb-4">Get in Touch</h1>
    <p class="text-gray-400 text-lg mb-12">
      Open to collaborations, contract work, and conversations about food tech, AI tooling, or restaurant ops.
    </p>

    <div class="space-y-6">
      <a
        href="mailto:shadowwalkernc@gmail.com"
        class="flex items-center gap-4 p-5 bg-brand-card border border-brand-border rounded-xl hover:border-brand-purple/50 transition group"
      >
        <span class="text-2xl">✉️</span>
        <div>
          <p class="font-semibold text-white group-hover:text-brand-purple transition">Email</p>
          <p class="text-gray-400 text-sm">shadowwalkernc@gmail.com</p>
        </div>
      </a>

      <a
        href="https://github.com/ShadowWalkerNC"
        target="_blank"
        rel="noopener noreferrer"
        class="flex items-center gap-4 p-5 bg-brand-card border border-brand-border rounded-xl hover:border-brand-purple/50 transition group"
      >
        <span class="text-2xl">🐙</span>
        <div>
          <p class="font-semibold text-white group-hover:text-brand-purple transition">GitHub</p>
          <p class="text-gray-400 text-sm">github.com/ShadowWalkerNC</p>
        </div>
      </a>
    </div>

    <div class="mt-16 p-6 bg-brand-card border border-brand-border rounded-xl">
      <p class="text-brand-purple font-mono text-sm mb-2">// Location</p>
      <p class="text-white font-semibold">Bangor, Maine</p>
      <p class="text-gray-400 text-sm mt-1">Opening Half Baked Café & Bakehouse — 2027</p>
    </div>
  </div>
</BaseLayout>
